---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';
---

<Layout title="Compare Properties">
  <Navbar />

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/search" class="text-sm text-[#ea580c] hover:underline font-medium">← Back to Search</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-2">Compare Properties</h1>
      <p class="text-gray-500 text-sm mt-1">Side-by-side comparison of selected properties</p>
    </div>

    <div id="compare-loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-2 border-[#ea580c] border-t-transparent rounded-full animate-spin mb-4"></div>
      <p class="text-gray-400 text-sm">Loading properties...</p>
    </div>

    <div id="compare-content" class="hidden">
      <div id="compare-table" class="overflow-x-auto"></div>
      <div class="mt-6 flex justify-center gap-4 flex-wrap">
        <a href="/search" class="text-[#ea580c] hover:underline text-sm font-medium">← Search more properties</a>
        <button id="clear-compare-btn" class="text-gray-400 hover:text-gray-700 text-sm transition-colors underline">Clear comparison</button>
      </div>
    </div>

    <div id="compare-empty" class="hidden text-center py-20">
      <p class="text-6xl mb-4 opacity-30">📊</p>
      <p class="text-gray-500 text-lg font-medium mb-2">No properties selected to compare</p>
      <p class="text-gray-400 text-sm mb-6">Browse properties and use the compare button to add up to 3</p>
      <a href="/search"
        class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-8 py-3 rounded-xl transition-colors">
        Browse Properties
      </a>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ WP_API }}>
  const params = new URLSearchParams(window.location.search);
  const idsParam = params.get('ids') || '';
  const urlIds = idsParam.split(',').map(Number).filter(Boolean);
  const stored = JSON.parse(localStorage.getItem('compare_list') || '[]');
  const storedIds = stored.map(x => x.id);
  const allIds = [...new Set([...urlIds, ...storedIds])].slice(0, 3);

  const loading = document.getElementById('compare-loading');
  const content = document.getElementById('compare-content');
  const tableDiv = document.getElementById('compare-table');
  const empty = document.getElementById('compare-empty');

  const ROWS = [
    { label: 'Price',         val: p => p.acf?.price ? '₱' + Number(p.acf.price).toLocaleString('en-PH') : 'Price on Request' },
    { label: 'Listing Type',  val: p => p.acf?.listing_type || '—' },
    { label: 'Property Type', val: p => p.acf?.property_type || '—' },
    { label: 'Location',      val: p => [p.acf?.location_city, p.acf?.location_province].filter(Boolean).join(', ') || '—' },
    { label: 'Bedrooms',      val: p => p.acf?.bedrooms || '—' },
    { label: 'Bathrooms',     val: p => p.acf?.bathrooms || '—' },
    { label: 'Floor Area',    val: p => p.acf?.floor_area ? p.acf.floor_area + ' m²' : '—' },
    { label: 'Lot Area',      val: p => p.acf?.lot_area ? p.acf.lot_area + ' m²' : '—' },
    { label: 'Status',        val: p => p.acf?.property_status || 'Available' },
    { label: 'Agent',         val: p => p.acf?.agent_name || '—' },
  ];

  async function loadComparison() {
    if (allIds.length === 0) {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    try {
      const results = await Promise.all(
        allIds.map(id =>
          fetch(`${WP_API}/property/${id}?_embed`)
            .then(r => r.json())
            .catch(() => null)
        )
      );
      const props = results.filter(p => p && !p.code);

      if (props.length === 0) {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }

      const colW = Math.floor(100 / (props.length + 1));

      let html = `<table class="w-full border-collapse text-sm" style="min-width:${360 + props.length * 200}px">`;

      // Photo + title header row
      html += `<thead><tr>
        <th class="p-4 bg-gray-50 border border-gray-200 text-left text-gray-500 font-medium w-32">Property</th>
        ${props.map(p => {
          const img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
          const title = p.title?.rendered || 'Property';
          return `<th class="p-4 bg-white border border-gray-200 text-center font-normal">
            <a href="/property/${p.slug}" class="block hover:opacity-90 transition-opacity">
              <div class="h-36 rounded-xl overflow-hidden bg-gray-100 mb-3">
                ${img ? `<img src="${img}" alt="${title}" class="w-full h-full object-cover"/>` : '<div class="w-full h-full flex items-center justify-center text-4xl opacity-20">🏠</div>'}
              </div>
              <p class="text-gray-900 font-semibold text-sm line-clamp-2 text-left">${title}</p>
              <p class="text-[#ea580c] font-bold text-left mt-1">${p.acf?.price ? '₱' + Number(p.acf.price).toLocaleString('en-PH') : 'Price on Request'}</p>
            </a>
            <a href="/property/${p.slug}" class="mt-2 inline-block w-full text-center bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-2 rounded-lg text-xs transition-colors">View Property</a>
          </th>`;
        }).join('')}
      </tr></thead>`;

      // Data rows
      html += '<tbody>';
      ROWS.forEach((row, i) => {
        const bg = i % 2 === 0 ? 'bg-white' : 'bg-gray-50';
        html += `<tr>
          <td class="p-4 border border-gray-200 ${bg} text-gray-500 font-medium">${row.label}</td>
          ${props.map(p => `<td class="p-4 border border-gray-200 ${bg} text-gray-900 text-center">${row.val(p)}</td>`).join('')}
        </tr>`;
      });
      html += '</tbody></table>';

      tableDiv.innerHTML = html;
      loading.classList.add('hidden');
      content.classList.remove('hidden');
    } catch (e) {
      loading.innerHTML = '<p class="text-gray-400">Failed to load properties. <a href="/search" class="text-[#ea580c] hover:underline">Go back to search</a></p>';
    }
  }

  document.getElementById('clear-compare-btn')?.addEventListener('click', () => {
    localStorage.removeItem('compare_list');
    window.location.href = '/search';
  });

  loadComparison();
</script>
