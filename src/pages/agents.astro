---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';

let agentMap = new Map<string, any>();
try {
  const res = await fetch(`${WP_API}/property?per_page=100&status=publish`);
  const properties = await res.json();
  properties.forEach((p: any) => {
    const name = p.acf?.agent_name?.trim();
    if (!name) return;
    const slug = name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    if (!agentMap.has(slug)) {
      agentMap.set(slug, {
        name,
        slug,
        phone: p.acf?.agent_phone || '',
        email: p.acf?.agent_email || '',
        photo: p.acf?.agent_photo || '',
        count: 0,
        sample: p,
      });
    }
    const entry = agentMap.get(slug);
    entry.count++;
    if (!entry.photo && p.acf?.agent_photo) {
      entry.photo = p.acf.agent_photo;
    }
  });
} catch {}

const agents = Array.from(agentMap.values()).sort((a, b) => b.count - a.count);
---

<Layout title="Our Agents">
  <Navbar />

  <section class="bg-[#ea580c] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3 text-white/70">[Your Brand]</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Our Agents</h1>
      <p class="text-white/80 text-lg">Browse properties by agent and get in touch directly.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    {agents.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {agents.map(agent => (
          <a href={`/agent/${agent.slug}`}
            class="group bg-white border border-gray-100 shadow-sm rounded-2xl p-6 hover:border-[#ea580c]/50 hover:shadow-lg transition-all flex flex-col">
            <div class="flex items-center gap-4 mb-4">
              {agent.photo
                ? <img src={agent.photo} alt={agent.name} class="w-16 h-16 rounded-full object-cover border-2 border-orange-100 shadow-sm shrink-0" />
                : <div class="w-14 h-14 bg-[#ea580c] rounded-2xl flex items-center justify-center text-white text-2xl font-bold shrink-0">
                    {agent.name[0].toUpperCase()}
                  </div>
              }
              <div class="min-w-0">
                <p class="font-bold text-gray-900 text-lg leading-tight group-hover:text-[#ea580c] transition-colors">{agent.name}</p>
                <p class="text-gray-400 text-xs mt-0.5">Licensed Agent</p>
              </div>
            </div>
            <div class="space-y-2 text-sm flex-1">
              {agent.phone && (
                <p class="text-gray-500 flex items-center gap-2">
                  <span class="text-base">📞</span> {agent.phone}
                </p>
              )}
              {agent.email && (
                <p class="text-gray-500 flex items-center gap-2 truncate">
                  <span class="text-base">✉️</span> <span class="truncate">{agent.email}</span>
                </p>
              )}
            </div>
            <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
              <span class="text-xs text-gray-400">{agent.count} listing{agent.count !== 1 ? 's' : ''}</span>
              <span class="text-xs font-semibold text-[#ea580c] group-hover:underline">View Listings →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-5xl mb-4 opacity-20">👤</p>
        <p class="text-gray-400 text-lg">No agent profiles yet.</p>
        <p class="text-gray-300 text-sm mt-2">Agents appear here once properties with agent info are listed.</p>
      </div>
    )}
  </section>

  <Footer />
</Layout>
