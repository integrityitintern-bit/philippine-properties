---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';

let featured: any[] = [];
try {
  const res = await fetch(`${WP_API}/property?_embed&per_page=3&status=publish`);
  featured = await res.json();
  if (!Array.isArray(featured)) featured = [];
} catch {}
---

<Layout title="Page Not Found">
  <Navbar />

  <section class="py-20 px-4 text-center bg-gray-50">
    <div class="max-w-xl mx-auto">
      <p class="text-8xl font-black text-[#ea580c] leading-none mb-4 opacity-80">404</p>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Page Not Found</h1>
      <p class="text-gray-500 mb-8 text-sm">The page you're looking for doesn't exist or was moved.</p>

      <!-- Search box -->
      <form action="/search" method="GET" class="flex gap-2 max-w-md mx-auto mb-8">
        <input type="text" name="city" placeholder="Search properties by city..."
          class="flex-1 px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900 placeholder-gray-400"
        />
        <button type="submit" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-3 rounded-xl transition-colors text-sm">
          Search
        </button>
      </form>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">← Go Home</a>
        <a href="/search" class="bg-white border border-gray-200 hover:border-[#ea580c] text-gray-700 font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">Browse All</a>
        <a href="/faq" class="bg-white border border-gray-200 hover:border-gray-300 text-gray-500 font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">FAQ</a>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="py-16 max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold text-gray-900 mb-6 text-center">While you're here — Featured Properties</h2>
      <div class="grid sm:grid-cols-3 gap-5">
        {featured.map((p: any) => {
          const acf = p.acf || {};
          const img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
          const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
          const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
          return (
            <a href={`/property/${p.slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-[#ea580c]/40 hover:shadow-md transition-all">
              <div class="h-40 overflow-hidden bg-gray-100">
                {img
                  ? <img src={img} alt={p.title?.rendered} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                  : <div class="w-full h-full flex items-center justify-center text-4xl opacity-20">🏠</div>
                }
              </div>
              <div class="p-4">
                <p class="text-[#ea580c] font-bold text-base">{price}</p>
                <p class="text-gray-800 font-semibold text-sm mt-0.5 line-clamp-1">{p.title?.rendered}</p>
                {city && <p class="text-gray-400 text-xs mt-1">📍 {city}</p>}
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <Footer />
</Layout>
