---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <Navbar />
  <div class="min-h-[70vh] flex items-center justify-center px-4 bg-[#0a0a0a]">
    <div class="text-center max-w-md">
      <p class="text-8xl font-bold text-[#ea580c] mb-4">404</p>
      <h1 class="text-2xl font-bold text-white mb-3">Page Not Found</h1>
      <p class="text-white/50 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          Go to Homepage
        </a>
        <a href="/search" class="border-2 border-white/[0.08] hover:border-[#ea580c] text-white/80 font-semibold px-6 py-3 rounded-xl transition-colors">
          Browse Properties
        </a>
      </div>
    </div>
  </div>
  <Footer />
</Layout>
