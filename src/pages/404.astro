---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <Navbar />

  <section class="min-h-[75vh] flex items-center justify-center text-center px-4 py-16 bg-gray-50">
    <div class="max-w-md mx-auto">
      <p class="text-[120px] font-black text-[#ea580c] leading-none mb-2 opacity-90">404</p>
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">Page Not Found</h1>
      <p class="text-gray-500 mb-8 leading-relaxed">
        The page you're looking for doesn't exist, was removed, or the link is broken.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          ← Go Home
        </a>
        <a href="/search" class="bg-white border border-gray-200 hover:border-[#ea580c] text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors">
          Browse Properties
        </a>
        <a href="/contact" class="bg-white border border-gray-200 hover:border-gray-300 text-gray-500 font-semibold px-6 py-3 rounded-xl transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
