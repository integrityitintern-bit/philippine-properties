---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <Navbar />

  <div class="min-h-[72vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-md w-full">

      <!-- 404 visual -->
      <div class="relative inline-flex items-center justify-center mb-8">
        <span class="text-[9rem] font-black text-gray-100 leading-none select-none tracking-tighter">404</span>
        <span class="absolute text-5xl">🏚</span>
      </div>

      <h1 class="text-2xl font-bold text-gray-900 mb-3">Page Not Found</h1>
      <p class="text-gray-500 mb-8 leading-relaxed">
        This property listing doesn't exist or may have been removed.<br/>
        Let's find you something better.
      </p>

      <!-- Search box -->
      <form action="/search" method="GET" class="flex gap-2 mb-8 max-w-sm mx-auto">
        <input type="text" name="city" placeholder="Search by city or area..."
          class="flex-1 px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-gray-50 text-gray-900 placeholder-gray-400"
        />
        <button type="submit"
          class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-3 rounded-xl transition-colors">
          Go
        </button>
      </form>

      <!-- Quick links -->
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="text-sm text-gray-500 hover:text-[#ea580c] border border-gray-200 hover:border-[#ea580c] px-4 py-2.5 rounded-xl transition-colors">
          🏠 Home
        </a>
        <a href="/search" class="text-sm text-gray-500 hover:text-[#ea580c] border border-gray-200 hover:border-[#ea580c] px-4 py-2.5 rounded-xl transition-colors">
          🔍 Browse Properties
        </a>
        <a href="/saved" class="text-sm text-gray-500 hover:text-[#ea580c] border border-gray-200 hover:border-[#ea580c] px-4 py-2.5 rounded-xl transition-colors">
          ❤️ Saved
        </a>
        <a href="/contact" class="text-sm text-gray-500 hover:text-[#ea580c] border border-gray-200 hover:border-[#ea580c] px-4 py-2.5 rounded-xl transition-colors">
          💬 Contact Us
        </a>
      </div>

    </div>
  </div>

  <Footer />
</Layout>
