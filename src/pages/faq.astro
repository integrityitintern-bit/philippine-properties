---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    category: "Buying a Property",
    items: [
      { q: "Can foreigners buy property in the Philippines?", a: "Foreigners cannot own land in the Philippines, but they can own a condominium unit as long as foreign ownership in the building does not exceed 40%. Foreigners married to Filipino citizens may also own property through their spouse." },
      { q: "What are the typical costs when buying a property?", a: "Expect to pay Documentary Stamp Tax (1.5% of selling price), Transfer Tax (0.5–0.75%), Registration Fee (~0.25%), Notarial Fee, and agent commission (usually 5% paid by the seller). Total buyer costs are typically 2–4% of the property price." },
      { q: "How long does the property transfer process take?", a: "The transfer of title typically takes 2–6 months, depending on the completeness of documents and the processing time at the Registry of Deeds and Bureau of Internal Revenue (BIR)." },
      { q: "What documents do I need to buy a property?", a: "You will need: valid government-issued ID, Tax Identification Number (TIN), proof of income (for bank financing), and the Deed of Absolute Sale. The seller must provide the Original Certificate of Title (OCT) or Transfer Certificate of Title (TCT)." },
      { q: "What is the difference between a TCT and a CCT?", a: "A Transfer Certificate of Title (TCT) is for land or house-and-lot properties. A Condominium Certificate of Title (CCT) is specifically for condominium units. Both are issued by the Registry of Deeds." },
    ]
  },
  {
    category: "Renting a Property",
    items: [
      { q: "What is the standard rental deposit in the Philippines?", a: "The standard is 2 months advance rent plus 2 months security deposit, totaling 4 months upfront. Some landlords may require more. The deposit is refundable at the end of the lease, minus any deductions for damages or unpaid utilities." },
      { q: "Are rental prices negotiable?", a: "Yes, rental prices are often negotiable, especially for longer lease terms (1 year or more) or if you are paying several months in advance. It is always worth asking the landlord or agent." },
      { q: "What does 'semi-furnished' mean?", a: "'Semi-furnished' typically means the unit comes with basic fixtures like air conditioning, closets, and sometimes kitchen cabinets, but without appliances or furniture. 'Fully furnished' includes all furniture and major appliances." },
      { q: "What protection do renters have under Philippine law?", a: "The Rent Control Act (RA 9653) covers residential units with monthly rent of ₱10,000 or below in Metro Manila and ₱5,000 in other areas, limiting rent increases to 7% per year. Higher-priced rentals are not covered." },
    ]
  },
  {
    category: "Financing & Mortgages",
    items: [
      { q: "What banks offer home loans in the Philippines?", a: "Major lenders include BDO, BPI, Metrobank, Security Bank, RCBC, PNB, and Pag-IBIG Fund. Pag-IBIG (HDMF) offers some of the lowest interest rates and is available to all contributing members." },
      { q: "How much can I borrow for a home loan?", a: "Most banks lend up to 80% of the appraised value or selling price (whichever is lower). Loan amounts are also subject to your monthly income — typically your monthly amortization should not exceed 30–40% of your gross monthly income." },
      { q: "What is Pag-IBIG housing loan and who can avail it?", a: "Pag-IBIG (HDMF) offers affordable housing loans to active members who have made at least 24 monthly contributions. Interest rates start at around 5.375% per year for a 1-year fixed term, making it one of the most affordable financing options." },
      { q: "What is the typical interest rate for a home loan?", a: "Bank interest rates in the Philippines typically range from 5.5% to 8% per year for a 1–5 year fixed term. Rates are repriced periodically. Pag-IBIG rates start lower but may also be repriced." },
    ]
  },
  {
    category: "Listing Your Property",
    items: [
      { q: "Is it free to list a property on this site?", a: "Yes, listing your property on Philippine Properties is completely free. Simply click '+ List Property' in the navigation menu and fill out the form. Your listing will appear after review." },
      { q: "How long will my listing stay active?", a: "Listings remain active until you mark the property as sold, reserved, or remove it yourself. We recommend keeping your listing updated to attract serious buyers." },
      { q: "What photos should I include?", a: "Include at least 5 clear, well-lit photos: main facade, living room, bedrooms, kitchen, bathroom, and surrounding area. High-quality photos significantly increase inquiries. Avoid clutter and ensure good lighting." },
    ]
  },
];
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(s => s.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  })))
};
---

<Layout title="Frequently Asked Questions — Philippine Real Estate">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
  <Navbar />

  <section class="bg-[#ea580c] text-white py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Frequently Asked Questions</h1>
      <p class="text-white/80">Everything you need to know about buying, renting, and listing property in the Philippines.</p>
    </div>
  </section>

  <section class="py-16 max-w-3xl mx-auto px-4">
    {faqs.map(section => (
      <div class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-5 pb-3 border-b border-gray-100">{section.category}</h2>
        <div class="space-y-4">
          {section.items.map((item, i) => (
            <details class="group bg-white border border-gray-100 shadow-sm rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none select-none hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900 text-sm">{item.q}</span>
                <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-5 pt-1 text-gray-600 text-sm leading-relaxed border-t border-gray-50">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}

    <div class="bg-orange-50 border border-orange-100 rounded-2xl p-8 text-center mt-8">
      <h3 class="font-bold text-gray-900 mb-2">Still have questions?</h3>
      <p class="text-gray-500 text-sm mb-5">Our team is happy to help you find the right property or answer any questions.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/contact" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">Contact Us</a>
        <a href="/search" class="bg-white border border-gray-200 hover:border-[#ea580c] text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors text-sm">Browse Properties</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
