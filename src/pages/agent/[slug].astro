---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { WP_API } from '../../config.js';

export async function getStaticPaths() {
  try {
    const res = await fetch(`${WP_API}/property?_embed&per_page=100&status=publish`);
    const properties = await res.json();

    const agentMap = new Map<string, any>();
    properties.forEach((p: any) => {
      const name = p.acf?.agent_name?.trim();
      if (!name) return;
      const slug = name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
      if (!agentMap.has(slug)) {
        agentMap.set(slug, { name, slug, phone: p.acf?.agent_phone || '', email: p.acf?.agent_email || '', listings: [] });
      }
      agentMap.get(slug).listings.push(p);
    });

    return Array.from(agentMap.values()).map(agent => ({
      params: { slug: agent.slug },
      props: { agent },
    }));
  } catch {
    return [];
  }
}

const { agent } = Astro.props;
const whatsappPhone = agent.phone ? agent.phone.replace(/\D/g, '').replace(/^0/, '63') : '';
---

<Layout title={`${agent.name} — Properties`} description={`Browse ${agent.listings.length} properties listed by ${agent.name} on Integrity Real Estate.`}>
  <Navbar />

  <!-- Agent Header -->
  <section class="bg-[#0f0f0f] border-b border-white/[0.06] py-12">
    <div class="max-w-5xl mx-auto px-4">
      <a href="/agents" class="text-xs text-white/40 hover:text-[#ea580c] transition-colors mb-6 inline-flex items-center gap-1">
        ← All Agents
      </a>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mt-4">
        <div class="w-20 h-20 bg-[#ea580c] rounded-3xl flex items-center justify-center text-white text-3xl font-bold shrink-0 shadow-xl shadow-orange-900/30">
          {agent.name[0].toUpperCase()}
        </div>
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl md:text-3xl font-bold text-white">{agent.name}</h1>
          <p class="text-white/40 text-sm mt-1">Integrity Real Estate Agent · {agent.listings.length} listing{agent.listings.length !== 1 ? 's' : ''}</p>
          <div class="flex flex-wrap gap-3 mt-4">
            {agent.phone && (
              <a href={`tel:${agent.phone}`}
                class="inline-flex items-center gap-2 bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors">
                📞 {agent.phone}
              </a>
            )}
            {whatsappPhone && (
              <a href={`https://wa.me/${whatsappPhone}`} target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1da850] text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            )}
            {agent.email && (
              <a href={`mailto:${agent.email}`}
                class="inline-flex items-center gap-2 bg-[#1a1a1a] hover:bg-[#222222] text-white/80 font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors border border-white/[0.08]">
                ✉️ {agent.email}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Listings -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold text-white mb-6">
      Properties by {agent.name}
      <span class="text-white/30 font-normal text-base ml-2">({agent.listings.length})</span>
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {agent.listings.map((p: any) => {
        const acf = p.acf || {};
        const img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
        const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
        const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
        const badge = acf.listing_type === 'For Rent' ? 'bg-blue-500/90' : acf.listing_type === 'Pre-Selling' ? 'bg-purple-500/90' : 'bg-[#ea580c]';
        const isNew = (Date.now() - new Date(p.date).getTime()) < 7 * 24 * 60 * 60 * 1000;
        return (
          <a href={`/property/${p.slug}`}
            class="group bg-[#141414] rounded-2xl overflow-hidden border border-white/[0.07] hover:border-[#ea580c]/40 hover:shadow-xl hover:shadow-[#ea580c]/5 transition-all flex flex-col card-enter">
            <div class="relative h-48 overflow-hidden bg-[#1a1a1a]">
              {img
                ? <img src={img} alt={p.title?.rendered} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                : <div class="w-full h-full flex items-center justify-center text-5xl opacity-20">🏠</div>
              }
              <div class="absolute top-3 left-3 flex flex-col gap-1.5">
                {acf.listing_type && (
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full text-white backdrop-blur-sm ${badge} w-fit`}>
                    {acf.listing_type}
                  </span>
                )}
                {isNew && (
                  <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-green-500 text-white backdrop-blur-sm uppercase tracking-wider w-fit">
                    New
                  </span>
                )}
              </div>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <p class="text-[#f97316] font-bold text-lg mb-1">{price}</p>
              <h3 class="text-white font-semibold text-sm leading-snug mb-2 line-clamp-2">{p.title?.rendered}</h3>
              {city && <p class="text-white/40 text-xs mb-3">📍 {city}</p>}
              <div class="flex items-center gap-3 text-white/40 text-xs mt-auto pt-3 border-t border-white/[0.06]">
                {acf.bedrooms && <span>🛏 {acf.bedrooms}</span>}
                {acf.bathrooms && <span>🚿 {acf.bathrooms}</span>}
                {acf.floor_area && <span>📐 {acf.floor_area}m²</span>}
                {acf.property_type && (
                  <span class="ml-auto capitalize text-[10px] bg-white/[0.06] text-white/50 px-2 py-0.5 rounded-full">{acf.property_type}</span>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <Footer />
</Layout>
