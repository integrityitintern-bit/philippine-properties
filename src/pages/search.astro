---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';
---

<Layout title="Search Properties">
  <Navbar />

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Search Properties</h1>
      <p class="text-gray-500 text-sm mt-1">Find your perfect home, condo, or investment property</p>
    </div>

    <!-- Filters -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-4 mb-8 space-y-3">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        <input id="filter-city" type="text" placeholder="City or Area" list="city-suggestions" autocomplete="off"
          class="col-span-2 sm:col-span-1 px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-gray-50 text-gray-900 placeholder-gray-400"
        />
        <datalist id="city-suggestions"></datalist>
        <select id="filter-listing-type" class="px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
          <option value="">All Types</option>
          <option value="For Sale">For Sale</option>
          <option value="For Rent">For Rent</option>
          <option value="Pre-Selling">Pre-Selling</option>
        </select>
        <select id="filter-property-type" class="px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
          <option value="">All Properties</option>
          <option value="House & Lot">House &amp; Lot</option>
          <option value="Condo">Condo</option>
          <option value="Condominium">Condominium</option>
          <option value="Townhouse">Townhouse</option>
          <option value="Apartment">Apartment</option>
          <option value="Studio">Studio</option>
          <option value="Land & Lot">Land &amp; Lot</option>
          <option value="Lot Only">Lot Only</option>
          <option value="Commercial">Commercial</option>
          <option value="Warehouse">Warehouse</option>
        </select>
        <select id="filter-bedrooms" class="px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
          <option value="">Any Beds</option>
          <option value="1">1+ Bed</option>
          <option value="2">2+ Beds</option>
          <option value="3">3+ Beds</option>
          <option value="4">4+ Beds</option>
        </select>
        <button id="filter-btn" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-2.5 px-6 rounded-xl transition-colors text-sm">
          Search
        </button>
      </div>
      <div class="flex flex-wrap items-center gap-3 pt-1">
        <span class="text-xs font-medium text-gray-500">Price Range:</span>
        <select id="filter-price-min" class="px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
          <option value="">No Min</option>
          <option value="500000">₱500K</option>
          <option value="1000000">₱1M</option>
          <option value="2000000">₱2M</option>
          <option value="5000000">₱5M</option>
          <option value="10000000">₱10M</option>
          <option value="20000000">₱20M</option>
        </select>
        <span class="text-gray-400 text-sm">–</span>
        <select id="filter-price-max" class="px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
          <option value="">No Max</option>
          <option value="1000000">₱1M</option>
          <option value="2000000">₱2M</option>
          <option value="5000000">₱5M</option>
          <option value="10000000">₱10M</option>
          <option value="20000000">₱20M</option>
          <option value="50000000">₱50M</option>
        </select>
        <div class="flex items-center gap-3 ml-auto">
          <button id="save-search-btn" class="text-xs font-semibold text-[#ea580c] hover:underline">💾 Save Search</button>
          <button id="clear-filters" class="text-xs text-gray-400 hover:text-[#ea580c] transition-colors underline">Clear all</button>
        </div>
      </div>
      <div id="saved-searches-bar" class="hidden flex items-center flex-wrap gap-2 pt-2 border-t border-gray-100">
        <span class="text-xs font-medium text-gray-400 shrink-0">Saved searches:</span>
        <div id="saved-searches-list" class="flex flex-wrap gap-1.5"></div>
      </div>
    </div>

    <!-- Quick filter chips -->
    <div class="flex flex-wrap gap-2 mb-4">
      <button id="chip-new-week" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors">🆕 New This Week</button>
      <button id="chip-for-sale" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors">🏠 For Sale</button>
      <button id="chip-for-rent" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors">🔑 For Rent</button>
      <button id="chip-pre-selling" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors">🏗 Pre-Selling</button>
    </div>

    <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
      <p id="results-count" class="text-sm text-gray-500"></p>
      <div class="flex items-center gap-2 ml-auto">
        <button id="view-grid" title="Grid view"
          class="w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-[#ea580c] text-white border-[#ea580c]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
        </button>
        <button id="view-map" title="Map view"
          class="w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-white text-gray-600 border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </button>
      </div>
      <div class="flex items-center rounded-xl overflow-hidden border border-gray-200 text-xs font-bold shrink-0">
        <button id="cur-php" class="px-3 py-2 bg-[#ea580c] text-white transition-colors">₱</button>
        <button id="cur-usd" class="px-3 py-2 bg-white text-gray-500 hover:bg-gray-50 transition-colors">$</button>
        <button id="cur-sgd" class="px-3 py-2 bg-white text-gray-500 hover:bg-gray-50 transition-colors">S$</button>
      </div>
      <select id="sort-select" class="px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white text-gray-900">
        <option value="newest">Newest First</option>
        <option value="price_asc">Price: Low → High</option>
        <option value="price_desc">Price: High → Low</option>
      </select>
    </div>

    <!-- Loading Skeletons -->
    <div id="loading-skeleton" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {Array(6).fill(0).map(() => (
        <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100">
          <div class="skeleton h-48 bg-gray-100"></div>
          <div class="p-4 space-y-3">
            <div class="skeleton h-5 bg-gray-100 rounded w-1/2"></div>
            <div class="skeleton h-4 bg-gray-100 rounded w-3/4"></div>
            <div class="skeleton h-3 bg-gray-100 rounded w-1/3"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Property Grid -->
    <div id="property-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <div class="relative">
      <div id="map-view" class="hidden rounded-2xl overflow-hidden border border-gray-200 shadow-sm" style="height: 540px;"></div>
      <button id="search-area-btn" class="hidden absolute top-3 left-1/2 -translate-x-1/2 z-[1000] bg-white border border-gray-200 shadow-lg rounded-full px-4 py-2 text-sm font-semibold text-gray-800 hover:bg-orange-50 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors whitespace-nowrap">
        🔍 Search this area
      </button>
    </div>

    <!-- No Results -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-5xl mb-4">🏠</p>
      <p class="text-gray-500 text-lg font-medium">No properties found</p>
      <p class="text-gray-400 text-sm mt-1">Try adjusting your filters</p>
      <a href="/list-property" class="mt-6 inline-block bg-[#ea580c] text-white px-6 py-3 rounded-xl font-semibold hover:bg-[#c2410c] transition-colors">
        + List a Property
      </a>
    </div>

    <div class="text-center mt-10">
      <button id="load-more-btn" class="hidden bg-white border-2 border-[#ea580c] text-[#ea580c] font-semibold px-8 py-3 rounded-xl hover:bg-[#ea580c] hover:text-white transition-colors">
        Load More Properties
      </button>
    </div>

    <!-- Property Alerts Banner -->
    <div id="alerts-banner" class="mt-12 rounded-2xl bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-100 p-6 md:p-8 text-center">
      <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">Never Miss a Deal</p>
      <h3 class="text-xl font-bold text-gray-900 mb-1" style="font-family:'Playfair Display',serif;">Get Notified of New Listings</h3>
      <p class="text-gray-400 text-sm mb-6">We'll email you when properties matching your search are added.</p>
      <form id="alerts-form" action="https://formsubmit.co/info@philippine-properties.com" method="POST"
            class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="_subject" value="Property Alert Signup" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" id="alerts-filters" name="filters" value="" />
        <input type="email" name="email" required placeholder="your@email.com"
               class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-[#ea580c] focus:ring-1 focus:ring-[#ea580c]/30" />
        <button type="submit"
                class="px-5 py-2.5 bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold text-sm rounded-xl transition-colors whitespace-nowrap">
          Notify Me
        </button>
      </form>
      <p id="alerts-success" class="hidden mt-4 text-sm text-green-600 font-medium">✓ You're on the list! We'll notify you of new matches.</p>
    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>

  <div id="compare-bar" class="hidden fixed bottom-0 inset-x-0 z-40 bg-white border-t border-gray-200 shadow-2xl px-4 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-3">
        <span class="text-sm font-semibold text-gray-900">Compare <span id="compare-count">0</span>/3</span>
        <div id="compare-slots" class="flex gap-2 items-center"></div>
      </div>
      <div class="flex gap-3 shrink-0 items-center">
        <button id="compare-clear" class="text-sm text-gray-400 hover:text-gray-700 transition-colors px-3 py-2">Clear all</button>
        <a id="compare-go-btn" href="/compare"
          class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition-colors">
          Compare Now →
        </a>
      </div>
    </div>
  </div>

  <!-- Quick View Modal -->
  <div id="qv-modal" class="hidden fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white rounded-t-3xl sm:rounded-2xl max-w-lg w-full shadow-2xl overflow-hidden">
      <div id="qv-img" class="h-52 bg-gray-100 overflow-hidden relative">
        <button onclick="document.getElementById('qv-modal').classList.add('hidden')"
          class="absolute top-3 right-3 w-8 h-8 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center z-10 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-5">
        <p id="qv-price" class="text-2xl font-bold text-[#ea580c] mb-1"></p>
        <h3 id="qv-title" class="font-bold text-gray-900 text-base mb-1 line-clamp-2"></h3>
        <p id="qv-location" class="text-gray-400 text-sm mb-3"></p>
        <div id="qv-specs" class="flex flex-wrap gap-3 text-sm text-gray-500 mb-5 pb-4 border-b border-gray-100"></div>
        <div class="flex gap-3">
          <a id="qv-link" href="#" class="flex-1 bg-[#ea580c] hover:bg-[#c2410c] text-white text-center font-semibold py-3 rounded-xl transition-colors text-sm">
            View Full Listing →
          </a>
          <a id="qv-wa" href="#" target="_blank" rel="noopener" class="w-12 h-12 bg-[#25D366] hover:bg-[#1da850] rounded-xl flex items-center justify-center shrink-0 transition-colors hidden">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ WP_API }}>
  const ITEMS_PER_PAGE = 12;
  let currentPage = 1;
  let allProperties = [];
  let filteredProperties = [];

  // Currency toggle
  let activeCurrency = (localStorage.getItem('pp_currency') || 'PHP') as 'PHP' | 'USD';
  const RATES: Record<string, number> = { PHP: 1, USD: 1/56, SGD: 1/42 };
  const SYMBOLS: Record<string, string> = { PHP: '₱', USD: '$', SGD: 'S$' };
  function formatPrice(phpAmount: string | number) {
    if (!phpAmount) return 'Price on Request';
    const val = Math.round(Number(phpAmount) * RATES[activeCurrency]);
    return SYMBOLS[activeCurrency] + val.toLocaleString('en-PH');
  }
  window.addEventListener('pp:currency', (e: Event) => {
    activeCurrency = (e as CustomEvent).detail;
    renderProperties();
  });

  // Map area filter
  let mapBoundsActive = false;

  const grid = document.getElementById('property-grid');
  const skeleton = document.getElementById('loading-skeleton');
  const noResults = document.getElementById('no-results');
  const resultsCount = document.getElementById('results-count');
  const loadMoreBtn = document.getElementById('load-more-btn');

  // Pre-fill filters from URL params
  const params = new URLSearchParams(window.location.search);
  if (params.get('city')) document.getElementById('filter-city').value = params.get('city');
  if (params.get('listing_type')) document.getElementById('filter-listing-type').value = params.get('listing_type');
  if (params.get('property_type')) document.getElementById('filter-property-type').value = params.get('property_type');

  async function fetchProperties() {
    try {
      const res = await fetch(`${WP_API}/property?_embed&per_page=100&status=publish`);
      allProperties = await res.json();
      // Build city autocomplete
      const cities = [...new Set(allProperties.map(p => p.acf?.location_city).filter(Boolean))].sort();
      const datalist = document.getElementById('city-suggestions');
      if (datalist) datalist.innerHTML = cities.map(c => `<option value="${c}">`).join('');
      applyFilters();
    } catch (err) {
      skeleton.classList.add('hidden');
      noResults.classList.remove('hidden');
    }
  }

  function applyFilters() {
    const city = document.getElementById('filter-city').value.trim().toLowerCase();
    const listingType = document.getElementById('filter-listing-type').value;
    const propertyType = document.getElementById('filter-property-type').value;
    const minBeds = parseInt(document.getElementById('filter-bedrooms').value) || 0;
    const priceMin = parseInt(document.getElementById('filter-price-min').value) || 0;
    const priceMax = parseInt(document.getElementById('filter-price-max').value) || Infinity;

    // Apply active quick-filter chip
    const chipFn = activeChip ? chipConfig[activeChip] : null;

    filteredProperties = allProperties.filter(p => {
      const acf = p.acf || {};
      const price = parseFloat(acf.price) || 0;
      if (city && !acf.location_city?.toLowerCase().includes(city)) return false;
      if (listingType && acf.listing_type !== listingType) return false;
      if (propertyType && (acf.property_type || '').toLowerCase() !== propertyType.toLowerCase()) return false;
      if (minBeds && (parseInt(acf.bedrooms) || 0) < minBeds) return false;
      if (priceMin && price < priceMin) return false;
      if (priceMax !== Infinity && price > priceMax) return false;
      if (chipFn && !chipFn(p)) return false;
      return true;
    });

    const sort = document.getElementById('sort-select').value;
    if (sort === 'price_asc') filteredProperties.sort((a, b) => (parseFloat(a.acf?.price) || 0) - (parseFloat(b.acf?.price) || 0));
    else if (sort === 'price_desc') filteredProperties.sort((a, b) => (parseFloat(b.acf?.price) || 0) - (parseFloat(a.acf?.price) || 0));
    else filteredProperties.sort((a, b) => new Date(b.date) - new Date(a.date));

    currentPage = 1;
    renderProperties();
  }

  const getSaved = () => JSON.parse(localStorage.getItem('saved_properties') || '[]');

  // ── Map logic ──────────────────────────────────────────────────────────────
  const CITY_COORDS = {
    'manila': [14.5995, 120.9842], 'makati': [14.5547, 121.0244],
    'quezon city': [14.6760, 121.0437], 'taguig': [14.5176, 121.0509],
    'pasig': [14.5764, 121.0851], 'mandaluyong': [14.5794, 121.0359],
    'paranaque': [14.4793, 121.0198], 'parañaque': [14.4793, 121.0198],
    'las pinas': [14.4497, 120.9834], 'las piñas': [14.4497, 120.9834],
    'muntinlupa': [14.4081, 121.0415], 'caloocan': [14.6490, 120.9673],
    'malabon': [14.6628, 120.9571], 'navotas': [14.6670, 120.9417],
    'valenzuela': [14.7011, 120.9830], 'marikina': [14.6507, 121.1029],
    'san juan': [14.6019, 121.0355], 'pasay': [14.5378, 120.9931],
    'cebu city': [10.3157, 123.8854], 'cebu': [10.3157, 123.8854],
    'davao': [7.1907, 125.4553], 'davao city': [7.1907, 125.4553],
    'cagayan de oro': [8.4542, 124.6319], 'iloilo': [10.7202, 122.5621],
    'bacolod': [10.6713, 122.9511], 'antipolo': [14.5860, 121.1763],
    'bacoor': [14.4580, 120.9345], 'imus': [14.4297, 120.9367],
    'santa rosa': [14.3122, 121.1114], 'sta. rosa': [14.3122, 121.1114],
    'tagaytay': [14.1153, 120.9621], 'baguio': [16.4023, 120.5960],
    'angeles': [15.1450, 120.5887], 'san fernando': [15.0302, 120.6899],
    'olongapo': [14.8295, 120.2826], 'batangas': [13.7565, 121.0583],
    'lipa': [13.9411, 121.1636], 'lucena': [13.9373, 121.6170],
    'naga': [13.6192, 123.1814], 'tacloban': [11.2543, 125.0000],
    'dumaguete': [9.3068, 123.3054], 'zamboanga': [6.9214, 122.0790],
    'general santos': [6.1164, 125.1716], 'butuan': [8.9475, 125.5406],
    'puerto princesa': [9.7392, 118.7353],
  };

  let leafletMap = null;
  let isMapView = false;

  function initOrUpdateMap() {
    const mapDiv = document.getElementById('map-view');
    if (!mapDiv) return;

    if (!leafletMap) {
      leafletMap = L.map('map-view').setView([12.8797, 121.7740], 6);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 18,
      }).addTo(leafletMap);
    }

    // Clear existing markers
    leafletMap.eachLayer(layer => {
      if (layer instanceof L.Marker) leafletMap.removeLayer(layer);
    });

    const propsWithCoords = filteredProperties.filter(p => {
      const city = (p.acf?.location_city || '').toLowerCase().trim();
      return CITY_COORDS[city];
    });

    const bounds = [];
    propsWithCoords.slice(0, 100).forEach(p => {
      const city = (p.acf?.location_city || '').toLowerCase().trim();
      const coords = CITY_COORDS[city];
      if (!coords) return;

      const pr = p.acf?.price ? '₱' + Number(p.acf.price).toLocaleString('en-PH') : 'Price on Request';
      const img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';

      const icon = L.divIcon({
        html: '<div style="background:#ea580c;color:white;border-radius:50% 50% 50% 0;width:28px;height:28px;transform:rotate(-45deg);border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);"></div>',
        iconSize: [28, 28],
        iconAnchor: [14, 28],
        className: '',
      });

      const marker = L.marker(coords, { icon }).addTo(leafletMap);
      const popupHtml = `
        <div style="min-width:180px;font-family:system-ui,sans-serif">
          ${img ? `<img src="${img}" style="width:100%;height:90px;object-fit:cover;border-radius:6px;margin-bottom:8px;" loading="lazy"/>` : ''}
          <p style="color:#ea580c;font-weight:700;font-size:13px;margin:0 0 3px">${pr}</p>
          <p style="color:#111;font-size:12px;margin:0 0 6px;font-weight:600;line-height:1.3">${p.title?.rendered || 'Property'}</p>
          <a href="/property/${p.slug}" style="display:inline-block;background:#ea580c;color:white;text-decoration:none;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;">View →</a>
        </div>`;
      marker.bindPopup(popupHtml, { maxWidth: 220 });
      bounds.push(coords);
    });

    if (bounds.length > 0) {
      leafletMap.fitBounds(bounds, { padding: [40, 40], maxZoom: 13 });
    }

    // Invalidate size after showing (fixes rendering bug with hidden divs)
    setTimeout(() => leafletMap.invalidateSize(), 100);

    // Show "Search this area" when map is panned/zoomed
    leafletMap.on('moveend', () => {
      if (!mapBoundsActive && searchAreaBtn) {
        const bounds = leafletMap.getBounds();
        const count = filteredProperties.filter(p => {
          const city = (p.acf?.location_city || '').toLowerCase().trim();
          const coords = CITY_COORDS[city];
          return coords && bounds.contains(coords);
        }).length;
        searchAreaBtn.textContent = `🔍 Search this area (${count})`;
        searchAreaBtn.classList.remove('hidden');
      }
    });
  }

  // ── Compare logic ──────────────────────────────────────────────────────────
  const getCompare = () => JSON.parse(localStorage.getItem('compare_list') || '[]');

  function toggleCompare(item) {
    let list = getCompare();
    const idx = list.findIndex(x => x.id === item.id);
    if (idx >= 0) {
      list.splice(idx, 1);
    } else {
      if (list.length >= 3) {
        alert('You can compare up to 3 properties at a time. Remove one first.');
        return;
      }
      list.push(item);
    }
    localStorage.setItem('compare_list', JSON.stringify(list));
    updateCompareBar();
    updateCompareButtons();
  }

  function updateCompareBar() {
    const list = getCompare();
    const bar = document.getElementById('compare-bar');
    const count = document.getElementById('compare-count');
    const slots = document.getElementById('compare-slots');
    const goBtn = document.getElementById('compare-go-btn');
    if (!bar) return;

    bar.classList.toggle('hidden', list.length === 0);
    if (count) count.textContent = list.length;

    if (slots) {
      slots.innerHTML = list.map(item => `
        <div class="relative group">
          <div class="w-12 h-12 rounded-lg overflow-hidden bg-gray-100 border border-gray-200">
            ${item.image ? `<img src="${item.image}" class="w-full h-full object-cover" loading="lazy"/>` : '<div class="w-full h-full flex items-center justify-center text-lg opacity-30">🏠</div>'}
          </div>
          <button onclick="removeFromCompare(${item.id})" class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-red-500 text-white rounded-full text-xs flex items-center justify-center leading-none hover:bg-red-600 transition-colors">&times;</button>
        </div>
      `).join('');
    }

    if (goBtn) goBtn.href = `/compare?ids=${list.map(x => x.id).join(',')}`;
  }

  window.removeFromCompare = function(id) {
    let list = getCompare();
    list = list.filter(x => x.id !== id);
    localStorage.setItem('compare_list', JSON.stringify(list));
    updateCompareBar();
    updateCompareButtons();
  };

  function updateCompareButtons() {
    const list = getCompare();
    document.querySelectorAll('.compare-btn').forEach(btn => {
      const id = Number(btn.dataset.id);
      const inList = list.some(x => x.id === id);
      const svg = btn.querySelector('svg');
      if (svg) svg.setAttribute('stroke', inList ? '#ea580c' : 'currentColor');
    });
  }

  function bindCompareButtons() {
    document.querySelectorAll('.compare-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        e.stopPropagation();
        toggleCompare({
          id: Number(btn.dataset.id),
          slug: btn.dataset.slug,
          title: btn.dataset.title,
          price: btn.dataset.price,
          image: btn.dataset.image,
        });
      });
    });
  }

  function cdnImg(url, w) {
    if (!url || url.startsWith('data:')) return url;
    return 'https://wsrv.nl/?url=' + encodeURIComponent(url) + '&w=' + (w || 600) + '&q=82&output=webp';
  }

  function cardHTML(p) {
    const acf = p.acf || {};
    const title = p.title?.rendered || 'Property';
    const image = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
    const price = formatPrice(acf.price);
    const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
    const badge = acf.listing_type === 'For Rent' ? 'bg-blue-500/90' : acf.listing_type === 'Pre-Selling' ? 'bg-purple-500/90' : 'bg-[#ea580c]';
    const isNew = (Date.now() - new Date(p.date).getTime()) < 7 * 24 * 60 * 60 * 1000;
    const isSavedProp = getSaved().includes(p.id);
    const heartFill = isSavedProp ? '#ea580c' : 'none';
    const heartStroke = isSavedProp ? '#ea580c' : 'currentColor';
    const inCompare = getCompare().some(x => x.id === p.id);
    const compareBtnColor = inCompare ? '#ea580c' : 'currentColor';

    // Open house / status badges
    const ohRaw = acf.open_house_date ? String(acf.open_house_date).replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3') : '';
    const ohDate = ohRaw ? new Date(ohRaw) : null;
    const todayMid = new Date(); todayMid.setHours(0,0,0,0);
    const ohBadge = ohDate && ohDate >= todayMid
      ? `<span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-600 text-white backdrop-blur-sm uppercase tracking-wider">Open ${ohDate.toLocaleDateString('en-PH', {month:'short',day:'numeric'})}</span>`
      : '';
    const isSoldStatus = acf.property_status === 'Sold' || acf.property_status === 'Reserved';
    const statusBadge = isSoldStatus
      ? `<span class="text-[10px] font-bold px-2.5 py-1 rounded-full ${acf.property_status === 'Sold' ? 'bg-red-500' : 'bg-yellow-500'} text-white backdrop-blur-sm uppercase tracking-wider">${acf.property_status}</span>`
      : (isNew ? `<span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-green-500 text-white backdrop-blur-sm uppercase tracking-wider">New</span>` : '') + ohBadge;

    // Photo count
    const photoCount = [image, acf.photo_2, acf.photo_3, acf.photo_4, acf.photo_5,
      acf.photo_6, acf.photo_7, acf.photo_8, acf.photo_9, acf.photo_10].filter(Boolean).length;

    // Amenities
    const amenitySources = [acf.amenities, acf.features, acf.property_features].filter(Boolean);
    const amenityStr = amenitySources.map(s => Array.isArray(s) ? s.join(' ') : String(s)).join(' ').toLowerCase();
    const hasPool    = /pool|swim/.test(amenityStr)            || !!(acf.swimming_pool || acf.has_pool);
    const hasGym     = /gym|fitness/.test(amenityStr)          || !!(acf.gym || acf.has_gym);
    const hasParking = /parking|garage|carport/.test(amenityStr) || !!(acf.parking || acf.garage || acf.has_parking);
    const hasBalcony = /balcony|terrace/.test(amenityStr)      || !!(acf.balcony);

    const detailItems = [
      acf.bedrooms  ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 12V8.5A1.5 1.5 0 014.5 7H8m-5 5v4m18-4v4M8 7h8a1 1 0 011 1v4H7V8a1 1 0 011-1z"/></svg><span class="font-semibold text-gray-700">${acf.bedrooms}</span></span>` : '',
      acf.bathrooms ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M4 12a2 2 0 01-2-2V8.5A1.5 1.5 0 013.5 7H6m-4 5v4a2 2 0 002 2h12a2 2 0 002-2v-4"/></svg><span class="font-semibold text-gray-700">${acf.bathrooms}</span></span>` : '',
      acf.floor_area ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg><span class="font-semibold text-gray-700">${acf.floor_area}</span><span class="text-gray-400">m²</span></span>` : '',
      hasPool    ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17c1.5-1 3-1 4.5 0s3 1 4.5 0 3-1 4.5 0 3 1 4.5 0"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 0a4 4 0 014 4H8a4 4 0 014-4z"/></svg><span class="text-blue-500 font-semibold">Pool</span></span>` : '',
      hasGym     ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 8v8M18 8v8M3 10v4M21 10v4M9 12h6"/></svg><span class="font-semibold">Gym</span></span>` : '',
      hasParking ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 17H3a2 2 0 01-2-2v-4l2.5-5h13l2.5 5v4a2 2 0 01-2 2h-2m-9 0a1.5 1.5 0 103 0m6 0a1.5 1.5 0 103 0"/></svg><span class="font-semibold">Parking</span></span>` : '',
      hasBalcony ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 10v8h18v-8M8 10V6m4 4V6m4 4V6"/></svg><span class="font-semibold">Balcony</span></span>` : '',
    ].filter(Boolean).join('');

    // Agent
    const agentName  = acf.agent_name || '';
    const agentPhoto = typeof acf.agent_photo === 'string' ? acf.agent_photo : '';
    const agentInitial = agentName ? agentName.trim()[0].toUpperCase() : '';
    const agentAvatar = agentPhoto
      ? `<img src="${agentPhoto}" alt="${agentName}" class="w-8 h-8 rounded-full object-cover border border-gray-200 shrink-0" loading="lazy"/>`
      : agentName
        ? `<div class="w-8 h-8 rounded-full bg-[#ea580c] flex items-center justify-center text-white text-xs font-bold shrink-0">${agentInitial}</div>`
        : `<div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0"><svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-5.33 0-8 2.67-8 4v1h16v-1c0-1.33-2.67-4-8-4z"/></svg></div>`;
    const agentLabel = agentName || 'Philippine Real Estate Properties';
    const propTypeBadge = acf.property_type ? `<span class="ml-auto text-[10px] bg-gray-100 text-gray-400 px-2 py-0.5 rounded-full capitalize shrink-0">${acf.property_type}</span>` : '';

    return `
      <a href="/property/${p.slug}" class="group bg-white rounded-2xl shadow-sm hover:shadow-md hover:border-[#ea580c]/40 transition-all overflow-hidden border border-gray-200 flex flex-col card-enter">
        <div class="relative h-48 overflow-hidden bg-gray-100">
          ${image ? `<img src="${cdnImg(image)}" alt="${title.replace(/"/g,'&quot;')}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>` : '<div class="w-full h-full flex items-center justify-center text-5xl opacity-20">🏠</div>'}
          <div class="absolute top-3 left-3 flex flex-col gap-1.5">
            ${acf.listing_type ? `<span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white backdrop-blur-sm ${badge}">${acf.listing_type}</span>` : ''}
            ${statusBadge}
          </div>
          <div class="absolute top-3 right-3 flex flex-col gap-1.5">
            <button class="compare-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors"
              data-id="${p.id}" data-slug="${p.slug}" data-title="${title.replace(/"/g,'&quot;')}" data-price="${price}" data-image="${cdnImg(image, 200)}"
              title="Add to compare" aria-label="Compare">
              <svg class="w-3.5 h-3.5" fill="none" stroke="${compareBtnColor}" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </button>
            <button class="save-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors" data-id="${p.id}" aria-label="Save property">
              <svg class="save-icon w-3.5 h-3.5" fill="${heartFill}" stroke="${heartStroke}" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </button>
          </div>
          ${photoCount > 0 ? `<div class="absolute bottom-2 left-2 flex items-center gap-1 bg-black/55 backdrop-blur-sm text-white text-[10px] font-semibold px-2 py-1 rounded-lg pointer-events-none"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>${photoCount}</div>` : ''}
          <button class="qv-btn absolute bottom-2 right-2 bg-white/90 backdrop-blur-sm text-gray-600 hover:text-[#ea580c] text-xs font-semibold px-3 py-1.5 rounded-full shadow flex items-center gap-1.5 transition-colors opacity-0 group-hover:opacity-100"
            data-prop='${JSON.stringify({id:p.id,slug:p.slug,title,price,image,city,bedrooms:acf.bedrooms,bathrooms:acf.bathrooms,floor_area:acf.floor_area,agent_phone:acf.agent_phone}).replace(/'/g,"&#39;")}'>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            Quick View
          </button>
        </div>
        <div class="p-4 flex flex-col flex-1">
          <p class="text-[#f97316] font-bold text-lg leading-tight mb-1">${price}</p>
          <h3 class="text-gray-900 font-semibold text-sm leading-snug mb-1.5 line-clamp-2">${title}</h3>
          ${city ? `<p class="text-gray-400 text-xs mb-3 flex items-center gap-1"><svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>${city}</p>` : ''}
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-gray-500 py-3 border-t border-b border-gray-100">
            ${detailItems || (acf.property_type ? `<span class="text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full capitalize">${acf.property_type}</span>` : '<span class="text-gray-300 text-xs">—</span>')}
          </div>
          <div class="flex items-center gap-2.5 mt-3">
            ${agentAvatar}
            <div class="min-w-0">
              <p class="text-xs font-semibold text-gray-700 truncate">${agentLabel}</p>
              <p class="text-[10px] text-gray-400 uppercase tracking-wide">Verified Agent</p>
            </div>
            ${propTypeBadge}
          </div>
        </div>
      </a>`;
  }

  function bindSaveButtons() {
    document.querySelectorAll('.save-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        e.stopPropagation();
        const id = Number(btn.dataset.id);
        const icon = btn.querySelector('.save-icon');
        let s = getSaved();
        if (s.includes(id)) {
          s = s.filter(x => x !== id);
          icon.setAttribute('fill', 'none');
          icon.setAttribute('stroke', 'currentColor');
        } else {
          s.push(id);
          icon.setAttribute('fill', '#ea580c');
          icon.setAttribute('stroke', '#ea580c');
        }
        localStorage.setItem('saved_properties', JSON.stringify(s));
      });
    });
  }

  function renderProperties() {
    skeleton.classList.add('hidden');
    if (filteredProperties.length === 0) {
      grid.innerHTML = '';
      noResults.classList.remove('hidden');
      loadMoreBtn.classList.add('hidden');
      resultsCount.textContent = '';
      return;
    }
    noResults.classList.add('hidden');
    resultsCount.textContent = `${filteredProperties.length} properties found`;
    const items = filteredProperties.slice(0, currentPage * ITEMS_PER_PAGE);
    grid.innerHTML = items.map(cardHTML).join('');
    bindSaveButtons();
    bindCompareButtons();
    bindQVButtons();
    if (isMapView) initOrUpdateMap();
    currentPage * ITEMS_PER_PAGE < filteredProperties.length
      ? loadMoreBtn.classList.remove('hidden')
      : loadMoreBtn.classList.add('hidden');
  }

  document.getElementById('filter-btn').addEventListener('click', applyFilters);
  document.getElementById('filter-city').addEventListener('keydown', e => e.key === 'Enter' && applyFilters());
  document.getElementById('sort-select').addEventListener('change', applyFilters);
  loadMoreBtn.addEventListener('click', () => { currentPage++; renderProperties(); bindSaveButtons(); });
  document.getElementById('clear-filters').addEventListener('click', () => {
    document.getElementById('filter-city').value = '';
    document.getElementById('filter-listing-type').value = '';
    document.getElementById('filter-property-type').value = '';
    document.getElementById('filter-bedrooms').value = '';
    document.getElementById('filter-price-min').value = '';
    document.getElementById('filter-price-max').value = '';
    applyFilters();
  });

  document.getElementById('view-grid')?.addEventListener('click', () => {
    isMapView = false;
    document.getElementById('property-grid').classList.remove('hidden');
    document.getElementById('map-view').classList.add('hidden');
    document.getElementById('view-grid').className = 'w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-[#ea580c] text-white border-[#ea580c]';
    document.getElementById('view-map').className = 'w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-white text-gray-600 border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c]';
  });
  document.getElementById('view-map')?.addEventListener('click', () => {
    isMapView = true;
    document.getElementById('property-grid').classList.add('hidden');
    document.getElementById('map-view').classList.remove('hidden');
    document.getElementById('view-grid').className = 'w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-white text-gray-600 border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c]';
    document.getElementById('view-map').className = 'w-9 h-9 rounded-xl border flex items-center justify-center text-sm transition-colors bg-[#ea580c] text-white border-[#ea580c]';
    initOrUpdateMap();
  });

  document.getElementById('compare-clear')?.addEventListener('click', () => {
    localStorage.removeItem('compare_list');
    updateCompareBar();
    updateCompareButtons();
  });

  // Quick filter chips
  let activeChip = null;
  const chipConfig = {
    'chip-new-week': p => (Date.now() - new Date(p.date).getTime()) < 7 * 24 * 60 * 60 * 1000,
    'chip-for-sale': p => p.acf?.listing_type === 'For Sale',
    'chip-for-rent': p => p.acf?.listing_type === 'For Rent',
    'chip-pre-selling': p => p.acf?.listing_type === 'Pre-Selling',
  };
  Object.keys(chipConfig).forEach(id => {
    document.getElementById(id)?.addEventListener('click', () => {
      const isActive = activeChip === id;
      // Reset all chips
      Object.keys(chipConfig).forEach(cid => {
        const b = document.getElementById(cid);
        if (b) b.className = 'text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c] transition-colors';
      });
      activeChip = isActive ? null : id;
      if (!isActive) {
        const b = document.getElementById(id);
        if (b) b.className = 'text-xs font-semibold px-3 py-1.5 rounded-full border-[#ea580c] bg-[#ea580c] text-white transition-colors border';
      }
      applyFilters();
    });
  });

  // Quick View modal
  const qvModal = document.getElementById('qv-modal');
  qvModal?.addEventListener('click', e => { if (e.target === qvModal) qvModal.classList.add('hidden'); });

  function bindQVButtons() {
    document.querySelectorAll('.qv-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault(); e.stopPropagation();
        try {
          const d = JSON.parse(btn.dataset.prop);
          const imgEl = document.getElementById('qv-img');
          if (imgEl) imgEl.innerHTML = (d.image
            ? `<img src="${d.image}" class="w-full h-full object-cover" loading="lazy"/>`
            : '<div class="w-full h-full flex items-center justify-center text-6xl opacity-20">🏠</div>') +
            `<button onclick="document.getElementById('qv-modal').classList.add('hidden')" class="absolute top-3 right-3 w-8 h-8 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center z-10 transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>`;
          document.getElementById('qv-price').textContent = d.price;
          document.getElementById('qv-title').textContent = d.title;
          document.getElementById('qv-location').textContent = d.city ? '📍 ' + d.city : '';
          const specs = [
            d.bedrooms ? '🛏 ' + d.bedrooms + ' Beds' : '',
            d.bathrooms ? '🚿 ' + d.bathrooms + ' Baths' : '',
            d.floor_area ? '📐 ' + d.floor_area + ' m²' : '',
          ].filter(Boolean).map(s => `<span>${s}</span>`).join('');
          document.getElementById('qv-specs').innerHTML = specs || '<span class="text-gray-400">No specs listed</span>';
          document.getElementById('qv-link').href = '/property/' + d.slug;
          const waEl = document.getElementById('qv-wa');
          if (waEl && d.agent_phone) {
            const phone = d.agent_phone.replace(/\D/g,'').replace(/^0/,'63');
            waEl.href = `https://wa.me/${phone}?text=${encodeURIComponent('Hi! I\'m interested in: ' + d.title)}`;
            waEl.classList.remove('hidden');
          } else if (waEl) waEl.classList.add('hidden');
          qvModal.classList.remove('hidden');
        } catch {}
      });
    });
  }

  // Currency toggle buttons
  ['php','usd','sgd'].forEach(cur => {
    document.getElementById('cur-' + cur)?.addEventListener('click', () => {
      activeCurrency = cur.toUpperCase();
      ['php','usd','sgd'].forEach(c => {
        const btn = document.getElementById('cur-' + c);
        if (btn) {
          btn.className = c === cur
            ? 'px-3 py-2 bg-[#ea580c] text-white transition-colors'
            : 'px-3 py-2 bg-white text-gray-500 hover:bg-gray-50 transition-colors';
        }
      });
      renderProperties();
    });
  });

  // Draw-to-search: toggle area filter on/off
  const searchAreaBtn = document.getElementById('search-area-btn');
  searchAreaBtn?.addEventListener('click', () => {
    if (mapBoundsActive) {
      mapBoundsActive = false;
      searchAreaBtn.textContent = '🔍 Search this area';
      searchAreaBtn.classList.remove('bg-orange-50', 'border-[#ea580c]', 'text-[#ea580c]');
      applyFilters();
      return;
    }
    if (!leafletMap) return;
    const bounds = leafletMap.getBounds();
    filteredProperties = allProperties.filter(p => {
      const city = (p.acf?.location_city || '').toLowerCase().trim();
      const coords = CITY_COORDS[city];
      return coords && bounds.contains(coords);
    });
    mapBoundsActive = true;
    searchAreaBtn.textContent = '✕ Clear area filter';
    searchAreaBtn.classList.add('bg-orange-50', 'border-[#ea580c]', 'text-[#ea580c]');
    renderProperties();
    initOrUpdateMap();
  });

  // ── Save Search ────────────────────────────────────────────────────────────
  function getCurrentFilters() {
    return {
      city: document.getElementById('filter-city').value.trim(),
      listingType: document.getElementById('filter-listing-type').value,
      propertyType: document.getElementById('filter-property-type').value,
      bedrooms: document.getElementById('filter-bedrooms').value,
      priceMin: document.getElementById('filter-price-min').value,
      priceMax: document.getElementById('filter-price-max').value,
    };
  }

  function formatShortNum(n) {
    const num = Number(n);
    if (num >= 1000000) return (num / 1000000).toFixed(0) + 'M';
    if (num >= 1000) return (num / 1000).toFixed(0) + 'K';
    return num.toString();
  }

  function buildSearchLabel(f) {
    const parts = [];
    if (f.city) parts.push(f.city);
    if (f.listingType) parts.push(f.listingType);
    if (f.propertyType) parts.push(f.propertyType);
    if (f.bedrooms) parts.push(f.bedrooms + '+ beds');
    if (f.priceMin && f.priceMax) parts.push('₱' + formatShortNum(f.priceMin) + '–₱' + formatShortNum(f.priceMax));
    else if (f.priceMin) parts.push('From ₱' + formatShortNum(f.priceMin));
    else if (f.priceMax) parts.push('Up to ₱' + formatShortNum(f.priceMax));
    return parts.join(', ');
  }

  function renderSavedSearches() {
    const searches = JSON.parse(localStorage.getItem('saved_searches') || '[]');
    const bar = document.getElementById('saved-searches-bar');
    const list = document.getElementById('saved-searches-list');
    if (!bar || !list) return;
    if (searches.length === 0) { bar.classList.add('hidden'); return; }
    bar.classList.remove('hidden');
    list.innerHTML = searches.map(s => `
      <div class="flex items-center gap-0.5 bg-orange-50 border border-orange-200 rounded-full pl-3 pr-1.5 py-1">
        <button onclick="loadSavedSearch(${s.id})" class="text-xs text-[#ea580c] font-medium hover:underline">${s.label}</button>
        <button onclick="deleteSavedSearch(${s.id})" class="w-4 h-4 text-gray-400 hover:text-red-500 transition-colors flex items-center justify-center text-sm ml-0.5">&times;</button>
      </div>
    `).join('');
  }

  window.loadSavedSearch = function(id) {
    const searches = JSON.parse(localStorage.getItem('saved_searches') || '[]');
    const entry = searches.find(s => s.id === id);
    if (!entry) return;
    const f = entry.filters;
    document.getElementById('filter-city').value = f.city || '';
    document.getElementById('filter-listing-type').value = f.listingType || '';
    document.getElementById('filter-property-type').value = f.propertyType || '';
    document.getElementById('filter-bedrooms').value = f.bedrooms || '';
    document.getElementById('filter-price-min').value = f.priceMin || '';
    document.getElementById('filter-price-max').value = f.priceMax || '';
    applyFilters();
  };

  window.deleteSavedSearch = function(id) {
    let searches = JSON.parse(localStorage.getItem('saved_searches') || '[]');
    searches = searches.filter(s => s.id !== id);
    localStorage.setItem('saved_searches', JSON.stringify(searches));
    renderSavedSearches();
  };

  document.getElementById('save-search-btn')?.addEventListener('click', () => {
    const filters = getCurrentFilters();
    const label = buildSearchLabel(filters);
    if (!label) {
      alert('Set at least one filter before saving a search.');
      return;
    }
    const searches = JSON.parse(localStorage.getItem('saved_searches') || '[]');
    searches.unshift({ id: Date.now(), label, filters, date: new Date().toISOString() });
    if (searches.length > 10) searches.pop();
    localStorage.setItem('saved_searches', JSON.stringify(searches));
    renderSavedSearches();
    const btn = document.getElementById('save-search-btn');
    if (btn) { btn.textContent = '✓ Saved!'; setTimeout(() => { btn.textContent = '💾 Save Search'; }, 2000); }
  });

  renderSavedSearches();

  updateCompareBar();
  fetchProperties();

  // Property alerts: stamp current filters into the hidden field, show success in-page
  (function() {
    var form = document.getElementById('alerts-form');
    var filtersInput = document.getElementById('alerts-filters');
    var successMsg = document.getElementById('alerts-success');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      // Capture active filter state as human-readable label
      var city = document.getElementById('filter-city')?.value || '';
      var type = document.getElementById('filter-type')?.value || '';
      var listing = document.getElementById('filter-listing')?.value || '';
      var minP = document.getElementById('filter-price-min')?.value || '';
      var maxP = document.getElementById('filter-price-max')?.value || '';
      var parts = [];
      if (city) parts.push('City: ' + city);
      if (type) parts.push('Type: ' + type);
      if (listing) parts.push('Listing: ' + listing);
      if (minP) parts.push('Min price: ₱' + Number(minP).toLocaleString('en-PH'));
      if (maxP) parts.push('Max price: ₱' + Number(maxP).toLocaleString('en-PH'));
      if (filtersInput) filtersInput.value = parts.length ? parts.join(' | ') : 'All listings';
      // Submit via fetch so user stays on page
      var data = new FormData(form);
      fetch(form.action, { method: 'POST', body: data, headers: { 'Accept': 'application/json' } })
        .finally(function() {
          form.style.display = 'none';
          if (successMsg) successMsg.classList.remove('hidden');
        });
    });
  })();
</script>
