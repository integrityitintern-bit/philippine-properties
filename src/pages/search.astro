---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';
---

<Layout title="Search Properties">
  <Navbar />

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-white">Search Properties</h1>
      <p class="text-white/50 text-sm mt-1">Find your perfect home, condo, or investment property</p>
    </div>

    <!-- Filters -->
    <div class="bg-[#141414] border border-white/[0.07] rounded-2xl p-4 mb-8 space-y-3">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        <input id="filter-city" type="text" placeholder="City or Area"
          class="col-span-2 sm:col-span-1 px-4 py-2.5 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white/[0.05] text-white placeholder-white/30"
        />
        <select id="filter-listing-type" class="px-4 py-2.5 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-[#1a1a1a] text-white">
          <option value="">All Types</option>
          <option value="For Sale">For Sale</option>
          <option value="For Rent">For Rent</option>
          <option value="Pre-Selling">Pre-Selling</option>
        </select>
        <select id="filter-property-type" class="px-4 py-2.5 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-[#1a1a1a] text-white">
          <option value="">All Properties</option>
          <option value="House">House</option>
          <option value="Condo">Condo</option>
          <option value="Townhouse">Townhouse</option>
          <option value="Apartment">Apartment</option>
          <option value="Studio">Studio</option>
          <option value="Land & Lot">Land & Lot</option>
          <option value="Commercial">Commercial</option>
        </select>
        <select id="filter-bedrooms" class="px-4 py-2.5 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-[#1a1a1a] text-white">
          <option value="">Any Beds</option>
          <option value="1">1+ Bed</option>
          <option value="2">2+ Beds</option>
          <option value="3">3+ Beds</option>
          <option value="4">4+ Beds</option>
        </select>
        <button id="filter-btn" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-2.5 px-6 rounded-xl transition-colors text-sm">
          Search
        </button>
      </div>
      <div class="flex flex-wrap items-center gap-3 pt-1">
        <span class="text-xs font-medium text-white/50">Price Range:</span>
        <select id="filter-price-min" class="px-3 py-2 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-[#1a1a1a] text-white">
          <option value="">No Min</option>
          <option value="500000">₱500K</option>
          <option value="1000000">₱1M</option>
          <option value="2000000">₱2M</option>
          <option value="5000000">₱5M</option>
          <option value="10000000">₱10M</option>
          <option value="20000000">₱20M</option>
        </select>
        <span class="text-white/40 text-sm">–</span>
        <select id="filter-price-max" class="px-3 py-2 text-sm border border-white/[0.1] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-[#1a1a1a] text-white">
          <option value="">No Max</option>
          <option value="1000000">₱1M</option>
          <option value="2000000">₱2M</option>
          <option value="5000000">₱5M</option>
          <option value="10000000">₱10M</option>
          <option value="20000000">₱20M</option>
          <option value="50000000">₱50M</option>
        </select>
        <button id="clear-filters" class="text-xs text-white/40 hover:text-[#ea580c] transition-colors underline ml-auto">
          Clear all filters
        </button>
      </div>
    </div>

    <p id="results-count" class="text-sm text-white/50 mb-4"></p>

    <!-- Loading Skeletons -->
    <div id="loading-skeleton" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {Array(6).fill(0).map(() => (
        <div class="bg-[#141414] rounded-xl overflow-hidden shadow-sm border border-white/[0.06]">
          <div class="skeleton h-48 bg-white/10"></div>
          <div class="p-4 space-y-3">
            <div class="skeleton h-5 bg-white/10 rounded w-1/2"></div>
            <div class="skeleton h-4 bg-white/10 rounded w-3/4"></div>
            <div class="skeleton h-3 bg-white/10 rounded w-1/3"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Property Grid -->
    <div id="property-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <!-- No Results -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-5xl mb-4">🏠</p>
      <p class="text-white/50 text-lg font-medium">No properties found</p>
      <p class="text-white/40 text-sm mt-1">Try adjusting your filters</p>
      <a href="/list-property" class="mt-6 inline-block bg-[#ea580c] text-white px-6 py-3 rounded-xl font-semibold hover:bg-[#c2410c] transition-colors">
        + List a Property
      </a>
    </div>

    <div class="text-center mt-10">
      <button id="load-more-btn" class="hidden bg-[#141414] border-2 border-[#ea580c] text-[#ea580c] font-semibold px-8 py-3 rounded-xl hover:bg-[#ea580c] hover:text-white transition-colors">
        Load More Properties
      </button>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ WP_API }}>
  const ITEMS_PER_PAGE = 12;
  let currentPage = 1;
  let allProperties = [];
  let filteredProperties = [];

  const grid = document.getElementById('property-grid');
  const skeleton = document.getElementById('loading-skeleton');
  const noResults = document.getElementById('no-results');
  const resultsCount = document.getElementById('results-count');
  const loadMoreBtn = document.getElementById('load-more-btn');

  // Pre-fill filters from URL params
  const params = new URLSearchParams(window.location.search);
  if (params.get('city')) document.getElementById('filter-city').value = params.get('city');
  if (params.get('listing_type')) document.getElementById('filter-listing-type').value = params.get('listing_type');
  if (params.get('property_type')) document.getElementById('filter-property-type').value = params.get('property_type');

  async function fetchProperties() {
    try {
      const res = await fetch(`${WP_API}/property?_embed&per_page=100&status=publish`);
      allProperties = await res.json();
      applyFilters();
    } catch (err) {
      skeleton.classList.add('hidden');
      noResults.classList.remove('hidden');
    }
  }

  function applyFilters() {
    const city = document.getElementById('filter-city').value.trim().toLowerCase();
    const listingType = document.getElementById('filter-listing-type').value;
    const propertyType = document.getElementById('filter-property-type').value;
    const minBeds = parseInt(document.getElementById('filter-bedrooms').value) || 0;
    const priceMin = parseInt(document.getElementById('filter-price-min').value) || 0;
    const priceMax = parseInt(document.getElementById('filter-price-max').value) || Infinity;

    filteredProperties = allProperties.filter(p => {
      const acf = p.acf || {};
      const price = parseFloat(acf.price) || 0;
      if (city && !acf.location_city?.toLowerCase().includes(city)) return false;
      if (listingType && acf.listing_type !== listingType) return false;
      if (propertyType && acf.property_type !== propertyType) return false;
      if (minBeds && (parseInt(acf.bedrooms) || 0) < minBeds) return false;
      if (priceMin && price < priceMin) return false;
      if (priceMax !== Infinity && price > priceMax) return false;
      return true;
    });

    currentPage = 1;
    renderProperties();
  }

  const getSaved = () => JSON.parse(localStorage.getItem('saved_properties') || '[]');

  function cardHTML(p) {
    const acf = p.acf || {};
    const title = p.title?.rendered || 'Property';
    const image = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
    const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
    const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
    const badge = acf.listing_type === 'For Rent' ? 'bg-blue-500/90' : acf.listing_type === 'Pre-Selling' ? 'bg-purple-500/90' : 'bg-[#ea580c]';
    const saved = getSaved().includes(p.id);
    const heartFill = saved ? '#ea580c' : 'none';
    const heartStroke = saved ? '#ea580c' : 'currentColor';
    return `
      <a href="/property/${p.slug}" class="group bg-[#141414] rounded-xl shadow-sm hover:shadow-md hover:border-[#ea580c]/40 transition-all overflow-hidden border border-white/[0.06] flex flex-col card-enter">
        <div class="relative h-48 overflow-hidden bg-white/[0.05]">
          ${image ? `<img src="${image}" alt="${title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy"/>` : '<div class="w-full h-full flex items-center justify-center text-5xl opacity-20">🏠</div>'}
          ${acf.listing_type ? `<span class="absolute top-3 left-3 text-xs font-semibold px-2.5 py-1 rounded-full text-white backdrop-blur-sm ${badge}">${acf.listing_type}</span>` : ''}
          <button class="save-btn absolute top-3 right-3 w-8 h-8 bg-black/50 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-black/70 transition-colors" data-id="${p.id}" aria-label="Save property">
            <svg class="save-icon w-4 h-4" fill="${heartFill}" stroke="${heartStroke}" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </button>
        </div>
        <div class="p-4 flex flex-col flex-1">
          <p class="text-[#ea580c] font-bold text-lg leading-tight mb-1">${price}</p>
          <h3 class="text-white font-semibold text-sm leading-snug mb-2 line-clamp-2">${title}</h3>
          ${city ? `<p class="text-white/40 text-xs mb-3 flex items-center gap-1"><svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>${city}</p>` : ''}
          <div class="flex items-center gap-3 text-white/40 text-xs mt-auto pt-3 border-t border-white/[0.06]">
            ${acf.bedrooms ? `<span>🛏 ${acf.bedrooms}</span>` : ''}
            ${acf.bathrooms ? `<span>🚿 ${acf.bathrooms}</span>` : ''}
            ${acf.floor_area ? `<span>📐 ${acf.floor_area} m²</span>` : ''}
            ${acf.property_type ? `<span class="ml-auto capitalize text-[10px] bg-white/[0.08] px-2 py-0.5 rounded-full">${acf.property_type}</span>` : ''}
          </div>
        </div>
      </a>`;
  }

  function bindSaveButtons() {
    document.querySelectorAll('.save-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        e.stopPropagation();
        const id = Number(btn.dataset.id);
        const icon = btn.querySelector('.save-icon');
        let s = getSaved();
        if (s.includes(id)) {
          s = s.filter(x => x !== id);
          icon.setAttribute('fill', 'none');
          icon.setAttribute('stroke', 'currentColor');
        } else {
          s.push(id);
          icon.setAttribute('fill', '#ea580c');
          icon.setAttribute('stroke', '#ea580c');
        }
        localStorage.setItem('saved_properties', JSON.stringify(s));
      });
    });
  }

  function renderProperties() {
    skeleton.classList.add('hidden');
    if (filteredProperties.length === 0) {
      grid.innerHTML = '';
      noResults.classList.remove('hidden');
      loadMoreBtn.classList.add('hidden');
      resultsCount.textContent = '';
      return;
    }
    noResults.classList.add('hidden');
    resultsCount.textContent = `${filteredProperties.length} properties found`;
    const items = filteredProperties.slice(0, currentPage * ITEMS_PER_PAGE);
    grid.innerHTML = items.map(cardHTML).join('');
    bindSaveButtons();
    currentPage * ITEMS_PER_PAGE < filteredProperties.length
      ? loadMoreBtn.classList.remove('hidden')
      : loadMoreBtn.classList.add('hidden');
  }

  document.getElementById('filter-btn').addEventListener('click', applyFilters);
  document.getElementById('filter-city').addEventListener('keydown', e => e.key === 'Enter' && applyFilters());
  loadMoreBtn.addEventListener('click', () => { currentPage++; renderProperties(); bindSaveButtons(); });
  document.getElementById('clear-filters').addEventListener('click', () => {
    document.getElementById('filter-city').value = '';
    document.getElementById('filter-listing-type').value = '';
    document.getElementById('filter-property-type').value = '';
    document.getElementById('filter-bedrooms').value = '';
    document.getElementById('filter-price-min').value = '';
    document.getElementById('filter-price-max').value = '';
    applyFilters();
  });

  fetchProperties();
</script>
