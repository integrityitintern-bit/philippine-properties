---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <Navbar />

  <!-- Hero — keep orange as-is -->
  <section class="bg-[#ea580c] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">About Us</h1>
      <p class="text-white/80 text-lg">Building trust, transforming lives through quality real estate solutions.</p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 max-w-5xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-xs font-bold text-[#ea580c] uppercase tracking-widest">Our Mission</span>
        <h2 class="text-2xl font-bold text-gray-900 mt-2 mb-4">Our Name Is Our Promise</h2>
        <p class="text-gray-500 leading-relaxed mb-4">
          At [Your Brand], we believe every Filipino deserves a place to call home. We've been connecting families with their dream properties across the Philippines — with honesty, transparency, and genuine care.
        </p>
        <p class="text-gray-500 leading-relaxed">
          We operate with a simple principle: your trust is our most valuable asset. Every transaction, every listing, every client interaction is guided by integrity first.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { number: '15+', label: 'Years in Business' },
          { number: '10,000+', label: 'Clients Served' },
          { number: '5,000+', label: 'Properties Listed' },
          { number: '50+', label: 'Cities Covered' },
        ].map(stat => (
          <div class="bg-[#ea580c] text-white p-6 rounded-2xl text-center">
            <p class="text-3xl font-bold">{stat.number}</p>
            <p class="text-white/80 text-xs mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Our Core Values</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {[
          { icon: '🤝', title: 'Integrity', desc: 'We operate with full transparency. What you see is what you get — no hidden fees, no misleading listings.' },
          { icon: '⭐', title: 'Excellence', desc: 'We set the highest standards in property listings, customer service, and after-sales support.' },
          { icon: '💡', title: 'Innovation', desc: 'We leverage modern technology to make your property search and listing experience seamless.' },
          { icon: '🏡', title: 'Client First', desc: 'Your needs drive every decision we make. We listen, we advise, and we deliver.' },
          { icon: '🌏', title: 'Community', desc: 'We give back to the communities where we operate, supporting local development and growth.' },
          { icon: '🔒', title: 'Trust', desc: 'Licensed, accredited, and backed by 15 years of proven track record in Philippine real estate.' },
        ].map(v => (
          <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-sm transition-shadow">
            <span class="text-3xl">{v.icon}</span>
            <h3 class="font-bold text-gray-900 mt-3 mb-2">{v.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 max-w-5xl mx-auto px-4">
    <div class="text-center mb-10">
      <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">The people behind the brand</p>
      <h2 class="text-2xl font-bold text-gray-900">Meet Our Team</h2>
      <p class="text-gray-500 text-sm mt-2">Licensed, experienced, and dedicated to finding your perfect property.</p>
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { name: 'Team Member', role: 'Broker / Owner', initials: 'TM' },
        { name: 'Team Member', role: 'Senior Sales Agent', initials: 'TM' },
        { name: 'Team Member', role: 'Leasing Specialist', initials: 'TM' },
        { name: 'Team Member', role: 'Property Consultant', initials: 'TM' },
      ].map(m => (
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
          <div class="w-20 h-20 bg-[#ea580c]/10 rounded-full flex items-center justify-center text-[#ea580c] font-bold text-2xl mx-auto mb-4">{m.initials}</div>
          <h3 class="font-bold text-gray-900 text-sm">{m.name}</h3>
          <p class="text-gray-400 text-xs mt-1">{m.role}</p>
          <p class="text-[10px] text-[#ea580c] mt-2 font-medium">PRC Licensed</p>
        </div>
      ))}
    </div>
    <p class="text-center text-gray-400 text-xs mt-6">Replace placeholder cards above by updating team member data in about.astro</p>
  </section>

  <!-- Accreditation -->
  <section class="py-12 bg-gray-50 border-y border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-center text-xs font-semibold text-gray-400 uppercase tracking-widest mb-8">Accreditations &amp; Memberships</p>
      <div class="flex flex-wrap justify-center gap-6 items-center">
        {[
          { label: 'PRC Licensed', sub: 'Professional Regulation Commission' },
          { label: 'HLURB Registered', sub: 'Now DHSUD — Housing & Urban Dev.' },
          { label: 'CREBA Member', sub: 'Chamber of Real Estate & Builders' },
          { label: 'RA 9646 Compliant', sub: 'Real Estate Service Act' },
        ].map(a => (
          <div class="bg-white border border-gray-200 rounded-xl px-6 py-4 text-center min-w-[160px] shadow-sm">
            <p class="text-[#ea580c] font-bold text-sm">{a.label}</p>
            <p class="text-gray-400 text-[10px] mt-1">{a.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Ready to Find Your Dream Property?</h2>
      <p class="text-gray-500 mb-8">Browse thousands of listings or list your own property today.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/search" class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-8 py-3 rounded-xl transition-colors">
          Search Properties
        </a>
        <a href="/contact" class="border-2 border-[#ea580c] text-[#ea580c] font-semibold px-8 py-3 rounded-xl hover:bg-[#ea580c] hover:text-white transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
