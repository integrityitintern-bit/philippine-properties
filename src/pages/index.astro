---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { WP_API } from '../config.js';

let featuredProperties = [];
let totalProperties = 0;
let totalAgents = 0;
let totalCities = 0;
try {
  const res = await fetch(`${WP_API}/property?_embed&per_page=6&status=publish&_fields=id,slug,title,date,acf,_embedded`);
  featuredProperties = await res.json();
} catch (e) {
  console.error('Failed to fetch properties:', e);
}
try {
  const statsRes = await fetch(`${WP_API}/property?per_page=100&status=publish&_fields=id,acf`);
  const allProps = await statsRes.json();
  if (Array.isArray(allProps)) {
    totalProperties = allProps.length;
    const agents = new Set(allProps.map((p: any) => p.acf?.agent_name?.trim()).filter(Boolean));
    const cities = new Set(allProps.map((p: any) => p.acf?.location_city?.trim()).filter(Boolean));
    totalAgents = agents.size;
    totalCities = cities.size;
  }
} catch {}

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": "Integrity Real Estate Corp",
  "url": "https://integrityrealty.ph",
  "logo": "https://integrityrealty.ph/favicon.svg",
  "image": "https://integrityrealty.ph/hero-bg.jpg",
  "description": "Find houses, condos, and lots for sale and rent across Metro Manila, Cebu, Davao, and 50+ cities in the Philippines.",
  "address": { "@type": "PostalAddress", "addressCountry": "PH", "addressRegion": "Metro Manila" },
  "contactPoint": { "@type": "ContactPoint", "contactType": "customer service", "email": "info@integrityrealty.ph", "availableLanguage": ["en", "tl"] },
  "sameAs": [],
  "areaServed": { "@type": "Country", "name": "Philippines" },
  "priceRange": "₱₱₱"
};
---

<Layout title="Find Your Dream Property in the Philippines">
  <link rel="preload" as="image" href="/hero-bg.jpg" slot="head" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessJsonLd)} />
  <Navbar />

  <!-- ═══ HERO ═══ -->
  <!-- HOW TO CHANGE HERO IMAGE: Put your photo in /public/hero-bg.jpg -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">

    <!-- Background image layer — replace /hero-bg.jpg with your own photo in /public/ -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/hero-bg.jpg');"
    ></div>

    <!-- Dark overlay for readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>

    <!-- Decorative orange accent line -->
    <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-[#ea580c] to-transparent"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-4 text-center text-white pt-12 pb-16">

      <!-- Eyebrow label -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-xs font-medium px-4 py-2 rounded-full mb-8 tracking-widest uppercase">
        <span class="w-1.5 h-1.5 bg-[#ea580c] rounded-full"></span>
        Philippines Real Estate Portal
      </div>

      <!-- Main heading -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6" style="font-family: 'Playfair Display', serif;">
        Find Your Dream<br />
        <span class="italic text-[#fb923c]">Property</span> in the Philippines
      </h1>

      <p class="text-white/70 text-lg md:text-xl mb-12 max-w-2xl mx-auto leading-relaxed font-light">
        Discover houses, condos, and lots for sale and rent across Metro Manila, Cebu, Davao, and beyond.
      </p>

      <!-- Search Bar — glassmorphism -->
      <form action="/search" method="GET"
        class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-3 max-w-3xl mx-auto shadow-2xl flex flex-col sm:flex-row gap-3"
      >
        <input
          type="text"
          name="city"
          placeholder="City, area, or landmark..."
          class="flex-1 px-5 py-3.5 text-white placeholder-white/50 text-sm rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:border-[#ea580c] focus:bg-white/20 backdrop-blur-sm transition-all"
        />
        <select name="listing_type"
          class="px-4 py-3.5 text-white text-sm rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:border-[#ea580c] backdrop-blur-sm transition-all"
          style="color-scheme: dark;"
        >
          <option value="" class="bg-gray-900">Buy or Rent?</option>
          <option value="For Sale" class="bg-gray-900">For Sale</option>
          <option value="For Rent" class="bg-gray-900">For Rent</option>
          <option value="Pre-Selling" class="bg-gray-900">Pre-Selling</option>
        </select>
        <button type="submit"
          class="bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-8 py-3.5 rounded-xl transition-colors whitespace-nowrap shadow-lg shadow-orange-900/30"
        >
          Search
        </button>
      </form>

      <!-- Quick type pills -->
      <div class="flex flex-wrap justify-center gap-2 mt-8 text-sm">
        {[
          { label: '🏠 For Sale', q: '?listing_type=For+Sale' },
          { label: '🔑 For Rent', q: '?listing_type=For+Rent' },
          { label: '🏢 Condos', q: '?property_type=condo' },
          { label: '🏡 Houses', q: '?property_type=house' },
          { label: '🌿 Land', q: '?property_type=land' },
        ].map(p => (
          <a href={`/search${p.q}`}
            class="bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 text-white/80 hover:text-white px-4 py-2 rounded-full transition-all text-xs tracking-wide"
          >
            {p.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 text-xs">
      <span class="tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/40 to-transparent"></div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="bg-gray-50 border-b border-gray-100 py-10">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {[
        { n: '5,000+', l: 'Active Listings' },
        { n: '50+',    l: 'Cities Covered' },
        { n: '10,000+',l: 'Happy Clients' },
        { n: '15+',    l: 'Years Experience' },
      ].map(s => (
        <div>
          <p class="text-3xl font-bold gradient-text">{s.n}</p>
          <p class="text-gray-500 text-xs mt-1 tracking-widest uppercase">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FEATURED LISTINGS ═══ -->
  <section class="py-20 max-w-7xl mx-auto px-4">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">Hand-picked for you</p>
        <h2 class="text-3xl font-bold text-gray-900">Featured Properties</h2>
      </div>
      <a href="/search" class="text-[#ea580c] text-sm font-semibold hover:text-[#f97316] transition-colors tracking-wide">View All →</a>
    </div>

    {featuredProperties.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProperties.map((property: any) => (
          <PropertyCard property={property} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-6xl mb-4 opacity-20">🏠</p>
        <p class="text-gray-400 text-lg">No properties yet.</p>
        <a href="/list-property" class="mt-4 inline-block text-[#ea580c] font-semibold hover:underline">Be first to list →</a>
      </div>
    )}
  </section>

  <!-- ═══ BROWSE BY TYPE ═══ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">Browse by category</p>
        <h2 class="text-3xl font-bold text-gray-900">Property Types</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {[
          { label: 'House',      icon: '🏡', value: 'House' },
          { label: 'Condo',      icon: '🏢', value: 'Condo' },
          { label: 'Townhouse',  icon: '🏘', value: 'Townhouse' },
          { label: 'Apartment',  icon: '🏬', value: 'Apartment' },
          { label: 'Land & Lot', icon: '🌿', value: 'Land & Lot' },
          { label: 'Commercial', icon: '🏪', value: 'Commercial' },
        ].map(t => (
          <a href={`/search?property_type=${encodeURIComponent(t.value)}`}
            class="flex flex-col items-center py-6 px-2 bg-white rounded-2xl border border-gray-100 shadow-sm hover:border-[#ea580c]/50 hover:bg-orange-50 transition-all group"
          >
            <span class="text-3xl mb-3">{t.icon}</span>
            <span class="text-xs font-semibold text-gray-500 group-hover:text-[#ea580c] transition-colors tracking-wide">{t.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: totalProperties > 0 ? totalProperties + '+' : '—', label: 'Properties Listed' },
          { value: totalAgents > 0 ? totalAgents + '+' : '—', label: 'Active Agents' },
          { value: totalCities > 0 ? totalCities + '+' : '—', label: 'Cities Covered' },
          { value: '100%', label: 'Free to List' },
        ].map(stat => (
          <div>
            <p class="text-4xl font-bold text-[#ea580c] mb-2">{stat.value}</p>
            <p class="text-gray-500 text-sm font-medium tracking-wide">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="py-20 bg-white max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">What our clients say</p>
      <h2 class="text-3xl font-bold text-gray-900">Client Stories</h2>
    </div>
    <div id="testimonials-grid" class="grid md:grid-cols-3 gap-6">
      <!-- Static fallback — replaced by JS if WP testimonials exist -->
      {[
        { name: 'Maria Santos', role: 'First-Time Homebuyer', location: 'Metro Manila', text: 'Found my dream condo in Makati through this site. The agent was very responsive and the process was smooth from viewing to turnover.', rating: 5 },
        { name: 'Jose Reyes',   role: 'OFW Property Investor', location: 'Overseas',     text: 'As an OFW, I was worried about investing from abroad. The detailed listings and direct agent contact made buying back home easy.', rating: 5 },
        { name: 'Ana Cruz',     role: 'Property Renter',       location: 'Taguig City',  text: 'Found a great apartment in BGC within my budget. The search filters saved me so much time compared to other Philippine real estate sites.', rating: 5 },
      ].map(t => (
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-7 flex flex-col">
          <div class="flex gap-0.5 mb-5">
            {Array.from({length: t.rating}).map(() => <span class="text-[#ea580c] text-sm">★</span>)}
            {Array.from({length: 5 - t.rating}).map(() => <span class="text-gray-200 text-sm">★</span>)}
          </div>
          <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-6">"{t.text}"</p>
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-10 h-10 bg-[#ea580c]/20 rounded-full flex items-center justify-center text-[#f97316] font-bold text-sm shrink-0">{t.name[0]}</div>
            <div>
              <p class="text-gray-900 font-semibold text-sm">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.role} · {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ RECENTLY VIEWED ═══ -->
  <section id="recently-viewed-home" class="py-16 max-w-7xl mx-auto px-4 hidden">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-2">Your activity</p>
        <h2 class="text-3xl font-bold text-gray-900">Recently Viewed</h2>
      </div>
      <a href="/saved" class="text-[#ea580c] text-sm font-semibold hover:text-[#f97316] transition-colors tracking-wide">Saved Properties →</a>
    </div>
    <div id="recently-viewed-home-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4"></div>
  </section>

  <!-- ═══ DARK CTA ═══ -->
  <!-- HOW TO CHANGE THIS BG: replace /cta-bg.jpg in /public/ -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/cta-bg.jpg');"></div>
    <div class="absolute inset-0 bg-gray-900/85"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-4 text-center text-white">
      <p class="text-[#fb923c] text-xs font-semibold tracking-widest uppercase mb-3">Free listing</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family:'Playfair Display',serif;">
        Ready to List Your Property?
      </h2>
      <p class="text-white/60 mb-10 text-lg font-light leading-relaxed">
        Reach thousands of verified buyers and renters across the Philippines.
      </p>
      <a href="/list-property"
        class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-10 py-4 rounded-xl text-lg transition-colors shadow-xl shadow-orange-900/40"
      >
        + List Your Property Free
      </a>
      <div class="mt-8 pt-8 border-t border-white/10">
        <p class="text-white/50 text-sm mb-4">Join our community of property buyers &amp; investors</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <!-- WhatsApp Group: replace the link with your actual WhatsApp group invite URL -->
          <a href="https://chat.whatsapp.com/XXXXXXXXXXXXXXXXXX" target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1da850] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm shadow-lg">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Join WhatsApp Group
          </a>
          <!-- Viber Group: replace the link with your actual Viber group invite URL -->
          <a href="viber://invite?g2=XXXXXXXXXXXXXXXXXX" target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-[#7360f2] hover:bg-[#5a4bd1] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm shadow-lg">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.398.002C8.278.065 1.678.592.598 7.137c-.35 2.098-.398 4.537.11 6.663.89 3.717 4.277 6.048 7.52 6.598v2.75c0 .306.187.584.473.7.094.037.192.056.29.056.2 0 .395-.078.542-.226l2.796-2.796c.3.016.596.032.89.032 3.117 0 9.718-.528 10.8-7.074.507-3.138.288-5.43-.428-7.198C21.47 2.49 17.558-.12 11.398.002zm-.14 1.98c5.596-.112 8.895 2.143 9.78 4.284.61 1.497.79 3.527.33 6.327-.866 5.27-6.15 5.656-8.68 5.656-.42 0-.872-.02-1.343-.06-.25-.02-.49.076-.655.253l-2.085 2.085v-2.013c0-.35-.228-.66-.563-.762-2.726-.818-5.7-2.756-6.47-6.05-.46-1.928-.416-4.166-.098-6.07.87-5.15 6.026-5.618 9.783-5.65zm1.48 4.26c-.456.038-.797.44-.76.896.038.457.44.797.897.76.86-.072 1.56.138 2.11.643.55.505.868 1.246.94 2.144.04.457.44.796.898.757.457-.04.797-.44.758-.898-.103-1.268-.558-2.34-1.387-3.105-.83-.766-1.914-1.13-3.056-1.198l-.4.001zm-3.32.682a7.2 7.2 0 00-.74.095C7.29 7.272 6.27 8.24 6.03 9.55c-.09.496-.085.992-.08 1.354.002.226.004.394-.01.52l-.01.1c-.047.36-.01.654.243.88.204.187.484.27.753.23.46-.07.78-.5.71-.962l.01-.1c.019-.185.016-.41.013-.69-.003-.306-.007-.668.052-1.02.13-.706.634-1.197 1.3-1.337.174-.037.358-.057.544-.07.46-.034.807-.43.773-.89-.033-.46-.43-.808-.89-.773l-.04.003v.001zm3.374 1.358c-.33-.016-.638.152-.8.44-.16.286-.15.633.026.91l.064.102c.102.16.21.394.3.67.088.273.145.564.15.836.007.46.385.825.845.817.46-.007.826-.386.818-.847-.01-.44-.097-.89-.24-1.31-.143-.42-.33-.793-.518-1.083l-.064-.102c-.147-.233-.384-.372-.623-.44l-.068.007h.11z"/></svg>
            Join Viber Group
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<!-- Newsletter success toast -->
<script is:inline>
  (function() {
    if (new URLSearchParams(window.location.search).get('newsletter') !== 'success') return;
    history.replaceState(null, '', window.location.pathname);
    var toast = document.createElement('div');
    toast.textContent = '✅ You\'re subscribed! Thanks for joining our newsletter.';
    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a2e;color:white;padding:14px 24px;border-radius:12px;font-size:14px;font-weight:600;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.3);max-width:90%;text-align:center;transition:opacity 0.5s;';
    document.body.appendChild(toast);
    setTimeout(function() {
      toast.style.opacity = '0';
      setTimeout(function() { toast.remove(); }, 500);
    }, 4000);
  })();
</script>

<!-- Recently Viewed: read localStorage, show compact property cards -->
<script>
  (function() {
    try {
      var viewed = JSON.parse(localStorage.getItem('recently_viewed') || '[]');
      if (!viewed.length) return;
      var section = document.getElementById('recently-viewed-home');
      var grid = document.getElementById('recently-viewed-home-grid');
      if (!section || !grid) return;
      grid.innerHTML = viewed.slice(0, 5).map(function(v) {
        return (
          '<a href="/property/' + v.slug + '" class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-[#ea580c]/40 hover:shadow-md transition-all flex flex-col">' +
            '<div class="h-32 sm:h-36 overflow-hidden bg-gray-100">' +
              (v.image
                ? '<img src="' + v.image + '" alt="' + v.title + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy"/>'
                : '<div class="w-full h-full flex items-center justify-center text-4xl opacity-20">🏠</div>') +
            '</div>' +
            '<div class="p-3">' +
              '<p class="text-[#ea580c] font-bold text-sm">' + v.price + '</p>' +
              '<p class="text-gray-700 text-xs font-medium mt-0.5 line-clamp-2">' + v.title + '</p>' +
            '</div>' +
          '</a>'
        );
      }).join('');
      section.classList.remove('hidden');
    } catch(e) {}
  })();
</script>

<!-- Testimonials: fetch live from WP, replace static fallback if data exists -->
<script define:vars={{ WP_API }}>
  (async function () {
    try {
      var res = await fetch(WP_API + '/testimonial?per_page=6&status=publish');
      if (!res.ok) return;
      var items = await res.json();
      if (!Array.isArray(items) || items.length === 0) return;

      var grid = document.getElementById('testimonials-grid');
      if (!grid) return;

      grid.innerHTML = items.map(function (t) {
        var acf = t.acf || {};
        var name = acf.reviewer_name || (t.title && t.title.rendered) || 'Client';
        var role = acf.reviewer_role || '';
        var location = acf.reviewer_location || '';
        var text = acf.review_text || '';
        var rating = parseInt(acf.rating) || 5;
        if (rating < 1) rating = 1;
        if (rating > 5) rating = 5;

        var stars = '';
        for (var i = 1; i <= 5; i++) {
          stars += '<span class="' + (i <= rating ? 'text-[#ea580c]' : 'text-gray-200') + ' text-sm">★</span>';
        }

        var initial = name[0] || '?';
        var byline = role + (location ? ' · ' + location : '');

        return (
          '<div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-7 flex flex-col">' +
            '<div class="flex gap-0.5 mb-5">' + stars + '</div>' +
            '<p class="text-gray-500 text-sm leading-relaxed flex-1 mb-6">"' + text + '"</p>' +
            '<div class="flex items-center gap-3 pt-4 border-t border-gray-100">' +
              '<div class="w-10 h-10 bg-[#ea580c]/20 rounded-full flex items-center justify-center text-[#f97316] font-bold text-sm shrink-0">' + initial + '</div>' +
              '<div>' +
                '<p class="text-gray-900 font-semibold text-sm">' + name + '</p>' +
                '<p class="text-gray-400 text-xs">' + byline + '</p>' +
              '</div>' +
            '</div>' +
          '</div>'
        );
      }).join('');
    } catch (e) {
      // keep static fallback on error
    }
  })();
</script>
