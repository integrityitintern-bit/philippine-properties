---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { WP_API } from '../../config.js';

export async function getStaticPaths() {
  try {
    const res = await fetch(`${WP_API}/property?per_page=100&status=publish&_fields=id,slug`);
    const properties = await res.json();
    return properties.map((p: any) => ({
      params: { slug: p.slug },
      props: { propertyId: p.id },
    }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;
const { propertyId } = Astro.props;

let property: any = null;
try {
  const res = await fetch(`${WP_API}/property/${propertyId}?_embed`);
  property = await res.json();
} catch {}

if (!property || property.code) return Astro.redirect('/search');

const acf = property.acf || {};
const title = property.title?.rendered || 'Property';
const content = property.content?.rendered || '';
const image = property._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
const badgeColor = acf.listing_type === 'For Rent' ? 'bg-blue-50 text-blue-600' : acf.listing_type === 'Pre-Selling' ? 'bg-purple-50 text-purple-600' : 'bg-orange-50 text-[#ea580c]';
const locationQuery = encodeURIComponent([acf.full_address, acf.location_city, acf.location_province, 'Philippines'].filter(Boolean).join(', '));
const whatsappPhone = acf.agent_phone ? acf.agent_phone.replace(/\D/g, '').replace(/^0/, '63') : '';
const whatsappMsg = encodeURIComponent(`Hi! I'm interested in this property: ${title} — ${price}`);
const description = content.replace(/<[^>]*>/g, '').slice(0, 160) || `${price} — ${title} in ${acf.location_city || 'Philippines'}`;

// Mortgage estimate chip (20% down, 6.5% rate, 20-yr term)
const rawPrice = Number(acf.price) || 0;
const loanAmt = rawPrice * 0.80;
const mRate = 0.065 / 12;
const nPay = 240;
const monthlyEst = loanAmt > 0 ? Math.round(loanAmt * (mRate * Math.pow(1 + mRate, nPay)) / (Math.pow(1 + mRate, nPay) - 1)) : 0;
const monthlyEstStr = monthlyEst > 0 ? '~₱' + monthlyEst.toLocaleString('en-PH') + '/mo' : '';

// Breadcrumb JSON-LD
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://philippine-properties.com/" },
    { "@type": "ListItem", "position": 2, "name": "Properties", "item": "https://philippine-properties.com/search" },
    { "@type": "ListItem", "position": 3, "name": title, "item": Astro.url.href },
  ],
};

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": title,
  "description": description,
  "url": Astro.url.href,
  ...(image ? { "image": image } : {}),
  "offers": {
    "@type": "Offer",
    "price": acf.price || undefined,
    "priceCurrency": "PHP",
    "availability": acf.property_status === 'Sold' ? "https://schema.org/SoldOut" : "https://schema.org/InStock"
  },
  "address": {
    "@type": "PostalAddress",
    ...(acf.full_address ? { "streetAddress": acf.full_address } : {}),
    ...(acf.location_city ? { "addressLocality": acf.location_city } : {}),
    ...(acf.location_province ? { "addressRegion": acf.location_province } : {}),
    "addressCountry": "PH"
  },
  ...(acf.bedrooms ? { "numberOfRooms": Number(acf.bedrooms) } : {}),
  ...(acf.floor_area ? { "floorSize": { "@type": "QuantitativeValue", "value": Number(acf.floor_area), "unitCode": "MTK" } } : {}),
};

// CDN helper — wraps WP image URLs through wsrv.nl for resize + WebP conversion
function cdnUrl(url: string, w: number): string {
  if (!url || url.startsWith('data:')) return url;
  return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=${w}&q=82&output=webp`;
}

// Virtual tour
const vtUrl = acf.virtual_tour_url || '';
const ytMatch = vtUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
const vtEmbedUrl = ytMatch ? `https://www.youtube.com/embed/${ytMatch[1]}?rel=0&modestbranding=1` : vtUrl;

// Build gallery array: featured image first, then additional photo fields
const galleryImages: string[] = [];
if (image) galleryImages.push(image);
// Free ACF: individual image fields photo_2 through photo_10
for (const key of ['photo_2','photo_3','photo_4','photo_5','photo_6','photo_7','photo_8','photo_9','photo_10']) {
  const img = acf[key];
  if (!img) continue;
  let url = '';
  if (typeof img === 'string') {
    url = img;
  } else if (typeof img === 'number') {
    // ACF returned image ID — resolve via media endpoint
    try {
      const mRes = await fetch(`${WP_API}/media/${img}?_fields=source_url`);
      const mData = await mRes.json();
      url = mData.source_url || '';
    } catch {}
  } else {
    url = img?.url || img?.sizes?.large || img?.sizes?.medium_large || '';
  }
  if (url && !galleryImages.includes(url)) galleryImages.push(url);
}
// ACF Pro: gallery field (works if upgraded later)
if (Array.isArray(acf.gallery)) {
  acf.gallery.forEach((img: any) => {
    const url = typeof img === 'string' ? img : (img?.url || img?.sizes?.large || '');
    if (url && !galleryImages.includes(url)) galleryImages.push(url);
  });
}
// Fallback: fetch all media attached to this post (catches content-block images & any ACF format)
try {
  const mediaRes = await fetch(`${WP_API}/media?parent=${propertyId}&per_page=20&_fields=source_url,mime_type`);
  const mediaData = await mediaRes.json();
  if (Array.isArray(mediaData)) {
    mediaData.forEach((m: any) => {
      const url = m.source_url || '';
      if (url && m.mime_type?.startsWith('image/') && !galleryImages.includes(url)) galleryImages.push(url);
    });
  }
} catch {}
---

<Layout title={title} description={description} ogImage={image || '/hero-bg.jpg'} ogType="article">
  <Navbar />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Breadcrumb + back-to-search -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
      <nav class="text-xs text-gray-400 flex items-center gap-2">
        <a href="/" class="hover:text-[#ea580c]">Home</a>
        <span>›</span>
        <a href="/search" class="hover:text-[#ea580c]">Properties</a>
        <span>›</span>
        <span class="text-gray-700">{title}</span>
      </nav>
      <a id="back-to-search" href="/search" class="hidden text-xs font-semibold text-[#ea580c] hover:text-[#c2410c] flex items-center gap-1 transition-colors">
        ← Back to results
      </a>
    </div>

    <!-- Mortgage estimate chip -->
    {monthlyEstStr && (
      <a href={`/mortgage-calculator?price=${rawPrice}`}
         class="inline-flex items-center gap-2 text-xs font-semibold text-gray-500 hover:text-[#ea580c] bg-orange-50 hover:bg-orange-100 border border-orange-100 px-3 py-1.5 rounded-full mb-6 transition-colors">
        🏦 {monthlyEstStr} est. · Adjust calculator ↗
      </a>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Main -->
      <div class="lg:col-span-2">

        <!-- Gallery -->
        <div class="mb-6">
          <div class="rounded-2xl overflow-hidden bg-gray-100 h-72 md:h-[420px] relative group cursor-pointer"
               onclick="openLightbox(0)">
            {galleryImages.length > 0
              ? <img src={cdnUrl(galleryImages[0], 1200)} alt={title} class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
              : <div class="w-full h-full flex items-center justify-center text-6xl opacity-20">🏠</div>
            }
            {galleryImages.length > 1 && (
              <div class="absolute bottom-3 right-3 flex items-center gap-1.5 bg-black/60 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1.5 rounded-full pointer-events-none">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {galleryImages.length} photos
              </div>
            )}
            {galleryImages.length > 0 && (
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm rounded-full px-5 py-2 text-white text-sm font-semibold">
                  View Photos
                </span>
              </div>
            )}
          </div>

          {galleryImages.length > 1 && (
            <div class="grid grid-cols-5 gap-2 mt-2">
              {galleryImages.slice(0, 5).map((img, i) => (
                <button
                  class={`thumb-btn h-16 rounded-xl overflow-hidden border-2 transition-all ${i === 0 ? 'border-[#ea580c]' : 'border-transparent hover:border-gray-300'}`}
                  data-idx={i}
                  onclick={`openLightbox(${i})`}
                >
                  <img src={cdnUrl(img, 200)} alt="" class="w-full h-full object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Virtual Tour -->
        {vtUrl && (
          <div class="mb-6">
            <h3 class="font-bold text-gray-900 mb-3 flex items-center gap-2">🎥 Virtual Tour</h3>
            <div class="aspect-video rounded-2xl overflow-hidden border border-gray-200 bg-gray-100">
              <iframe src={vtEmbedUrl} class="w-full h-full" allowfullscreen loading="lazy" title="Virtual Tour"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" />
            </div>
            <!-- WP SETUP: In ACF → Field Groups → Property Details, add field:
                 Label: Virtual Tour URL | Name: virtual_tour_url | Type: URL
                 Paste YouTube link or any embeddable URL -->
          </div>
        )}

        <!-- Title, Price & Share -->
        <div class="mb-4">
          <div class="flex items-center gap-2 flex-wrap mb-3">
            {acf.listing_type && (
              <span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full ${badgeColor}`}>
                {acf.listing_type}
              </span>
            )}
            {acf.property_status === 'Sold' && (
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-red-100 text-red-600 border border-red-200">
                Sold
              </span>
            )}
            {acf.property_status === 'Reserved' && (
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 border border-yellow-200">
                Reserved
              </span>
            )}
          </div>
          {acf.property_status === 'Sold' && (
            <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4 flex items-center gap-2">
              <span class="text-red-500 font-bold text-sm">⛔ This property has been SOLD</span>
              <span class="text-red-400 text-xs">— Contact us for similar available properties</span>
            </div>
          )}
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex-1">
              <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">{title}</h1>
              <p class="text-3xl font-bold text-[#ea580c]">{price}</p>
              <span id="view-counter" class="hidden text-xs text-gray-400 font-medium mt-1 block"></span>
              {(acf.location_city || acf.location_province) && (
                <p class="text-gray-500 text-sm mt-2">
                  📍 {[acf.full_address, acf.location_city, acf.location_province].filter(Boolean).join(', ')}
                </p>
              )}
            </div>
            <!-- Share buttons -->
            <div class="flex items-center gap-2 shrink-0 mt-1">
              <button id="share-copy" title="Copy link"
                class="w-9 h-9 bg-gray-100 hover:bg-gray-200 rounded-xl flex items-center justify-center transition-colors text-gray-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              </button>
              <a id="share-facebook" href="#" target="_blank" rel="noopener" title="Share on Facebook"
                class="w-9 h-9 bg-[#1877F2] hover:bg-[#1565d8] rounded-xl flex items-center justify-center transition-colors text-white font-bold text-sm">
                f
              </a>
              <a id="share-whatsapp" href="#" target="_blank" rel="noopener" title="Share on WhatsApp"
                class="w-9 h-9 bg-[#25D366] hover:bg-[#1da850] rounded-xl flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </a>
              <button id="cmp-btn" title="Add to compare"
                class="w-9 h-9 bg-gray-100 hover:bg-gray-200 rounded-xl flex items-center justify-center transition-colors text-gray-500 print:hidden">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </button>
              <button onclick="window.print()" title="Print listing"
                class="w-9 h-9 bg-gray-100 hover:bg-gray-200 rounded-xl flex items-center justify-center transition-colors text-gray-500 print:hidden">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Details Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 p-6 bg-gray-50 border border-gray-100 rounded-2xl mb-6">
          {acf.bedrooms && (
            <div class="text-center">
              <p class="text-2xl mb-1">🛏</p>
              <p class="text-lg font-bold text-gray-900">{acf.bedrooms}</p>
              <p class="text-xs text-gray-500">Bedrooms</p>
            </div>
          )}
          {acf.bathrooms && (
            <div class="text-center">
              <p class="text-2xl mb-1">🚿</p>
              <p class="text-lg font-bold text-gray-900">{acf.bathrooms}</p>
              <p class="text-xs text-gray-500">Bathrooms</p>
            </div>
          )}
          {acf.floor_area && (
            <div class="text-center">
              <p class="text-2xl mb-1">📐</p>
              <p class="text-lg font-bold text-gray-900">{acf.floor_area}</p>
              <p class="text-xs text-gray-500">Floor Area m²</p>
            </div>
          )}
          {acf.lot_area && (
            <div class="text-center">
              <p class="text-2xl mb-1">🌿</p>
              <p class="text-lg font-bold text-gray-900">{acf.lot_area}</p>
              <p class="text-xs text-gray-500">Lot Area m²</p>
            </div>
          )}
        </div>

        <!-- Description -->
        {content && (
          <div class="prose max-w-none text-gray-700 text-sm leading-relaxed mb-8" set:html={content} />
        )}

        <!-- Map -->
        {(acf.location_city || acf.full_address) && (
          <div class="mb-8">
            <h3 class="font-bold text-gray-900 mb-3">Location</h3>
            <div id="property-map"
              data-address={[acf.full_address, acf.location_city, acf.location_province, 'Philippines'].filter(Boolean).join(', ')}
              data-title={title}
              data-price={price}
              class="rounded-2xl overflow-hidden border border-gray-200 h-64 bg-gray-100 flex items-center justify-center">
              <span class="text-gray-400 text-sm">Loading map…</span>
            </div>
          </div>
        )}

        <!-- Neighborhood -->
        <div id="neighborhood-section" class="mb-8 hidden">
          <h3 class="font-bold text-gray-900 mb-3">🗺️ What's Nearby</h3>
          <div id="neighborhood-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-3"></div>
        </div>

        <!-- Related Properties -->
        <div id="related-section" class="print:hidden">
          <h3 class="font-bold text-gray-900 mb-4">Similar Properties</h3>
          <div id="related-grid" class="grid sm:grid-cols-3 gap-4">
            <div class="h-40 bg-gray-100 rounded-xl animate-pulse"></div>
            <div class="h-40 bg-gray-100 rounded-xl animate-pulse"></div>
            <div class="h-40 bg-gray-100 rounded-xl animate-pulse"></div>
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1 print:hidden">
        <div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-6">
          <h3 class="font-bold text-gray-900 mb-4">Contact Agent</h3>

          {acf.agent_name && (
            <a href={`/agent/${acf.agent_name.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}`}
              class="flex items-center gap-3 mb-4 group">
              <div class="w-12 h-12 bg-[#ea580c] rounded-full flex items-center justify-center text-white font-bold text-lg shrink-0">
                {acf.agent_name.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="font-semibold text-gray-900 group-hover:text-[#ea580c] transition-colors">{acf.agent_name}</p>
                <p class="text-xs text-gray-400">View all listings →</p>
              </div>
            </a>
          )}

          {acf.agent_phone && (
            <a href={`tel:${acf.agent_phone}`}
              class="flex items-center justify-center gap-2 w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3 px-4 rounded-xl mb-3 text-sm transition-colors">
              📞 {acf.agent_phone}
            </a>
          )}

          {whatsappPhone && (
            <a href={`https://wa.me/${whatsappPhone}?text=${whatsappMsg}`} target="_blank" rel="noopener"
              class="flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#1da850] text-white font-semibold py-3 px-4 rounded-xl mb-3 text-sm transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Agent
            </a>
          )}

          {acf.agent_email && (
            <a href={`mailto:${acf.agent_email}?subject=Inquiry: ${title}`}
              class="flex items-center justify-center gap-2 w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 px-4 rounded-xl text-sm transition-colors mb-6">
              ✉️ Send Email
            </a>
          )}

          <!-- Quick Inquiry -->
          <div class="pt-4 border-t border-gray-100">
            <p class="text-sm font-semibold text-gray-700 mb-3">Send a Message</p>
            <form id="inquiry-form" class="space-y-3">
              <input type="hidden" name="_subject" value={`Property Inquiry: ${title}`} />
              <input type="hidden" name="property" value={title} />
              <input type="text" name="name" placeholder="Your Name" required
                class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
              <input type="tel" name="phone" placeholder="Phone Number" required
                class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
              <textarea name="message" rows="3" placeholder="I'm interested in this property..."
                class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] resize-none"
              ></textarea>
              <button type="submit" id="inquiry-submit"
                class="w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3 rounded-xl text-sm transition-colors">
                Send Inquiry
              </button>
              <p id="inquiry-success" class="hidden text-green-600 text-xs text-center font-medium">
                ✅ Message sent! We'll contact you soon.
              </p>
            </form>
          </div>
        </div>

        <!-- Mortgage Calculator -->
        <div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-5 mt-4">
          <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            🏦 Mortgage Calculator
          </h3>
          <div class="space-y-3">
            <div>
              <label class="text-xs text-gray-500 mb-1 block">Property Price</label>
              <input type="text" id="mc-price" readonly
                class="w-full px-3 py-2 text-sm bg-gray-50 text-gray-500 border border-gray-200 rounded-xl cursor-default" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-xs text-gray-500 mb-1 block">Down Payment %</label>
                <input type="number" id="mc-down" value="20" min="5" max="80"
                  class="w-full px-3 py-2 text-sm bg-white text-gray-900 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
              </div>
              <div>
                <label class="text-xs text-gray-500 mb-1 block">Interest Rate %</label>
                <input type="number" id="mc-rate" value="6.5" min="1" max="20" step="0.1"
                  class="w-full px-3 py-2 text-sm bg-white text-gray-900 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
              </div>
            </div>
            <div>
              <label class="text-xs text-gray-500 mb-1 block">Loan Term</label>
              <select id="mc-term" class="w-full px-3 py-2 text-sm bg-white text-gray-900 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]">
                <option value="10">10 years</option>
                <option value="15">15 years</option>
                <option value="20" selected>20 years</option>
                <option value="25">25 years</option>
                <option value="30">30 years</option>
              </select>
            </div>
            <div class="bg-orange-50 border border-orange-100 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-500 mb-1">Est. Monthly Payment</p>
              <p id="mc-result" class="text-2xl font-bold text-[#ea580c]">—</p>
              <p class="text-xs text-gray-400 mt-1">Principal + Interest only</p>
            </div>
          </div>
        </div>

        <!-- Schedule a Viewing -->
        <div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-5 mt-4 print:hidden">
          <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">📅 Schedule a Viewing</h3>
          <form id="viewing-form" class="space-y-3">
            <input type="hidden" name="_subject" value={`Viewing Request: ${title}`} />
            <input type="hidden" name="property" value={title} />
            <input type="text" name="name" placeholder="Your Name" required
              class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
            <input type="tel" name="phone" placeholder="Phone Number" required
              class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
            <div class="grid grid-cols-2 gap-2">
              <input type="date" name="viewing_date" required
                class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
              <select name="viewing_time" required
                class="w-full px-3 py-2.5 text-sm bg-gray-50 text-gray-900 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]">
                <option value="">Time</option>
                <option>9:00 AM</option>
                <option>10:00 AM</option>
                <option>11:00 AM</option>
                <option>1:00 PM</option>
                <option>2:00 PM</option>
                <option>3:00 PM</option>
                <option>4:00 PM</option>
                <option>5:00 PM</option>
              </select>
            </div>
            <button type="submit" id="viewing-submit"
              class="w-full bg-gray-900 hover:bg-gray-800 text-white font-bold py-3 rounded-xl text-sm transition-colors">
              Request Viewing
            </button>
            <p id="viewing-success" class="hidden text-green-600 text-xs text-center font-medium">
              ✅ Request sent! We'll confirm your schedule.
            </p>
          </form>
        </div>

        <!-- Recently Viewed -->
        <div id="recently-viewed-section" class="bg-white border border-gray-200 shadow-sm rounded-2xl p-5 mt-4 hidden">
          <h3 class="font-bold text-gray-900 mb-3 text-sm">Recently Viewed</h3>
          <div id="recently-viewed-list" class="space-y-2"></div>
        </div>

      </div>
    </div>
  </div>

  <!-- Similar Properties -->
  <section class="max-w-7xl mx-auto px-4 pb-14 print:hidden">
    <div id="similar-section" class="hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Similar Properties</h2>
      <div id="similar-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" style="display:none"
    class="fixed inset-0 z-[200] bg-black/95 backdrop-blur-md print:hidden"
    onclick="handleLightboxClick(event)">
    <!-- Close -->
    <button onclick="closeLightbox()"
      class="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 text-white rounded-full flex items-center justify-center z-10 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <!-- Prev -->
    <button id="lb-prev" onclick="shiftLightbox(-1)"
      class="absolute left-3 top-1/2 -translate-y-1/2 w-11 h-11 bg-white/10 hover:bg-white/20 text-white rounded-full flex items-center justify-center z-10 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <!-- Next -->
    <button id="lb-next" onclick="shiftLightbox(1)"
      class="absolute right-3 top-1/2 -translate-y-1/2 w-11 h-11 bg-white/10 hover:bg-white/20 text-white rounded-full flex items-center justify-center z-10 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <!-- Image -->
    <div id="lb-content" class="absolute inset-0 flex items-center justify-center p-14">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl" />
    </div>
    <!-- Counter -->
    <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm bg-black/40 backdrop-blur-sm px-4 py-1.5 rounded-full pointer-events-none"></div>
  </div>

  <!-- Sticky mobile CTA bar -->
  <div class="fixed bottom-0 inset-x-0 z-40 bg-white border-t border-gray-200 shadow-xl px-4 py-3 flex gap-2 md:hidden print:hidden">
    {acf.agent_phone && (
      <a href={`tel:${acf.agent_phone}`}
        class="flex-1 flex items-center justify-center gap-1.5 bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3 rounded-xl text-sm transition-colors">
        📞 Call
      </a>
    )}
    {whatsappPhone && (
      <a href={`https://wa.me/${whatsappPhone}?text=${whatsappMsg}`} target="_blank" rel="noopener"
        class="flex-1 flex items-center justify-center gap-1.5 bg-[#25D366] hover:bg-[#1da850] text-white font-semibold py-3 rounded-xl text-sm transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    )}
    <button onclick="document.getElementById('inquiry-form')?.scrollIntoView({behavior:'smooth',block:'center'})"
      class="flex-1 flex items-center justify-center gap-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-xl text-sm transition-colors">
      ✉️ Inquire
    </button>
  </div>
  <div class="h-4 md:hidden print:hidden"></div>

  <Footer />
</Layout>

<script define:vars={{ WP_API, propertyId, propAcf: property.acf, galleryImages, currentSlug: slug, currentTitle: title, currentPrice: price, currentImage: image, similarCity: acf.location_city || '', similarType: acf.property_type || '' }}>
  // Lightbox
  var lbIdx = 0;

  window.openLightbox = function(idx) {
    lbIdx = idx;
    document.getElementById('lightbox').style.display = 'flex';
    document.getElementById('lightbox').style.alignItems = 'center';
    document.getElementById('lightbox').style.justifyContent = 'center';
    document.body.style.overflow = 'hidden';
    updateLightbox();
    var prev = document.getElementById('lb-prev');
    var next = document.getElementById('lb-next');
    if (prev) prev.style.display = galleryImages.length > 1 ? 'flex' : 'none';
    if (next) next.style.display = galleryImages.length > 1 ? 'flex' : 'none';
  };

  window.closeLightbox = function() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  };

  window.shiftLightbox = function(dir) {
    lbIdx = (lbIdx + dir + galleryImages.length) % galleryImages.length;
    updateLightbox();
  };

  window.handleLightboxClick = function(e) {
    var content = document.getElementById('lb-content');
    if (e.target === document.getElementById('lightbox') || e.target === content) {
      window.closeLightbox();
    }
  };

  function updateLightbox() {
    var img = document.getElementById('lightbox-img');
    if (img && galleryImages[lbIdx]) img.src = galleryImages[lbIdx];
    var counter = document.getElementById('lb-counter');
    if (counter) counter.textContent = galleryImages.length > 1 ? (lbIdx + 1) + ' / ' + galleryImages.length : '';
    document.querySelectorAll('.thumb-btn').forEach(function(t) {
      t.style.borderColor = Number(t.dataset.idx) === lbIdx ? '#ea580c' : 'transparent';
    });
  }

  document.addEventListener('keydown', function(e) {
    if (document.getElementById('lightbox').style.display === 'none') return;
    if (e.key === 'Escape') window.closeLightbox();
    if (e.key === 'ArrowLeft') window.shiftLightbox(-1);
    if (e.key === 'ArrowRight') window.shiftLightbox(1);
  });

  // Touch swipe support for lightbox
  (function() {
    var lb = document.getElementById('lightbox');
    var startX = 0;
    lb.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
    }, { passive: true });
    lb.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 48 && galleryImages.length > 1) window.shiftLightbox(dx < 0 ? 1 : -1);
    }, { passive: true });
  })();

  // Back-to-search: show link if user came from /search
  (function() {
    var ref = document.referrer;
    if (ref && ref.includes('/search')) {
      var backEl = document.getElementById('back-to-search');
      if (backEl) { backEl.href = ref; backEl.style.display = 'inline-flex'; }
    }
  })();

  // Similar Properties
  (async function() {
    try {
      var res = await fetch(WP_API + '/property?per_page=20&status=publish');
      var all = await res.json();
      if (!Array.isArray(all)) return;
      var similar = all.filter(function(p) {
        if (p.id === propertyId) return false;
        var city = p.acf?.location_city || '';
        var type = p.acf?.property_type || '';
        return (similarCity && city === similarCity) || (similarType && type === similarType);
      }).slice(0, 3);
      if (similar.length === 0) return;
      var section = document.getElementById('similar-section');
      var grid = document.getElementById('similar-grid');
      if (!section || !grid) return;
      grid.innerHTML = similar.map(function(p) {
        var img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
        var cdnImg = img ? 'https://wsrv.nl/?url=' + encodeURIComponent(img) + '&w=600&q=82&output=webp' : '';
        var pAcf = p.acf || {};
        var pPrice = pAcf.price ? '₱' + Number(pAcf.price).toLocaleString('en-PH') : 'Price on Request';
        var pTitle = p.title?.rendered || 'Property';
        var pSlug = p.slug || p.id;
        var loc = [pAcf.location_city, pAcf.location_province].filter(Boolean).join(', ');
        return '<a href="/property/' + pSlug + '" class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-[#ea580c]/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">' +
          '<div class="relative h-44 overflow-hidden bg-gray-100">' +
            (cdnImg ? '<img src="' + cdnImg + '" alt="' + pTitle + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>' : '<div class="w-full h-full flex items-center justify-center text-4xl opacity-20">🏠</div>') +
            '<div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-black/70 to-transparent pointer-events-none"></div>' +
            '<p class="absolute bottom-2 left-3 text-white font-bold text-sm" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">' + pPrice + '</p>' +
          '</div>' +
          '<div class="p-4 flex flex-col flex-1">' +
            '<h3 class="text-gray-900 font-semibold text-sm leading-snug mb-1 line-clamp-2">' + pTitle + '</h3>' +
            (loc ? '<p class="text-gray-400 text-xs">' + loc + '</p>' : '') +
          '</div>' +
        '</a>';
      }).join('');
      section.classList.remove('hidden');
    } catch(e) {}
  })();

  // Share buttons
  const shareUrl = window.location.href;
  document.getElementById('share-copy')?.addEventListener('click', () => {
    navigator.clipboard.writeText(shareUrl).then(() => {
      const btn = document.getElementById('share-copy');
      btn.style.background = '#dcfce7';
      setTimeout(() => { btn.style.background = ''; }, 2000);
    });
  });
  const fbShare = document.getElementById('share-facebook');
  if (fbShare) fbShare.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
  const waShare = document.getElementById('share-whatsapp');
  if (waShare) waShare.href = `https://wa.me/?text=${encodeURIComponent(document.title + ' ' + shareUrl)}`;

  // Inquiry form
  const form = document.getElementById('inquiry-form');
  const btn = document.getElementById('inquiry-submit');
  const successMsg = document.getElementById('inquiry-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending...';
    btn.disabled = true;
    try {
      await fetch('https://formsubmit.co/ajax/info@philippine-properties.com', {
        method: 'POST',
        body: new FormData(form),
      });
      form.reset();
      successMsg?.classList.remove('hidden');
      btn.classList.add('hidden');
      try {
        var inqs = JSON.parse(localStorage.getItem('sent_inquiries') || '[]');
        inqs.unshift({ title: currentTitle, slug: currentSlug, date: new Date().toISOString() });
        localStorage.setItem('sent_inquiries', JSON.stringify(inqs.slice(0, 20)));
      } catch(e) {}
    } catch {
      btn.textContent = 'Send Inquiry';
      btn.disabled = false;
    }
  });

  // Related properties
  async function loadRelated() {
    const grid = document.getElementById('related-grid');
    const section = document.getElementById('related-section');
    if (!grid) return;
    try {
      const res = await fetch(`${WP_API}/property?_embed&per_page=20&status=publish`);
      const all = await res.json();
      const city = propAcf?.location_city || '';
      const type = propAcf?.property_type || '';
      const related = all
        .filter(p => p.id !== propertyId && ((city && p.acf?.location_city === city) || (type && p.acf?.property_type === type)))
        .slice(0, 3);
      if (related.length === 0) { section?.remove(); return; }
      grid.innerHTML = related.map(p => {
        const img = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
        const pr = p.acf?.price ? '₱' + Number(p.acf.price).toLocaleString('en-PH') : 'Price on Request';
        return `<a href="/property/${p.slug}" class="group bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-md transition-shadow"
          data-city="${p.acf?.location_city || ''}"
          data-price="${pr}"
          data-rel-title="${p.title?.rendered || ''}">
          <div class="h-32 bg-gray-100 overflow-hidden">
            ${img ? `<img src="${img}" alt="${p.title?.rendered}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy"/>` : '<div class="w-full h-full flex items-center justify-center text-3xl opacity-30">🏠</div>'}
          </div>
          <div class="p-3">
            <p class="text-[#ea580c] font-bold text-sm">${pr}</p>
            <p class="text-gray-700 text-xs font-medium mt-1 line-clamp-2">${p.title?.rendered || ''}</p>
          </div>
        </a>`;
      }).join('');
    } catch { section?.remove(); }
  }
  loadRelated();

  // Neighborhood info via OpenStreetMap (no API key)
  async function loadNeighborhood() {
    var section = document.getElementById('neighborhood-section');
    var container = document.getElementById('neighborhood-grid');
    if (!section || !container) return;
    var address = [propAcf?.full_address, propAcf?.location_city, 'Philippines'].filter(Boolean).join(', ');
    if (!address) return;
    try {
      var geoRes = await fetch('https://nominatim.openstreetmap.org/search?q=' + encodeURIComponent(address) + '&format=json&limit=1');
      var geoData = await geoRes.json();
      if (!Array.isArray(geoData) || !geoData[0]) return;
      var lat = parseFloat(geoData[0].lat);
      var lon = parseFloat(geoData[0].lon);
      var types = [
        { tag: 'school', icon: '🏫', label: 'School' },
        { tag: 'hospital', icon: '🏥', label: 'Hospital' },
        { tag: 'bank', icon: '🏦', label: 'Bank' },
        { tag: 'supermarket', icon: '🛒', label: 'Supermarket' },
        { tag: 'pharmacy', icon: '💊', label: 'Pharmacy' },
        { tag: 'restaurant', icon: '🍽', label: 'Restaurant' },
      ];
      var tagFilter = types.map(function(t) { return t.tag; }).join('|');
      var query = '[out:json][timeout:15];(node["amenity"~"' + tagFilter + '"](around:1500,' + lat + ',' + lon + ');way["amenity"~"' + tagFilter + '"](around:1500,' + lat + ',' + lon + '););out center 30;';
      var ovRes = await fetch('https://overpass-api.de/api/interpreter?data=' + encodeURIComponent(query));
      var ovData = await ovRes.json();
      var elements = ovData.elements || [];
      var grouped = {};
      elements.forEach(function(el) {
        var type = el.tags && el.tags.amenity;
        var name = el.tags && el.tags.name;
        if (!name || !type || grouped[type]) return;
        grouped[type] = name;
      });
      var found = types.filter(function(t) { return grouped[t.tag]; });
      if (!found.length) return;
      container.innerHTML = found.map(function(t) {
        return '<div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">' +
          '<span class="text-2xl shrink-0">' + t.icon + '</span>' +
          '<div class="min-w-0">' +
            '<p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">' + t.label + '</p>' +
            '<p class="text-sm text-gray-800 font-medium truncate">' + grouped[t.tag] + '</p>' +
          '</div>' +
        '</div>';
      }).join('');
      section.classList.remove('hidden');
    } catch(e) {}
  }
  loadNeighborhood();

  // View counter (localStorage, resets weekly)
  try {
    var counts = JSON.parse(localStorage.getItem('view_counts') || '{}');
    var week = Math.floor(Date.now() / (7 * 24 * 60 * 60 * 1000));
    var vKey = 'p' + propertyId + '_w' + week;
    counts[vKey] = (counts[vKey] || 0) + 1;
    // prune old week keys
    Object.keys(counts).forEach(function(k) { if (!k.endsWith('_w' + week)) delete counts[k]; });
    localStorage.setItem('view_counts', JSON.stringify(counts));
    var vc = document.getElementById('view-counter');
    if (vc && counts[vKey] > 2) {
      vc.textContent = '👁 ' + counts[vKey] + ' views this week';
      vc.classList.remove('hidden');
    }
  } catch(e) {}

  // Mortgage Calculator
  const rawPrice = propAcf?.price ? parseFloat(propAcf.price) : 0;
  const mcPriceEl = document.getElementById('mc-price');
  if (mcPriceEl) mcPriceEl.value = rawPrice > 0 ? '₱' + rawPrice.toLocaleString('en-PH') : 'Price on Request';

  function calcMortgage() {
    const result = document.getElementById('mc-result');
    if (!result || rawPrice <= 0) return;
    const down = parseFloat(document.getElementById('mc-down').value) || 20;
    const rate = parseFloat(document.getElementById('mc-rate').value) || 6.5;
    const term = parseInt(document.getElementById('mc-term').value) || 20;
    const principal = rawPrice * (1 - down / 100);
    const r = rate / 100 / 12;
    const n = term * 12;
    const monthly = principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    result.textContent = isFinite(monthly) && monthly > 0 ? '₱' + Math.round(monthly).toLocaleString('en-PH') : '—';
  }
  calcMortgage();
  ['mc-down', 'mc-rate', 'mc-term'].forEach(id => document.getElementById(id)?.addEventListener('input', calcMortgage));

  // Recently Viewed
  try {
    var viewed = JSON.parse(localStorage.getItem('recently_viewed') || '[]');
    viewed = viewed.filter(function(v) { return v.id !== propertyId; });
    viewed.unshift({ id: propertyId, slug: currentSlug, title: currentTitle, price: currentPrice, image: currentImage });
    viewed = viewed.slice(0, 10);
    localStorage.setItem('recently_viewed', JSON.stringify(viewed));
    var prev = viewed.slice(1, 6);
    var rvSection = document.getElementById('recently-viewed-section');
    var rvList = document.getElementById('recently-viewed-list');
    if (prev.length > 0 && rvSection && rvList) {
      rvList.innerHTML = prev.map(function(v) {
        return '<a href="/property/' + v.slug + '" class="flex gap-3 items-center group hover:bg-gray-50 -mx-2 px-2 py-1.5 rounded-lg transition-colors">' +
          '<div class="w-14 h-12 rounded-lg overflow-hidden bg-gray-100 shrink-0">' +
          (v.image ? '<img src="' + v.image + '" class="w-full h-full object-cover" loading="lazy"/>' : '<div class="w-full h-full flex items-center justify-center text-lg opacity-30">🏠</div>') +
          '</div>' +
          '<div class="min-w-0">' +
          '<p class="text-xs text-[#ea580c] font-semibold">' + v.price + '</p>' +
          '<p class="text-xs text-gray-600 font-medium truncate group-hover:text-gray-900 transition-colors">' + v.title + '</p>' +
          '</div></a>';
      }).join('');
      rvSection.classList.remove('hidden');
    }
  } catch(e) {}

  // Compare button
  var cmpBtn = document.getElementById('cmp-btn');
  if (cmpBtn) {
    var compareList = function() { return JSON.parse(localStorage.getItem('compare_list') || '[]'); };
    var setCmpActive = function(active) {
      cmpBtn.style.background = active ? '#dcfce7' : '';
      var svg = cmpBtn.querySelector('svg');
      if (svg) svg.style.stroke = active ? '#16a34a' : '';
      cmpBtn.title = active ? 'Remove from compare' : 'Add to compare';
    };
    setCmpActive(compareList().some(function(x) { return x.id === propertyId; }));
    cmpBtn.addEventListener('click', function() {
      var list = compareList();
      var inList = list.some(function(x) { return x.id === propertyId; });
      if (inList) {
        list = list.filter(function(x) { return x.id !== propertyId; });
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(false);
      } else {
        if (list.length >= 3) { alert('You can compare up to 3 properties. Remove one first at /compare'); return; }
        list.push({ id: propertyId, slug: currentSlug, title: currentTitle, price: currentPrice, image: currentImage });
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(true);
        var toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:5rem;right:1.5rem;z-index:1000;background:#1e293b;color:white;font-size:13px;font-weight:600;padding:10px 16px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;';
        toast.innerHTML = '&#10003; Added to compare &nbsp;<a href="/compare" style="color:#fb923c;text-decoration:underline">View &#8594;</a>';
        document.body.appendChild(toast);
        setTimeout(function() { toast.remove(); }, 3500);
      }
    });
  }

  // Leaflet map
  (function() {
    var mapEl = document.getElementById('property-map');
    if (!mapEl) return;
    var address = mapEl.dataset.address;
    var mapTitle = mapEl.dataset.title;
    var mapPrice = mapEl.dataset.price;

    var css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(css);

    var s = document.createElement('script');
    s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    s.onload = async function() {
      try {
        var geoRes = await fetch(
          'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(address),
          { headers: { 'Accept-Language': 'en' } }
        );
        var geoData = await geoRes.json();
        if (!geoData[0]) return;
        var lat = parseFloat(geoData[0].lat);
        var lng = parseFloat(geoData[0].lon);

        mapEl.innerHTML = '';
        var map = L.map(mapEl).setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
          maxZoom: 19
        }).addTo(map);

        // Blue pin for current property
        var currentIcon = L.divIcon({
          html: '<div style="width:22px;height:22px;background:#1d4ed8;border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.4);margin-top:-11px;margin-left:-11px"></div>',
          iconSize: [0,0], iconAnchor: [0,0], className: ''
        });
        L.marker([lat, lng], { icon: currentIcon }).addTo(map)
          .bindPopup('<b>' + mapTitle + '</b><br>' + mapPrice).openPopup();

        // Orange pins for related properties
        var relatedLinks = document.querySelectorAll('#related-grid a[href^="/property/"]');
        var orangeIcon = L.divIcon({
          html: '<div style="width:16px;height:16px;background:#ea580c;border:2px solid white;border-radius:50%;box-shadow:0 1px 5px rgba(0,0,0,0.3);margin-top:-8px;margin-left:-8px"></div>',
          iconSize: [0,0], iconAnchor: [0,0], className: ''
        });
        for (var link of relatedLinks) {
          var city = link.dataset.city;
          var rprice = link.dataset.price;
          var rtitle = link.dataset.relTitle;
          if (!city) continue;
          await new Promise(function(r){ setTimeout(r, 1200); });
          try {
            var rg = await fetch(
              'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(city + ', Philippines'),
              { headers: { 'Accept-Language': 'en' } }
            );
            var rd = await rg.json();
            if (!rd[0]) continue;
            var rlat = parseFloat(rd[0].lat) + (Math.random()-0.5)*0.008;
            var rlng = parseFloat(rd[0].lon) + (Math.random()-0.5)*0.008;
            L.marker([rlat, rlng], { icon: orangeIcon }).addTo(map)
              .bindPopup('<a href="' + link.href + '" style="color:#ea580c;font-weight:600">' + (rtitle || 'Property') + '</a><br>' + (rprice || ''));
          } catch(e) {}
        }
      } catch(e) {}
    };
    document.head.appendChild(s);
  })();

  // Schedule a Viewing form
  var viewingForm = document.getElementById('viewing-form');
  var viewingSubmit = document.getElementById('viewing-submit');
  var viewingSuccess = document.getElementById('viewing-success');
  // Set min date to tomorrow
  var dateInput = viewingForm ? viewingForm.querySelector('input[type="date"]') : null;
  if (dateInput) {
    var tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    dateInput.min = tomorrow.toISOString().split('T')[0];
  }
  if (viewingForm) {
    viewingForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (viewingSubmit) { viewingSubmit.textContent = 'Sending...'; viewingSubmit.disabled = true; }
      try {
        await fetch('https://formsubmit.co/ajax/info@philippine-properties.com', {
          method: 'POST',
          body: new FormData(viewingForm),
        });
        viewingForm.reset();
        if (viewingSuccess) viewingSuccess.classList.remove('hidden');
        if (viewingSubmit) viewingSubmit.classList.add('hidden');
      } catch(err) {
        if (viewingSubmit) { viewingSubmit.textContent = 'Request Viewing'; viewingSubmit.disabled = false; }
      }
    });
  }
</script>

