---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';
---

<Layout title="My Dashboard">
  <Navbar />

  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="w-8 h-8 border-2 border-[#ea580c] border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-gray-400 text-sm">Loading your dashboard...</p>
    </div>
  </div>

  <!-- Dashboard content (hidden until auth confirmed) -->
  <div id="dashboard-content" class="hidden">

    <!-- Header -->
    <div class="bg-gray-50 py-12">
      <div class="max-w-6xl mx-auto px-4 flex items-center gap-5">
        <div id="user-avatar"
          class="w-16 h-16 bg-[#ea580c] rounded-2xl flex items-center justify-center text-2xl font-bold shrink-0 text-white">
        </div>
        <div class="flex-1 min-w-0">
          <h1 id="user-name" class="text-xl font-bold text-gray-900 truncate"></h1>
          <p id="user-email" class="text-gray-500 text-sm mt-0.5 truncate"></p>
        </div>
        <button id="logout-btn"
          class="text-sm border border-gray-200 hover:border-gray-500 text-gray-700 px-4 py-2 rounded-lg transition-colors shrink-0">
          Logout
        </button>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12">

      <!-- Stats Row -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-saved" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Saved</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-submitted" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Submitted</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p class="text-3xl font-bold text-[#ea580c]">—</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Views</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-inquiries" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Inquiries</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="grid sm:grid-cols-3 gap-4 mb-14">
        {[
          { href: '/search', icon: '🔍', label: 'Search Properties', sub: 'Browse all listings' },
          { href: '/list-property', icon: '➕', label: 'List a Property', sub: 'Submit your property' },
          { href: '/contact', icon: '💬', label: 'Contact Us', sub: 'Get in touch with us' },
        ].map(item => (
          <a href={item.href}
            class="bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-md hover:border-[#ea580c] transition-all text-center group">
            <span class="text-3xl">{item.icon}</span>
            <p class="font-semibold text-gray-900 mt-3 group-hover:text-[#ea580c] transition-colors">{item.label}</p>
            <p class="text-gray-400 text-xs mt-1">{item.sub}</p>
          </a>
        ))}
      </div>

      <!-- My Inquiries -->
      <div class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">My Inquiries Sent</h2>
        </div>
        <div id="inquiries-list" class="space-y-3"></div>
        <div id="no-inquiries" class="hidden text-center py-12 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-4xl mb-3">💬</p>
          <p class="text-gray-500 font-medium">No inquiries sent yet</p>
          <p class="text-gray-400 text-sm mt-1">Send an inquiry from any property page and it will appear here</p>
        </div>
      </div>

      <!-- My Submitted Listings -->
      <div class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">My Submitted Listings</h2>
          <a href="/list-property" class="text-[#ea580c] text-sm font-semibold hover:underline">+ Submit New →</a>
        </div>
        <div id="submitted-list" class="space-y-3"></div>
        <div id="no-submitted" class="hidden text-center py-12 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-4xl mb-3">📋</p>
          <p class="text-gray-500 font-medium">No listings submitted yet</p>
          <p class="text-gray-400 text-sm mt-1 mb-6">Submit a property and track its review status here</p>
          <a href="/list-property"
            class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
            + List a Property
          </a>
        </div>
      </div>

      <!-- Saved Properties -->
      <div>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">Saved Properties</h2>
          <div class="flex items-center gap-4">
            <a href="/saved" class="text-[#ea580c] text-sm font-semibold hover:underline">View all saved →</a>
          </div>
        </div>

        <div id="saved-list" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

        <div id="no-saved" class="hidden text-center py-16 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-5xl mb-4">🏠</p>
          <p class="text-gray-500 font-medium">No saved properties yet</p>
          <p class="text-gray-400 text-sm mt-1 mb-6">Tap the ♡ icon on any listing to save it here</p>
          <a href="/search"
            class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
            Browse Properties
          </a>
        </div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ WP_API }} is:inline>
  var loading = document.getElementById('auth-loading');
  var content = document.getElementById('dashboard-content');
  var user = window.ppAuth && window.ppAuth.getUser();

  if (!user) { window.location.href = '/login'; }
  else { showDashboard(user); }

  document.getElementById('logout-btn') && document.getElementById('logout-btn').addEventListener('click', function() {
    window.ppAuth && window.ppAuth.logout();
  });

  async function showDashboard(user) {
    loading?.classList.add('hidden');
    content?.classList.remove('hidden');

    const name = user.name || user.email.split('@')[0];
    document.getElementById('user-avatar').textContent = name[0].toUpperCase();
    document.getElementById('user-name').textContent = name;
    document.getElementById('user-email').textContent = user.email;

    // Stats
    const saved = JSON.parse(localStorage.getItem('saved_properties') || '[]');
    const submitted = JSON.parse(localStorage.getItem('submitted_listings') || '[]');
    const inquiries = JSON.parse(localStorage.getItem('sent_inquiries') || '[]');
    document.getElementById('stat-saved').textContent = saved.length;
    document.getElementById('stat-submitted').textContent = submitted.length;
    document.getElementById('stat-inquiries').textContent = inquiries.length;

    // Inquiries sent
    const inquiriesList = document.getElementById('inquiries-list');
    const noInquiries = document.getElementById('no-inquiries');
    if (inquiries.length === 0) {
      noInquiries?.classList.remove('hidden');
    } else {
      inquiries.slice(0, 10).forEach(item => {
        const el = document.createElement('div');
        el.className = 'flex items-center justify-between bg-white border border-gray-100 rounded-xl px-5 py-4';
        el.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="text-gray-900 font-semibold text-sm truncate">${item.title || 'Property'}</p>
            <p class="text-gray-400 text-xs mt-0.5">${new Date(item.date).toLocaleDateString('en-PH', {month:'short',day:'numeric',year:'numeric'})}</p>
          </div>
          <a href="/property/${item.slug}" class="text-[#ea580c] text-xs font-semibold hover:underline shrink-0 ml-4">View →</a>`;
        inquiriesList?.appendChild(el);
      });
    }

    // Submitted listings
    const submittedList = document.getElementById('submitted-list');
    const noSubmitted = document.getElementById('no-submitted');
    if (submitted.length === 0) {
      noSubmitted?.classList.remove('hidden');
    } else {
      submitted.slice().reverse().forEach(item => {
        const el = document.createElement('div');
        el.className = 'flex items-center justify-between bg-white border border-gray-100 rounded-xl px-5 py-4';
        const statusColor = item.status === 'approved' ? 'text-green-400 bg-green-400/10' : 'text-yellow-400 bg-yellow-400/10';
        const statusLabel = item.status === 'approved' ? 'Live' : 'Pending Review';
        el.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="text-gray-900 font-semibold text-sm truncate">${item.title || 'Property Listing'}</p>
            <p class="text-gray-400 text-xs mt-0.5">${item.city ? item.city + ' · ' : ''}Ref: ${item.ref}</p>
          </div>
          <div class="flex items-center gap-3 ml-4 shrink-0">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full ${statusColor}">${statusLabel}</span>
            <span class="text-gray-300 text-xs">${new Date(item.date).toLocaleDateString('en-PH', {month:'short', day:'numeric', year:'numeric'})}</span>
          </div>`;
        submittedList?.appendChild(el);
      });
    }
    const savedList = document.getElementById('saved-list');
    const noSaved = document.getElementById('no-saved');

    if (saved.length === 0) {
      noSaved?.classList.remove('hidden');
      return;
    }

    for (const id of saved) {
      try {
        const res = await fetch(`${WP_API}/property/${id}?_embed`);
        const prop = await res.json();
        const image = prop._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
        const price = prop.acf?.price ? `₱${Number(prop.acf.price).toLocaleString()}` : 'Price on Request';
        const city = [prop.acf?.location_city, prop.acf?.location_province].filter(Boolean).join(', ');

        const card = document.createElement('div');
        card.className = 'bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow';
        card.dataset.propertyId = id;
        card.innerHTML = `
          <div class="h-48 bg-gray-50 overflow-hidden relative">
            ${image
              ? `<img src="${image}" alt="${prop.title?.rendered}" class="w-full h-full object-cover" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center text-5xl">🏠</div>`}
            <button class="unsave-btn absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow text-red-500 hover:bg-gray-100 transition-colors" data-id="${id}">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </button>
          </div>
          <div class="p-4">
            <p class="font-bold text-[#ea580c] text-lg">${price}</p>
            <p class="font-semibold text-gray-700 mt-1 text-sm group-hover:text-gray-900">${prop.title?.rendered || ''}</p>
            ${city ? `<p class="text-gray-400 text-xs mt-1">📍 ${city}</p>` : ''}
            <a href="/property/${prop.slug}" class="mt-3 inline-block text-[#ea580c] font-semibold text-sm hover:underline">View Details →</a>
          </div>
        `;
        savedList?.appendChild(card);

        card.querySelector('.unsave-btn')?.addEventListener('click', () => {
          let s = JSON.parse(localStorage.getItem('saved_properties') || '[]');
          s = s.filter(x => x !== id);
          localStorage.setItem('saved_properties', JSON.stringify(s));
          card.remove();
          if (s.length === 0) noSaved?.classList.remove('hidden');
        });
      } catch {}
    }
  }
</script>
