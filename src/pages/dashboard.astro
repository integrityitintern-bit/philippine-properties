---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';
---

<Layout title="My Dashboard">
  <Navbar />

  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="w-8 h-8 border-2 border-[#ea580c] border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-gray-400 text-sm">Loading your dashboard...</p>
    </div>
  </div>

  <!-- Dashboard content (hidden until auth confirmed) -->
  <div id="dashboard-content" class="hidden">

    <!-- Header -->
    <div class="bg-gray-50 py-12">
      <div class="max-w-6xl mx-auto px-4 flex items-center gap-5">
        <div id="user-avatar"
          class="w-16 h-16 bg-[#ea580c] rounded-2xl flex items-center justify-center text-2xl font-bold shrink-0 text-white">
        </div>
        <div class="flex-1 min-w-0">
          <h1 id="user-name" class="text-xl font-bold text-gray-900 truncate"></h1>
          <p id="user-email" class="text-gray-500 text-sm mt-0.5 truncate"></p>
        </div>
        <button id="logout-btn"
          class="text-sm border border-gray-200 hover:border-gray-500 text-gray-700 px-4 py-2 rounded-lg transition-colors shrink-0">
          Logout
        </button>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12">

      <!-- Stats Row -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-saved" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Saved</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-submitted" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Submitted</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p class="text-3xl font-bold text-[#ea580c]">—</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Views</p>
        </div>
        <div class="bg-white border border-gray-100 shadow-sm rounded-2xl p-5 text-center">
          <p id="stat-inquiries" class="text-3xl font-bold text-[#ea580c]">0</p>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-wide">Inquiries</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="grid sm:grid-cols-3 gap-4 mb-14">
        {[
          { href: '/search', icon: '🔍', label: 'Search Properties', sub: 'Browse all listings' },
          { href: '/list-property', icon: '➕', label: 'List a Property', sub: 'Submit your property' },
          { href: '/contact', icon: '💬', label: 'Contact Us', sub: 'Get in touch with us' },
        ].map(item => (
          <a href={item.href}
            class="bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-md hover:border-[#ea580c] transition-all text-center group">
            <span class="text-3xl">{item.icon}</span>
            <p class="font-semibold text-gray-900 mt-3 group-hover:text-[#ea580c] transition-colors">{item.label}</p>
            <p class="text-gray-400 text-xs mt-1">{item.sub}</p>
          </a>
        ))}
      </div>

      <!-- Saved Searches -->
      <div id="saved-searches-section" class="hidden mb-14">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">Saved Searches</h2>
          <a href="/search" class="text-[#ea580c] text-sm font-semibold hover:underline">Search →</a>
        </div>
        <div id="saved-searches-dashboard" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- My Inquiries -->
      <div class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">My Inquiries Sent</h2>
        </div>
        <div id="inquiries-list" class="space-y-3"></div>
        <div id="no-inquiries" class="hidden text-center py-12 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-4xl mb-3">💬</p>
          <p class="text-gray-500 font-medium">No inquiries sent yet</p>
          <p class="text-gray-400 text-sm mt-1">Send an inquiry from any property page and it will appear here</p>
        </div>
      </div>

      <!-- My Submitted Listings -->
      <div class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">My Submitted Listings</h2>
          <a href="/list-property" class="text-[#ea580c] text-sm font-semibold hover:underline">+ Submit New →</a>
        </div>
        <div id="submitted-list" class="space-y-3"></div>
        <div id="no-submitted" class="hidden text-center py-12 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-4xl mb-3">📋</p>
          <p class="text-gray-500 font-medium">No listings submitted yet</p>
          <p class="text-gray-400 text-sm mt-1 mb-6">Submit a property and track its review status here</p>
          <a href="/list-property"
            class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
            + List a Property
          </a>
        </div>
      </div>

      <!-- Saved Properties -->
      <div>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-900">Saved Properties</h2>
          <div class="flex items-center gap-4">
            <a href="/saved" class="text-[#ea580c] text-sm font-semibold hover:underline">View all saved →</a>
          </div>
        </div>

        <div id="saved-list" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

        <div id="no-saved" class="hidden text-center py-16 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-5xl mb-4">🏠</p>
          <p class="text-gray-500 font-medium">No saved properties yet</p>
          <p class="text-gray-400 text-sm mt-1 mb-6">Tap the ♡ icon on any listing to save it here</p>
          <a href="/search"
            class="inline-block bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
            Browse Properties
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Edit Property Modal -->
  <div id="edit-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeEditModal()"></div>
    <div class="absolute inset-0 flex items-start justify-center p-4 overflow-y-auto pointer-events-none">
      <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl my-8 pointer-events-auto">
        <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
          <h2 class="text-lg font-bold text-gray-900">Edit Property</h2>
          <button onclick="closeEditModal()" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-400 hover:text-gray-700 transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <form id="edit-form" class="px-6 py-5 space-y-4">
          <input type="hidden" id="edit-wp-id" />

          <!-- Photo -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Photo</label>
            <div class="flex items-center gap-4">
              <div class="w-20 h-20 rounded-xl overflow-hidden bg-gray-100 shrink-0 flex items-center justify-center">
                <img id="edit-photo-img" src="" alt="" class="w-full h-full object-cover hidden" />
                <span id="edit-photo-placeholder" class="text-3xl">🏠</span>
              </div>
              <div class="flex-1">
                <input type="file" id="edit-photo-input" accept="image/*"
                  class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-[#ea580c] hover:file:bg-orange-100 cursor-pointer" />
                <p class="text-xs text-gray-400 mt-1">JPG, PNG or WEBP. Upload a new image to replace the current one.</p>
              </div>
            </div>
          </div>

          <!-- Title -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Title</label>
            <input type="text" id="edit-title" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="Property title" />
          </div>

          <!-- Price + Listing Type -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Price (₱)</label>
              <input type="number" id="edit-price" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. 5000000" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Listing Type</label>
              <select id="edit-listing-type" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors bg-white">
                <option value="">Select...</option>
                <option value="For Sale">For Sale</option>
                <option value="For Rent">For Rent</option>
              </select>
            </div>
          </div>

          <!-- Property Type + Beds -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Property Type</label>
              <select id="edit-property-type" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors bg-white">
                <option value="">Select...</option>
                <option value="House">House</option>
                <option value="Condo">Condo</option>
                <option value="Lot">Lot</option>
                <option value="Townhouse">Townhouse</option>
                <option value="Apartment">Apartment</option>
                <option value="Commercial">Commercial</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Bedrooms</label>
              <input type="number" id="edit-beds" min="0" max="20" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. 3" />
            </div>
          </div>

          <!-- Baths + Areas -->
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Bathrooms</label>
              <input type="number" id="edit-baths" min="0" max="20" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. 2" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Floor Area (sqm)</label>
              <input type="number" id="edit-floor-area" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. 120" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Lot Area (sqm)</label>
              <input type="number" id="edit-lot-area" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. 200" />
            </div>
          </div>

          <!-- Address -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Address</label>
            <input type="text" id="edit-address" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="Street address" />
          </div>

          <!-- City + Province -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">City</label>
              <input type="text" id="edit-city" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. Makati" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Province</label>
              <input type="text" id="edit-province" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" placeholder="e.g. Metro Manila" />
            </div>
          </div>

          <!-- Description -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Description</label>
            <textarea id="edit-description" rows="4" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#ea580c] transition-colors resize-none" placeholder="Describe the property..."></textarea>
          </div>

          <!-- Error -->
          <div id="edit-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>

          <!-- Actions -->
          <div class="flex items-center gap-3 pt-1 pb-1">
            <button type="submit" id="edit-save-btn" class="flex-1 bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-2.5 rounded-xl text-sm transition-colors">
              Save Changes
            </button>
            <button type="button" onclick="closeEditModal()" class="px-6 py-2.5 border border-gray-200 hover:border-gray-400 text-gray-700 font-semibold rounded-xl text-sm transition-colors">
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ WP_API }} is:inline>
  var loading = document.getElementById('auth-loading');
  var content = document.getElementById('dashboard-content');
  var user = window.ppAuth && window.ppAuth.getUser();

  if (!user) { window.location.href = '/login'; }
  else { showDashboard(user); }

  document.getElementById('logout-btn') && document.getElementById('logout-btn').addEventListener('click', function() {
    window.ppAuth && window.ppAuth.logout();
  });

  async function showDashboard(user) {
    loading?.classList.add('hidden');
    content?.classList.remove('hidden');

    const name = user.name || user.email.split('@')[0];
    document.getElementById('user-avatar').textContent = name[0].toUpperCase();
    document.getElementById('user-name').textContent = name;
    document.getElementById('user-email').textContent = user.email;

    // Stats
    const saved = JSON.parse(localStorage.getItem('saved_properties') || '[]');
    const submitted = JSON.parse(localStorage.getItem('submitted_listings') || '[]');
    const inquiries = JSON.parse(localStorage.getItem('sent_inquiries') || '[]');
    document.getElementById('stat-saved').textContent = saved.length;
    document.getElementById('stat-submitted').textContent = submitted.length;
    document.getElementById('stat-inquiries').textContent = inquiries.length;

    // Saved searches
    const savedSearches = JSON.parse(localStorage.getItem('saved_searches') || '[]');
    const ssSection = document.getElementById('saved-searches-section');
    const ssDashboard = document.getElementById('saved-searches-dashboard');
    if (savedSearches.length > 0 && ssSection && ssDashboard) {
      ssSection.classList.remove('hidden');
      ssDashboard.innerHTML = savedSearches.map(function(s) {
        const params = new URLSearchParams();
        if (s.filters.city) params.set('city', s.filters.city);
        if (s.filters.listingType) params.set('listing_type', s.filters.listingType);
        if (s.filters.propertyType) params.set('property_type', s.filters.propertyType);
        return '<a href="/search?' + params.toString() + '" class="inline-flex items-center gap-1.5 bg-orange-50 border border-orange-200 hover:border-[#ea580c] text-[#ea580c] text-xs font-semibold px-4 py-2 rounded-full transition-colors">🔍 ' + s.label + '</a>';
      }).join('');
    }

    // Inquiries sent
    const inquiriesList = document.getElementById('inquiries-list');
    const noInquiries = document.getElementById('no-inquiries');
    if (inquiries.length === 0) {
      noInquiries?.classList.remove('hidden');
    } else {
      inquiries.slice(0, 10).forEach(item => {
        const el = document.createElement('div');
        el.className = 'flex items-center justify-between bg-white border border-gray-100 rounded-xl px-5 py-4';
        el.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="text-gray-900 font-semibold text-sm truncate">${item.title || 'Property'}</p>
            <p class="text-gray-400 text-xs mt-0.5">${new Date(item.date).toLocaleDateString('en-PH', {month:'short',day:'numeric',year:'numeric'})}</p>
          </div>
          <a href="/property/${item.slug}" class="text-[#ea580c] text-xs font-semibold hover:underline shrink-0 ml-4">View →</a>`;
        inquiriesList?.appendChild(el);
      });
    }

    // Submitted listings — check real WP status for each
    const submittedList = document.getElementById('submitted-list');
    const noSubmitted = document.getElementById('no-submitted');
    if (submitted.length === 0) {
      noSubmitted?.classList.remove('hidden');
    } else {
      for (const item of submitted.slice().reverse()) {
        let statusLabel = 'Under Review';
        let statusColor = 'text-yellow-600 bg-yellow-50';
        let viewLink = '';
        if (item.wpId) {
          try {
            const wpRes = await fetch(`${WP_API}/property/${item.wpId}?_fields=id,slug,status`);
            if (wpRes.ok) {
              const wpData = await wpRes.json();
              if (wpData.status === 'publish') {
                statusLabel = 'Live';
                statusColor = 'text-green-600 bg-green-50';
                viewLink = `<a href="/property/${wpData.slug}" class="text-[#ea580c] text-xs font-semibold hover:underline ml-2">View →</a>`;
              }
            }
          } catch {}
        }
        const editButton = item.wpId
          ? `<button onclick="openEditModal(${item.wpId})" class="flex items-center gap-1 text-[#ea580c] text-xs font-semibold hover:underline ml-1"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>Edit</button>`
          : '';
        const el = document.createElement('div');
        el.className = 'flex items-center justify-between bg-white border border-gray-100 rounded-xl px-5 py-4';
        el.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="text-gray-900 font-semibold text-sm truncate">${item.title || 'Property Listing'}</p>
            <p class="text-gray-400 text-xs mt-0.5">${item.city ? item.city + ' · ' : ''}Ref: ${item.ref}</p>
          </div>
          <div class="flex items-center gap-3 ml-4 shrink-0">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full ${statusColor}">${statusLabel}</span>
            <span class="text-gray-300 text-xs">${new Date(item.date).toLocaleDateString('en-PH', {month:'short', day:'numeric', year:'numeric'})}</span>
            ${viewLink}
            ${editButton}
          </div>`;
        submittedList?.appendChild(el);
      }
    }
    const savedList = document.getElementById('saved-list');
    const noSaved = document.getElementById('no-saved');

    if (saved.length === 0) {
      noSaved?.classList.remove('hidden');
      return;
    }


    for (const id of saved) {
      try {
        const res = await fetch(`${WP_API}/property/${id}?_embed`);
        const prop = await res.json();
        const image = prop._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
        const price = prop.acf?.price ? `₱${Number(prop.acf.price).toLocaleString()}` : 'Price on Request';
        const city = [prop.acf?.location_city, prop.acf?.location_province].filter(Boolean).join(', ');

        const card = document.createElement('div');
        card.className = 'bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow';
        card.dataset.propertyId = id;
        card.innerHTML = `
          <div class="h-48 bg-gray-50 overflow-hidden relative">
            ${image
              ? `<img src="${image}" alt="${prop.title?.rendered}" class="w-full h-full object-cover" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center text-5xl">🏠</div>`}
            <button class="unsave-btn absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow text-red-500 hover:bg-gray-100 transition-colors" data-id="${id}">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </button>
          </div>
          <div class="p-4">
            <p class="font-bold text-[#ea580c] text-lg">${price}</p>
            <p class="font-semibold text-gray-700 mt-1 text-sm group-hover:text-gray-900">${prop.title?.rendered || ''}</p>
            ${city ? `<p class="text-gray-400 text-xs mt-1">📍 ${city}</p>` : ''}
            <a href="/property/${prop.slug}" class="mt-3 inline-block text-[#ea580c] font-semibold text-sm hover:underline">View Details →</a>
          </div>
        `;
        savedList?.appendChild(card);

        card.querySelector('.unsave-btn')?.addEventListener('click', () => {
          let s = JSON.parse(localStorage.getItem('saved_properties') || '[]');
          s = s.filter(x => x !== id);
          localStorage.setItem('saved_properties', JSON.stringify(s));
          card.remove();
          if (s.length === 0) noSaved?.classList.remove('hidden');
        });
      } catch {}
    }
  }

  // ── Edit Property Modal ─────────────────────────────────────────────────────
  var _editWpId = null;

  window.openEditModal = async function(wpId) {
    _editWpId = wpId;
    document.getElementById('edit-wp-id').value = wpId;
    document.getElementById('edit-error').classList.add('hidden');
    document.getElementById('edit-save-btn').textContent = 'Save Changes';
    document.getElementById('edit-save-btn').disabled = false;
    document.getElementById('edit-form').reset();

    // Show modal with loading state
    document.getElementById('edit-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Fetch property data
    try {
      const res = await fetch(`${WP_API}/property/${wpId}?_embed&acf_format=standard`);
      if (!res.ok) throw new Error('Could not load property details.');
      const data = await res.json();
      const acf = data.acf || {};

      document.getElementById('edit-title').value = (data.title?.rendered || '').replace(/&amp;/g,'&').replace(/&#039;/g,"'").replace(/&quot;/g,'"').replace(/&lt;/g,'<').replace(/&gt;/g,'>');
      document.getElementById('edit-price').value = acf.price || '';
      document.getElementById('edit-listing-type').value = acf.listing_type || '';
      document.getElementById('edit-property-type').value = acf.property_type || '';
      document.getElementById('edit-beds').value = acf.bedrooms || '';
      document.getElementById('edit-baths').value = acf.bathrooms || '';
      document.getElementById('edit-floor-area').value = acf.floor_area || '';
      document.getElementById('edit-lot-area').value = acf.lot_area || '';
      document.getElementById('edit-address').value = acf.address || acf.location_address || '';
      document.getElementById('edit-city').value = acf.location_city || '';
      document.getElementById('edit-province').value = acf.location_province || '';
      document.getElementById('edit-description').value = acf.description || '';

      // Photo preview
      const photoUrl = data._embedded?.['wp:featuredmedia']?.[0]?.source_url || acf.photo_1 || '';
      const img = document.getElementById('edit-photo-img');
      const placeholder = document.getElementById('edit-photo-placeholder');
      if (photoUrl) {
        img.src = photoUrl;
        img.classList.remove('hidden');
        placeholder.classList.add('hidden');
      } else {
        img.classList.add('hidden');
        placeholder.classList.remove('hidden');
      }
    } catch(e) {
      const errEl = document.getElementById('edit-error');
      errEl.textContent = e.message || 'Could not load property details. Please try again.';
      errEl.classList.remove('hidden');
    }
  };

  window.closeEditModal = function() {
    document.getElementById('edit-modal').classList.add('hidden');
    document.body.style.overflow = '';
    _editWpId = null;
  };

  document.getElementById('edit-photo-input')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
      const img = document.getElementById('edit-photo-img');
      const placeholder = document.getElementById('edit-photo-placeholder');
      img.src = ev.target.result;
      img.classList.remove('hidden');
      placeholder.classList.add('hidden');
    };
    reader.readAsDataURL(file);
  });

  document.getElementById('edit-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('edit-save-btn');
    const errEl = document.getElementById('edit-error');
    errEl.classList.add('hidden');
    btn.textContent = 'Saving...';
    btn.disabled = true;

    const user = window.ppAuth && window.ppAuth.getUser();
    const token = user?.token;
    if (!token) {
      errEl.textContent = 'Session expired. Please log in again.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Save Changes';
      btn.disabled = false;
      return;
    }

    const wpId = document.getElementById('edit-wp-id').value;
    try {
      // Upload new photo if selected
      let featuredMediaId = null;
      const photoFile = document.getElementById('edit-photo-input').files[0];
      if (photoFile) {
        btn.textContent = 'Uploading photo...';
        const fd = new FormData();
        fd.append('file', photoFile);
        const mediaRes = await fetch(`${WP_API}/media`, {
          method: 'POST',
          headers: { 'Authorization': 'Bearer ' + token },
          body: fd,
        });
        if (mediaRes.ok) {
          const mediaData = await mediaRes.json();
          featuredMediaId = mediaData.id;
        }
      }

      btn.textContent = 'Saving...';

      // Build payload
      const title = document.getElementById('edit-title').value.trim();
      const acf = {};
      const fields = {
        price: 'edit-price', listing_type: 'edit-listing-type',
        property_type: 'edit-property-type', bedrooms: 'edit-beds',
        bathrooms: 'edit-baths', floor_area: 'edit-floor-area',
        lot_area: 'edit-lot-area', description: 'edit-description',
      };
      for (const [key, id] of Object.entries(fields)) {
        const val = document.getElementById(id).value.trim();
        if (val) acf[key] = val;
      }
      const addr = document.getElementById('edit-address').value.trim();
      const city = document.getElementById('edit-city').value.trim();
      const province = document.getElementById('edit-province').value.trim();
      if (addr) { acf.address = addr; acf.location_address = addr; }
      if (city) acf.location_city = city;
      if (province) acf.location_province = province;

      const body = {};
      if (title) body.title = title;
      if (Object.keys(acf).length) body.acf = acf;
      if (featuredMediaId) body.featured_media = featuredMediaId;

      const res = await fetch(`${WP_API}/property/${wpId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || 'Update failed. You may not have permission to edit this property.');
      }

      // Update localStorage title/city
      const stored = JSON.parse(localStorage.getItem('submitted_listings') || '[]');
      const idx = stored.findIndex(x => String(x.wpId) === String(wpId));
      if (idx !== -1) {
        if (title) stored[idx].title = title;
        if (city) stored[idx].city = city;
        localStorage.setItem('submitted_listings', JSON.stringify(stored));
      }

      window.closeEditModal();
      window.location.reload();
    } catch(err) {
      errEl.textContent = err.message || 'Something went wrong. Please try again.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Save Changes';
      btn.disabled = false;
    }
  });
</script>
