---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="List Your Property">
  <Navbar />

  <div class="max-w-3xl mx-auto px-4 py-12">

    <!-- Header -->
    <div class="text-center mb-10">
      <span class="inline-block bg-yellow-400 text-[#ea580c] text-xs font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">Free Listing</span>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">List Your Property</h1>
      <p class="text-gray-500">Reach thousands of buyers and renters across the Philippines.</p>
    </div>

    <!-- Progress Steps -->
    <div class="flex items-center justify-center gap-2 mb-10" id="step-indicators">
      {['Property Info', 'Details', 'Photos', 'Contact'].map((label, i) => (
        <div class="flex items-center gap-2">
          <div class={`step-dot flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold transition-colors ${i === 0 ? 'bg-[#ea580c] text-white' : 'bg-gray-200 text-gray-500'}`} data-step={i + 1}>
            {i + 1}
          </div>
          <span class={`hidden sm:block text-xs font-medium ${i === 0 ? 'text-[#ea580c]' : 'text-gray-400'}`}>{label}</span>
          {i < 3 && <div class="w-6 h-px bg-gray-200 hidden sm:block"></div>}
        </div>
      ))}
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">

      <!-- Step 1: Property Info -->
      <div id="step-1" class="step-content">
        <h2 class="text-lg font-bold text-gray-900 mb-6">Step 1: Property Information</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Listing Type *</label>
              <select id="p-listing-type" class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white">
                <option value="">Select...</option>
                <option>For Sale</option>
                <option>For Rent</option>
                <option>Pre-Selling</option>
              </select>
            </div>
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Property Type *</label>
              <select id="p-property-type" class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] bg-white">
                <option value="">Select...</option>
                <option>House</option>
                <option>Condo</option>
                <option>Townhouse</option>
                <option>Apartment</option>
                <option>Studio</option>
                <option>Land & Lot</option>
                <option>Commercial</option>
                <option>Warehouse</option>
                <option>Office Space</option>
              </select>
            </div>
          </div>
          <div>
            <label class="text-xs font-medium text-gray-600 mb-1 block">Property Title / Listing Name *</label>
            <input type="text" id="p-title" placeholder="e.g. 3BR House for Sale in Makati"
              class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
          </div>
          <div>
            <label class="text-xs font-medium text-gray-600 mb-1 block">Price (PHP) *</label>
            <input type="number" id="p-price" placeholder="e.g. 5000000"
              class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">City *</label>
              <input type="text" id="p-city" placeholder="e.g. Makati"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Province / Region</label>
              <input type="text" id="p-province" placeholder="e.g. Metro Manila"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
          </div>
        </div>
        <button onclick="goToStep(2)" class="mt-6 w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3.5 rounded-xl transition-colors">
          Continue →
        </button>
      </div>

      <!-- Step 2: Details -->
      <div id="step-2" class="step-content hidden">
        <h2 class="text-lg font-bold text-gray-900 mb-6">Step 2: Property Details</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Bedrooms</label>
              <input type="number" id="p-bedrooms" min="0" placeholder="0"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Bathrooms</label>
              <input type="number" id="p-bathrooms" min="0" placeholder="0"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Floor Area (m²)</label>
              <input type="number" id="p-floor-area" min="0" placeholder="0"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
          </div>
          <div>
            <label class="text-xs font-medium text-gray-600 mb-1 block">Full Address</label>
            <input type="text" id="p-address" placeholder="Street address, subdivision, barangay"
              class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
          </div>
          <div>
            <label class="text-xs font-medium text-gray-600 mb-1 block">Property Description</label>
            <textarea id="p-description" rows="5" placeholder="Describe the property — features, amenities, nearby landmarks..."
              class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] resize-none"
            ></textarea>
          </div>
        </div>
        <div class="flex gap-3 mt-6">
          <button onclick="goToStep(1)" class="flex-1 border-2 border-gray-200 text-gray-600 font-semibold py-3 rounded-xl hover:border-gray-300 transition-colors">
            ← Back
          </button>
          <button onclick="goToStep(3)" class="flex-1 bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3 rounded-xl transition-colors">
            Continue →
          </button>
        </div>
      </div>

      <!-- Step 3: Photos -->
      <div id="step-3" class="step-content hidden">
        <h2 class="text-lg font-bold text-gray-900 mb-2">Step 3: Property Photos</h2>
        <p class="text-gray-500 text-sm mb-6">Upload up to 10 photos. First photo will be the main listing image.</p>

        <div id="photo-upload-area" class="border-2 border-dashed border-gray-200 rounded-2xl p-8 text-center hover:border-[#ea580c] transition-colors cursor-pointer" onclick="document.getElementById('photo-input').click()">
          <p class="text-4xl mb-3">📸</p>
          <p class="text-gray-700 font-semibold text-sm">Click to upload photos</p>
          <p class="text-gray-400 text-xs mt-1">JPG, PNG up to 10MB each</p>
          <input type="file" id="photo-input" accept="image/*" multiple class="hidden" />
        </div>

        <div id="photo-preview" class="grid grid-cols-3 gap-3 mt-4"></div>
        <p id="photo-status" class="text-xs text-gray-400 mt-2 text-center"></p>

        <div class="flex gap-3 mt-6">
          <button onclick="goToStep(2)" class="flex-1 border-2 border-gray-200 text-gray-600 font-semibold py-3 rounded-xl hover:border-gray-300 transition-colors">
            ← Back
          </button>
          <button onclick="goToStep(4)" class="flex-1 bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3 rounded-xl transition-colors">
            Continue →
          </button>
        </div>
      </div>

      <!-- Step 4: Contact -->
      <div id="step-4" class="step-content hidden">
        <h2 class="text-lg font-bold text-gray-900 mb-6">Step 4: Your Contact Details</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Full Name *</label>
              <input type="text" id="p-name" placeholder="Your full name"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-600 mb-1 block">Phone Number *</label>
              <input type="tel" id="p-phone" placeholder="+63 9XX XXX XXXX"
                class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
              />
            </div>
          </div>
          <div>
            <label class="text-xs font-medium text-gray-600 mb-1 block">Email Address *</label>
            <input type="email" id="p-email" placeholder="your@email.com"
              class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
            />
          </div>
          <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-xs text-yellow-800">
            📋 Your listing will be reviewed by our team within 24 hours before going live.
          </div>
        </div>
        <div class="flex gap-3 mt-6">
          <button onclick="goToStep(3)" class="flex-1 border-2 border-gray-200 text-gray-600 font-semibold py-3 rounded-xl hover:border-gray-300 transition-colors">
            ← Back
          </button>
          <button onclick="submitListing()" id="submit-btn" class="flex-1 bg-yellow-400 hover:bg-yellow-300 text-[#ea580c] font-bold py-3 rounded-xl transition-colors">
            Submit Listing ✓
          </button>
        </div>
      </div>

      <!-- Success Screen -->
      <div id="step-success" class="step-content hidden text-center py-8">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Listing Submitted!</h2>
        <p class="text-gray-500 mb-2">Your property has been submitted for review.</p>
        <p id="ref-number" class="text-sm font-semibold text-[#ea580c] mb-8"></p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/search" class="bg-[#ea580c] text-white font-semibold px-6 py-3 rounded-xl hover:bg-[#c2410c] transition-colors text-sm">
            Browse Properties
          </a>
          <button onclick="window.location.reload()" class="border-2 border-gray-200 text-gray-600 font-semibold px-6 py-3 rounded-xl hover:border-gray-300 transition-colors text-sm">
            Submit Another
          </button>
        </div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script>
  let uploadedPhotoUrls: string[] = [];

  function goToStep(step: number) {
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.getElementById(`step-${step}`)?.classList.remove('hidden');

    document.querySelectorAll('.step-dot').forEach((dot: any, i) => {
      if (i + 1 === step) {
        dot.classList.remove('bg-gray-200', 'text-gray-500');
        dot.classList.add('bg-[#ea580c]', 'text-white');
      } else {
        dot.classList.remove('bg-[#ea580c]', 'text-white');
        dot.classList.add('bg-gray-200', 'text-gray-500');
      }
    });
  }

  // Photo preview
  document.getElementById('photo-input')?.addEventListener('change', (e: any) => {
    const files = Array.from(e.target.files as FileList);
    const preview = document.getElementById('photo-preview')!;
    const status = document.getElementById('photo-status')!;
    preview.innerHTML = '';
    status.textContent = `${files.length} photo(s) selected`;
    files.slice(0, 10).forEach(file => {
      const reader = new FileReader();
      reader.onload = (ev) => {
        const img = document.createElement('img');
        img.src = ev.target?.result as string;
        img.className = 'w-full h-24 object-cover rounded-xl';
        preview.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  });

  async function submitListing() {
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    btn.textContent = 'Submitting...';
    btn.disabled = true;

    const data = {
      listing_type: (document.getElementById('p-listing-type') as HTMLSelectElement).value,
      property_type: (document.getElementById('p-property-type') as HTMLSelectElement).value,
      title: (document.getElementById('p-title') as HTMLInputElement).value,
      price: (document.getElementById('p-price') as HTMLInputElement).value,
      city: (document.getElementById('p-city') as HTMLInputElement).value,
      province: (document.getElementById('p-province') as HTMLInputElement).value,
      bedrooms: (document.getElementById('p-bedrooms') as HTMLInputElement).value,
      bathrooms: (document.getElementById('p-bathrooms') as HTMLInputElement).value,
      floor_area: (document.getElementById('p-floor-area') as HTMLInputElement).value,
      address: (document.getElementById('p-address') as HTMLInputElement).value,
      description: (document.getElementById('p-description') as HTMLTextAreaElement).value,
      name: (document.getElementById('p-name') as HTMLInputElement).value,
      phone: (document.getElementById('p-phone') as HTMLInputElement).value,
      email: (document.getElementById('p-email') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/.netlify/functions/submit-property', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (!res.ok) throw new Error(result.error || 'Submission failed.');
      document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
      document.getElementById('step-success')?.classList.remove('hidden');
      const ref = 'IRC-' + Date.now().toString(36).toUpperCase();
      document.getElementById('ref-number')!.textContent = `Reference: ${ref}`;
    } catch {
      btn.textContent = 'Submit Listing ✓';
      btn.disabled = false;
      alert('Error submitting. Please try again.');
    }
  }

  (window as any).goToStep = goToStep;
  (window as any).submitListing = submitListing;
</script>
