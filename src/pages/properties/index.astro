---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const WP_CMS = "https://cms.philippine-properties.com/wp-json/wp/v2";
const PESO = '₱';

let properties: any[] = [];
let cmsConnected = false;
let cmsError = '';
try {
  const res = await fetch(`${WP_CMS}/property?per_page=20&_embed`);
  properties = await res.json();
  if (!Array.isArray(properties)) {
    cmsError = 'API returned unexpected data';
    properties = [];
  } else {
    cmsConnected = true;
  }
} catch (e: any) {
  cmsError = e?.message || 'Could not reach CMS';
}
---

<Layout title="Properties" description="Browse all properties listed on Philippine Properties">
  <Navbar />
  <main class="pt-16 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      <div class="mb-8">
        <h1 class="text-3xl font-bold mb-2" style="color:#8B0000">Browse Properties</h1>
        <p class="text-gray-500">Explore our latest listings across the Philippines</p>
      </div>

      <div class="flex items-center gap-2 mb-8">
        {cmsConnected ? (
          <span class="w-3 h-3 rounded-full bg-green-500 animate-pulse" title="Connected to WordPress CMS"></span>
        ) : (
          <span class="w-3 h-3 rounded-full bg-red-500" title={`CMS not connected — ${cmsError}`}></span>
        )}
      </div>

      {properties.length === 0 ? (
        <div class="text-center py-24 text-gray-400">
          <p class="text-xl font-semibold mb-2">No properties found</p>
          <p class="text-sm">Check back soon for new listings.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {properties.map((p: any) => {
            const title = p.title?.rendered ?? 'Untitled';
            const slug = p.slug;
            const price = p.acf?.price
              ? `${PESO}${Number(p.acf.price).toLocaleString('en-PH')}`
              : 'Price on Request';
            const city = (p.acf?.location_city ?? '').replace(/\b\w/g, (c: string) => c.toUpperCase());
            const province = (p.acf?.location_province ?? '').replace(/\b\w/g, (c: string) => c.toUpperCase());
            const location = [city, province].filter(Boolean).join(', ');
            const beds = p.acf?.bedrooms;
            const baths = p.acf?.bathrooms;
            const listingType = p.acf?.listing_type ?? '';
            const photo = p._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? '';

            return (
              <a href={`/property/${slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-xl hover:border-[#8B0000]/30 transition-all duration-300 flex flex-col shadow-sm">

                <div class="relative h-48 bg-gray-100 overflow-hidden">
                  {photo
                    ? <img src={photo} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    : <div class="w-full h-full flex items-center justify-center text-gray-300">
                        <svg class="w-16 h-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a1 1 0 01-1 1H4a1 1 0 01-1-1V9.75z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/>
                        </svg>
                      </div>
                  }
                  {listingType && (
                    <span class="absolute top-3 left-3 text-xs font-semibold px-2.5 py-1 rounded-full text-white" style="background:#8B0000">
                      {listingType}
                    </span>
                  )}
                </div>

                <div class="p-4 flex flex-col flex-1">
                  <p class="font-bold text-lg leading-tight mb-1" style="color:#8B0000">{price}</p>
                  <h3 class="text-gray-900 font-semibold text-sm leading-snug mb-2 line-clamp-2" set:html={title} />

                  {location && (
                    <p class="text-gray-400 text-xs mb-3 flex items-center gap-1">
                      <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                      </svg>
                      {location}
                    </p>
                  )}

                  <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 pt-3 border-t border-gray-100 mt-auto">
                    {beds && (
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 12V8.5A1.5 1.5 0 014.5 7H8m-5 5v4m18-4v4M8 7h8a1 1 0 011 1v4H7V8a1 1 0 011-1z"/>
                        </svg>
                        <span class="font-semibold text-gray-700">{beds}</span> bed
                      </span>
                    )}
                    {baths && (
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M4 12a2 2 0 01-2-2V8.5A1.5 1.5 0 013.5 7H6m-4 5v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
                        </svg>
                        <span class="font-semibold text-gray-700">{baths}</span> bath
                      </span>
                    )}
                  </div>
                </div>

              </a>
            );
          })}
        </div>
      )}

    </div>
  </main>
  <Footer />
</Layout>
