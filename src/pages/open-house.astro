---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API, CONTACT_EMAIL } from '../config.js';

let openHouseProps: any[] = [];
const today = new Date();
today.setHours(0, 0, 0, 0);

try {
  const res = await fetch(`${WP_API}/property?_embed&per_page=100&status=publish`);
  const all = await res.json();
  if (Array.isArray(all)) {
    openHouseProps = all
      .filter((p: any) => {
        if (!p.acf?.open_house_date) return false;
        const d = new Date(p.acf.open_house_date);
        return !isNaN(d.getTime()) && d >= today;
      })
      .sort((a: any, b: any) =>
        new Date(a.acf.open_house_date).getTime() - new Date(b.acf.open_house_date).getTime()
      );
  }
} catch {}

function formatDate(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    return d.toLocaleDateString('en-PH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return dateStr;
  }
}

function formatShortDate(dateStr: string): { day: string; month: string; weekday: string } {
  try {
    const d = new Date(dateStr);
    return {
      day: d.toLocaleDateString('en-PH', { day: 'numeric' }),
      month: d.toLocaleDateString('en-PH', { month: 'short' }),
      weekday: d.toLocaleDateString('en-PH', { weekday: 'short' }),
    };
  } catch {
    return { day: '—', month: '—', weekday: '—' };
  }
}
---

<Layout
  title="Open House Calendar — Schedule a Viewing"
  description="Find upcoming open house events in the Philippines. RSVP to visit properties from Integrity Realty and schedule your viewing today."
>
  <Navbar />

  <!-- Hero -->
  <section class="relative py-20 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 overflow-hidden">
    <div class="absolute inset-0 opacity-20" style="background-image:url('/hero-bg.jpg');background-size:cover;background-position:center;"></div>
    <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-[#ea580c] to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center text-white">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-xs uppercase tracking-widest text-white/80 mb-6">
        <span class="w-1.5 h-1.5 bg-[#ea580c] rounded-full"></span>
        Integrity Realty — Open House Events
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="font-family:'Playfair Display',serif;">
        Open House <span class="italic text-[#fb923c]">Calendar</span>
      </h1>
      <p class="text-white/70 text-lg font-light mb-8 max-w-xl mx-auto">
        Visit properties in person. RSVP to upcoming open house events and schedule your viewing with our agents.
      </p>
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        <div class="flex items-center gap-2 bg-white/10 border border-white/20 rounded-xl px-4 py-2.5">
          <span>🗓️</span><span>Upcoming events</span>
        </div>
        <div class="flex items-center gap-2 bg-white/10 border border-white/20 rounded-xl px-4 py-2.5">
          <span>🆓</span><span>Free to attend</span>
        </div>
        <div class="flex items-center gap-2 bg-white/10 border border-white/20 rounded-xl px-4 py-2.5">
          <span>🏠</span><span>See the property first-hand</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Listings -->
  <section class="py-16 max-w-5xl mx-auto px-4">
    {openHouseProps.length > 0 ? (
      <div class="space-y-6">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-bold text-gray-900">
            Upcoming Open Houses
            <span class="ml-2 text-sm font-normal text-gray-400">{openHouseProps.length} event{openHouseProps.length !== 1 ? 's' : ''}</span>
          </h2>
        </div>

        {openHouseProps.map((p: any) => {
          const acf = p.acf || {};
          const title = p.title?.rendered || 'Property';
          const image = p._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
          const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
          const city = acf.location_city || '';
          const address = acf.full_address || city || 'Philippines';
          const slug = p.slug || '';
          const dateInfo = formatShortDate(acf.open_house_date);
          const dateStr = formatDate(acf.open_house_date);
          const agent = acf.agent_name || 'Integrity Realty Agent';
          const agentPhone = acf.agent_phone ? acf.agent_phone.replace(/\D/g, '').replace(/^0/, '63') : '639691967170';
          const waMsg = encodeURIComponent(`Hi! I'd like to RSVP for the open house of ${title} on ${dateStr}.`);
          const beds = acf.bedrooms ? acf.bedrooms + ' bed' : '';
          const baths = acf.bathrooms ? acf.bathrooms + ' bath' : '';
          const area = acf.floor_area ? acf.floor_area + ' m²' : '';
          const specs = [beds, baths, area].filter(Boolean).join(' · ');

          return (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col sm:flex-row">
              <!-- Date Block -->
              <div class="sm:w-24 bg-[#1a5276] flex flex-row sm:flex-col items-center justify-center gap-3 sm:gap-1 px-4 py-4 sm:py-6 shrink-0">
                <span class="text-white/60 text-xs uppercase tracking-widest">{dateInfo.weekday}</span>
                <span class="text-white text-3xl font-bold leading-none">{dateInfo.day}</span>
                <span class="text-[#fb923c] text-xs font-semibold uppercase tracking-widest">{dateInfo.month}</span>
              </div>

              <!-- Image -->
              {image && (
                <div class="sm:w-48 h-40 sm:h-auto overflow-hidden shrink-0 bg-gray-100">
                  <img
                    src={`https://wsrv.nl/?url=${encodeURIComponent(image)}&w=400&q=80&output=webp`}
                    alt={title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}

              <!-- Info -->
              <div class="flex-1 p-5 flex flex-col justify-between">
                <div>
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <a href={`/property/${slug}`} class="font-bold text-gray-900 hover:text-[#ea580c] transition-colors leading-snug line-clamp-2">{title}</a>
                    <span class="shrink-0 bg-purple-50 text-purple-600 text-xs font-semibold px-2.5 py-1 rounded-full">Open House</span>
                  </div>
                  <p class="text-[#ea580c] font-bold text-lg mb-1">{price}</p>
                  <p class="text-gray-400 text-xs mb-2 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {address}
                  </p>
                  {specs && <p class="text-gray-400 text-xs mb-3">{specs}</p>}
                  <p class="text-gray-500 text-xs flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    {dateStr}
                  </p>
                </div>
                <div class="flex flex-wrap gap-2 mt-4">
                  <button
                    onclick={`document.getElementById('rsvp-modal').classList.remove('hidden');document.getElementById('rsvp-property').value='${title.replace(/'/g, "\\'")}';document.getElementById('rsvp-date').value='${dateStr}';`}
                    class="flex-1 sm:flex-none bg-[#ea580c] hover:bg-[#c2410c] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors"
                  >
                    RSVP Now
                  </button>
                  <a
                    href={`https://wa.me/${agentPhone}?text=${waMsg}`}
                    target="_blank" rel="noopener"
                    class="flex-1 sm:flex-none flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1da850] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                  </a>
                  <a href={`/property/${slug}`} class="flex-1 sm:flex-none text-center text-sm font-medium border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-600 px-5 py-2.5 rounded-xl transition-colors">
                    View Listing
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <!-- No Events State -->
      <div class="text-center py-24">
        <span class="text-7xl block mb-4 opacity-20">🗓️</span>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">No Upcoming Open Houses</h2>
        <p class="text-gray-400 mb-2 max-w-md mx-auto">We're scheduling new open house events. Leave your details and we'll notify you when one is near you.</p>
      </div>
    )}
  </section>

  <!-- RSVP Form Section (also shown below listings as CTA) -->
  <section class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif;">Request a Private Viewing</h2>
      <p class="text-gray-400 text-sm mb-8">Can't make an open house? Request a private viewing at a time that works for you.</p>
      <form
        action="https://formsubmit.co/info@philippine-properties.com"
        method="POST"
        class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-left space-y-4"
      >
        <input type="hidden" name="_subject" value="Open House / Private Viewing Request — Philippine Properties Portal" />
        <input type="hidden" name="_next" value="/open-house?rsvp=success" />
        <input type="hidden" name="_captcha" value="false" />
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Full Name *</label>
            <input type="text" name="name" required placeholder="Juan dela Cruz" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Phone / WhatsApp *</label>
            <input type="tel" name="phone" required placeholder="+63 9XX XXX XXXX" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Email Address</label>
          <input type="email" name="email" placeholder="you@example.com" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Property of Interest</label>
          <input type="text" name="property" id="rsvp-static-property" placeholder="Property name, city, or type" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Preferred Date & Time</label>
          <input type="text" name="preferred_date" placeholder="e.g. Saturday afternoon, weekdays after 5pm" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Message (optional)</label>
          <textarea name="message" rows="3" placeholder="Any questions or special requests..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3.5 rounded-xl transition-colors shadow-lg shadow-orange-900/20">
          Submit RSVP / Viewing Request
        </button>
        <p class="text-center text-xs text-gray-400">Our team will confirm your schedule within 24 hours.</p>
      </form>
    </div>
  </section>

  <!-- RSVP Modal -->
  <div id="rsvp-modal" class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-bold text-gray-900 text-lg">RSVP for Open House</h3>
        <button onclick="document.getElementById('rsvp-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form
        action="https://formsubmit.co/info@philippine-properties.com"
        method="POST"
        class="space-y-4"
      >
        <input type="hidden" name="_subject" value="Open House RSVP — Philippine Properties Portal" />
        <input type="hidden" name="_next" value="/open-house?rsvp=success" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="property" id="rsvp-property" />
        <input type="hidden" name="open_house_date" id="rsvp-date" />

        <div class="bg-orange-50 rounded-xl px-4 py-3 text-sm text-gray-700">
          <p class="font-semibold text-[#ea580c]" id="rsvp-display-property"></p>
          <p class="text-gray-500 text-xs mt-0.5" id="rsvp-display-date"></p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Full Name *</label>
          <input type="text" name="name" required placeholder="Juan dela Cruz" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Phone / WhatsApp *</label>
          <input type="tel" name="phone" required placeholder="+63 9XX XXX XXXX" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Email</label>
          <input type="email" name="email" placeholder="you@example.com" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#ea580c] transition-colors" />
        </div>
        <button type="submit" class="w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3.5 rounded-xl transition-colors">
          Confirm RSVP
        </button>
      </form>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline>
  // Sync modal display fields
  var propInput = document.getElementById('rsvp-property');
  var dateInput = document.getElementById('rsvp-date');
  var propDisplay = document.getElementById('rsvp-display-property');
  var dateDisplay = document.getElementById('rsvp-display-date');
  if (propInput) propInput.addEventListener('change', function() { if (propDisplay) propDisplay.textContent = propInput.value; });
  if (dateInput) dateInput.addEventListener('change', function() { if (dateDisplay) dateDisplay.textContent = dateInput.value; });

  // Success toast
  (function() {
    if (new URLSearchParams(window.location.search).get('rsvp') !== 'success') return;
    history.replaceState(null, '', window.location.pathname);
    var toast = document.createElement('div');
    toast.textContent = '✅ RSVP confirmed! Our team will contact you shortly.';
    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a5276;color:white;padding:14px 24px;border-radius:12px;font-size:14px;font-weight:600;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.3);max-width:90%;text-align:center;';
    document.body.appendChild(toast);
    setTimeout(function() { toast.remove(); }, 5000);
  })();
</script>
