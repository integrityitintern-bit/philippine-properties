---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Mortgage Calculator"
  description="Calculate your monthly mortgage payments for Philippine properties. Estimate loan amount, monthly payments, and total interest — free tool from Philippine Real Estate Properties."
>
  <Navbar />

  <div class="max-w-5xl mx-auto px-4 py-16">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-[#ea580c] text-xs font-semibold tracking-widest uppercase mb-3">Free Tool</p>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif;">Mortgage Calculator</h1>
      <p class="text-gray-500 text-sm max-w-lg mx-auto leading-relaxed">Estimate your monthly payments for any Philippine property. Adjust the sliders and see your numbers update instantly.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 items-start">

      <!-- ── Left: Inputs ── -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-6">
        <h2 class="font-bold text-gray-900">Loan Details</h2>

        <!-- Property Price -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Property Price</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 font-semibold text-sm select-none">₱</span>
            <input id="calc-price" type="number" value="3000000" min="100000" step="50000"
              class="w-full pl-8 pr-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] text-gray-900 text-sm" />
          </div>
        </div>

        <!-- Down Payment Slider -->
        <div>
          <div class="flex justify-between items-baseline mb-1.5">
            <label class="text-sm font-medium text-gray-700">Down Payment</label>
            <span class="text-sm font-bold text-[#ea580c]"><span id="dp-pct-label">20</span>%
              &nbsp;<span class="text-xs font-normal text-gray-400">(<span id="dp-amount-label">₱600,000</span>)</span>
            </span>
          </div>
          <input id="calc-dp" type="range" min="5" max="50" value="20" step="5"
            class="w-full h-2 rounded-full accent-[#ea580c] cursor-pointer" />
          <div class="flex justify-between text-xs text-gray-300 mt-1"><span>5%</span><span>50%</span></div>
        </div>

        <!-- Interest Rate Slider -->
        <div>
          <div class="flex justify-between items-baseline mb-1.5">
            <label class="text-sm font-medium text-gray-700">Annual Interest Rate</label>
            <span class="text-sm font-bold text-[#ea580c]"><span id="rate-label">6.5</span>% p.a.</span>
          </div>
          <input id="calc-rate" type="range" min="3" max="15" value="6.5" step="0.25"
            class="w-full h-2 rounded-full accent-[#ea580c] cursor-pointer" />
          <div class="flex justify-between text-xs text-gray-300 mt-1"><span>3%</span><span>15%</span></div>
        </div>

        <!-- Loan Term Buttons -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Loan Term</label>
          <div class="grid grid-cols-5 gap-2">
            {[10, 15, 20, 25, 30].map(y => (
              <button data-term={y}
                class={`term-btn py-2.5 text-xs font-bold rounded-xl border transition-colors ${y === 20 ? 'bg-[#ea580c] text-white border-[#ea580c]' : 'bg-white text-gray-600 border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c]'}`}>
                {y} yrs
              </button>
            ))}
          </div>
        </div>

        <!-- Banks note -->
        <div class="bg-blue-50 rounded-xl px-4 py-3 text-xs text-blue-600 leading-relaxed">
          <span class="font-semibold">Typical PH bank rates:</span> BDO & BPI 5.5–7%, RCBC/Metrobank 6–7.5%, Pag-IBIG 5.375–6.5%. Rates vary by term and credit profile.
        </div>
      </div>

      <!-- ── Right: Results ── -->
      <div class="space-y-4">

        <!-- Monthly Payment Hero Card -->
        <div class="bg-gradient-to-br from-[#ea580c] to-[#c2410c] rounded-2xl p-6 text-white shadow-lg shadow-orange-900/20">
          <p class="text-orange-200 text-xs font-semibold tracking-widest uppercase mb-2">Estimated Monthly Payment</p>
          <p id="result-monthly" class="text-5xl font-bold mb-1 tabular-nums">₱0</p>
          <p class="text-orange-200 text-sm">Principal + Interest only</p>
        </div>

        <!-- Breakdown Card -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
          <h3 class="font-bold text-gray-900 text-sm mb-4">Full Breakdown</h3>
          <div class="space-y-2.5 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Property Price</span>
              <span id="res-price" class="font-semibold text-gray-900 tabular-nums">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Down Payment</span>
              <span id="res-dp" class="font-semibold text-emerald-600 tabular-nums">—</span>
            </div>
            <div class="flex justify-between pt-2.5 border-t border-gray-100">
              <span class="text-gray-700 font-medium">Loan Amount</span>
              <span id="res-loan" class="font-bold text-gray-900 tabular-nums">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Total Interest Paid</span>
              <span id="res-interest" class="font-semibold text-[#ea580c] tabular-nums">—</span>
            </div>
            <div class="flex justify-between pt-2.5 border-t border-gray-100">
              <span class="text-gray-700 font-medium">Total Amount Paid</span>
              <span id="res-total" class="font-bold text-gray-900 tabular-nums">—</span>
            </div>
          </div>

          <!-- Principal vs Interest bar -->
          <div class="mt-4">
            <div class="flex justify-between text-xs text-gray-400 mb-1.5">
              <span>Principal <span id="bar-principal-pct" class="text-gray-600 font-medium"></span></span>
              <span>Interest <span id="bar-interest-pct" class="text-gray-600 font-medium"></span></span>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div id="res-bar" class="h-full bg-[#ea580c] rounded-full transition-all duration-500" style="width:70%"></div>
            </div>
          </div>
        </div>

        <!-- Search CTA -->
        <div class="bg-orange-50 border border-orange-100 rounded-2xl p-5 flex items-center justify-between gap-4">
          <div>
            <p class="text-gray-800 text-sm font-semibold">Ready to find a property?</p>
            <p class="text-gray-400 text-xs mt-0.5">Browse listings that fit your budget</p>
          </div>
          <a id="search-cta" href="/search"
            class="shrink-0 bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors whitespace-nowrap">
            Browse →
          </a>
        </div>

        <p class="text-gray-400 text-[11px] text-center leading-relaxed px-2">
          Estimates are for illustration only and exclude taxes, insurance, and association dues. Consult your bank or a licensed broker for official loan quotes.
        </p>
      </div>
    </div>

    <!-- Amortization Schedule (collapsible) -->
    <div class="mt-12">
      <button id="toggle-amort"
        class="flex items-center gap-2 text-sm font-semibold text-gray-700 hover:text-[#ea580c] transition-colors group">
        <svg id="amort-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
        </svg>
        <span id="amort-label">Show Amortization Schedule</span>
      </button>

      <div id="amort-table" class="hidden mt-5 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-20">Year</th>
                <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Principal</th>
                <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Interest</th>
                <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Balance</th>
              </tr>
            </thead>
            <tbody id="amort-body" class="divide-y divide-gray-50 text-gray-700"></tbody>
          </table>
        </div>
      </div>
    </div>

  </div>

  <Footer />
</Layout>

<script is:inline>
  var loanTerm = 20;
  var fmt = function(n) { return '₱' + Math.round(n).toLocaleString('en-PH'); };

  function calculate() {
    var price = parseFloat(document.getElementById('calc-price').value) || 0;
    var dpPct = parseFloat(document.getElementById('calc-dp').value) / 100;
    var annualRate = parseFloat(document.getElementById('calc-rate').value) / 100;
    var rate = annualRate / 12;
    var n = loanTerm * 12;

    var dp = price * dpPct;
    var loan = price - dp;

    var monthly = 0;
    if (rate === 0 || loan === 0) {
      monthly = n > 0 ? loan / n : 0;
    } else {
      var pow = Math.pow(1 + rate, n);
      monthly = loan * (rate * pow) / (pow - 1);
    }

    var totalPaid = monthly * n;
    var totalInterest = totalPaid - loan;
    var principalPct = loan > 0 ? (loan / (loan + totalInterest) * 100) : 70;

    document.getElementById('result-monthly').textContent = fmt(monthly);
    document.getElementById('res-price').textContent = fmt(price);
    document.getElementById('res-dp').textContent = '−' + fmt(dp);
    document.getElementById('res-loan').textContent = fmt(loan);
    document.getElementById('res-interest').textContent = fmt(totalInterest);
    document.getElementById('res-total').textContent = fmt(loan + totalInterest);
    document.getElementById('res-bar').style.width = principalPct.toFixed(1) + '%';
    document.getElementById('bar-principal-pct').textContent = principalPct.toFixed(0) + '%';
    document.getElementById('bar-interest-pct').textContent = (100 - principalPct).toFixed(0) + '%';

    // Update search CTA with price filter
    var maxBudget = Math.round(price * 1.1 / 100000) * 100000;
    document.getElementById('search-cta').href = '/search?price_max=' + maxBudget;

    buildAmortization(loan, rate, monthly, n);
  }

  function buildAmortization(loan, rate, monthly, n) {
    var balance = loan;
    var rows = '';
    for (var yr = 1; yr <= loanTerm; yr++) {
      var yearPrincipal = 0, yearInterest = 0;
      for (var m = 0; m < 12 && (yr - 1) * 12 + m < n; m++) {
        var interest = balance * rate;
        var principal = Math.min(monthly - interest, balance);
        if (principal < 0) principal = 0;
        yearInterest += interest;
        yearPrincipal += principal;
        balance = Math.max(0, balance - principal);
      }
      rows += '<tr class="hover:bg-orange-50/40 transition-colors">' +
        '<td class="px-5 py-2.5 font-medium text-gray-800">Year ' + yr + '</td>' +
        '<td class="px-5 py-2.5 text-right tabular-nums">' + fmt(yearPrincipal) + '</td>' +
        '<td class="px-5 py-2.5 text-right tabular-nums text-[#ea580c]">' + fmt(yearInterest) + '</td>' +
        '<td class="px-5 py-2.5 text-right tabular-nums font-semibold text-gray-900">' + fmt(balance) + '</td>' +
        '</tr>';
    }
    document.getElementById('amort-body').innerHTML = rows;
  }

  // Sync down payment display
  function syncDp() {
    var price = parseFloat(document.getElementById('calc-price').value) || 0;
    var pct = parseFloat(document.getElementById('calc-dp').value);
    document.getElementById('dp-pct-label').textContent = pct;
    document.getElementById('dp-amount-label').textContent = fmt(price * pct / 100);
  }

  document.getElementById('calc-price').addEventListener('input', function() { syncDp(); calculate(); });
  document.getElementById('calc-dp').addEventListener('input', function() { syncDp(); calculate(); });
  document.getElementById('calc-rate').addEventListener('input', function() {
    document.getElementById('rate-label').textContent = parseFloat(this.value).toFixed(2).replace(/\.?0+$/, '');
    calculate();
  });

  // Term buttons
  document.querySelectorAll('.term-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      loanTerm = parseInt(this.dataset.term);
      document.querySelectorAll('.term-btn').forEach(function(b) {
        b.classList.remove('bg-[#ea580c]', 'text-white', 'border-[#ea580c]');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      this.classList.add('bg-[#ea580c]', 'text-white', 'border-[#ea580c]');
      this.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      calculate();
    });
  });

  // Amortization toggle
  document.getElementById('toggle-amort').addEventListener('click', function() {
    var table = document.getElementById('amort-table');
    var label = document.getElementById('amort-label');
    var chevron = document.getElementById('amort-chevron');
    var hidden = table.classList.toggle('hidden');
    label.textContent = hidden ? 'Show Amortization Schedule' : 'Hide Amortization Schedule';
    chevron.style.transform = hidden ? '' : 'rotate(180deg)';
  });

  // Init
  calculate();
</script>
