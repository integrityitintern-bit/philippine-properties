---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';

let posts = [];
try {
  const res = await fetch(`${WP_API}/posts?_embed&per_page=9&status=publish`);
  posts = await res.json();
} catch {}
---

<Layout title="Resources & Real Estate Guides">
  <Navbar />

  <!-- Hero -->
  <section class="bg-[#ea580c] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Resources & Guides</h1>
      <p class="text-white/80 text-lg">Expert tips, market insights, and real estate guides for Filipino buyers and renters.</p>
    </div>
  </section>

  <!-- Topics -->
  <section class="py-8 border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 flex flex-wrap gap-2 justify-center" id="topic-pills">
      {[
        { label: 'All Topics', filter: '' },
        { label: 'Buying Guide', filter: 'buying guide' },
        { label: 'Renting Tips', filter: 'renting rent' },
        { label: 'Market Insights', filter: 'market insights' },
        { label: 'OFW Investors', filter: 'ofw investor overseas' },
        { label: 'First-Time Buyers', filter: 'first-time first time buyer' },
        { label: 'Condo Living', filter: 'condo living' },
      ].map((t, i) => (
        <button
          class={`topic-pill px-4 py-2 text-sm rounded-full border transition-colors ${i === 0 ? 'border-[#ea580c] text-[#ea580c] bg-[#ea580c]/10' : 'border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c]'}`}
          data-filter={t.filter}
        >
          {t.label}
        </button>
      ))}
    </div>
  </section>

  <!-- Articles -->
  <section class="py-16 max-w-6xl mx-auto px-4">
    {posts.length > 0 ? (
      <div id="articles-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post: any) => {
          const image = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
          const excerpt = post.excerpt?.rendered?.replace(/<[^>]*>/g, '').slice(0, 120) + '...' || '';
          const date = new Date(post.date).toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' });
          const cats = (post._embedded?.['wp:term']?.[0] || []).map((c: any) => c.name).join(',').toLowerCase();
          return (
            <article class="article-card bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow group" data-categories={cats}>
              <div class="h-48 bg-gray-100 overflow-hidden">
                {image
                  ? <img src={image} alt={post.title?.rendered} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                  : <div class="w-full h-full flex items-center justify-center text-4xl bg-gray-50">📰</div>
                }
              </div>
              <div class="p-5">
                <p class="text-xs text-gray-400 mb-2">{date}</p>
                <h3 class="font-bold text-gray-900 leading-snug mb-2 line-clamp-2" set:html={post.title?.rendered} />
                <p class="text-gray-500 text-xs leading-relaxed mb-4">{excerpt}</p>
                <a href={post.link} target="_blank" rel="noopener" class="text-[#ea580c] font-semibold text-xs hover:underline">
                  Read More →
                </a>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <!-- Static guide cards when no WP posts -->
      <div id="articles-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '🏠', title: "First-Time Buyer's Complete Guide", desc: 'Everything you need to know before buying your first property in the Philippines — from financing to turnover.', tag: 'Buying Guide' },
          { icon: '📋', title: 'How to Rent a Property in the Philippines', desc: 'Step-by-step guide to renting safely — what to check in a lease contract, red flags, and tenant rights.', tag: 'Renting Tips' },
          { icon: '💰', title: 'Understanding Pag-IBIG Housing Loans', desc: 'A complete breakdown of Pag-IBIG Fund housing loan requirements, rates, and how to apply.', tag: 'Financing' },
          { icon: '🌏', title: 'OFW Real Estate Investment Guide', desc: 'How overseas Filipino workers can invest in Philippine real estate — legally, safely, and profitably.', tag: 'OFW Investors' },
          { icon: '📊', title: 'Philippine Real Estate Market 2026', desc: 'Key trends shaping the property market this year — rising condo demand, provincial growth, and more.', tag: 'Market Insights' },
          { icon: '🏢', title: 'Condo vs House: Which is Right for You?', desc: 'A practical comparison to help you decide between buying a condo or a house based on your lifestyle and budget.', tag: 'Buying Guide' },
        ].map(article => (
          <article class="article-card bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6" data-categories={article.tag.toLowerCase()}>
            <span class="text-3xl">{article.icon}</span>
            <span class="inline-block mt-3 text-[10px] font-bold text-[#ea580c] bg-[#ea580c]/10 px-2.5 py-0.5 rounded-full uppercase tracking-wide">{article.tag}</span>
            <h3 class="font-bold text-gray-900 mt-2 mb-2 leading-snug">{article.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{article.desc}</p>
          </article>
        ))}
      </div>
      <div id="no-articles" class="hidden text-center py-16">
        <p class="text-gray-400">No articles in this category yet.</p>
      </div>
    )}
  </section>

  <!-- Mortgage Calculator -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <span class="inline-block bg-[#ea580c] text-white text-xs font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">Free Tool</span>
        <h2 class="text-2xl font-bold mb-2">Mortgage Calculator</h2>
        <p class="text-white/60 text-sm">Estimate your monthly payment in seconds</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <!-- Inputs -->
        <div class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Property Price (₱)</label>
            <input id="mc-price" type="number" value="5000000" min="0"
              class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Down Payment (%)</label>
            <div class="flex gap-2">
              <input id="mc-downpct" type="number" value="20" min="0" max="100"
                class="w-24 px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
              <input id="mc-downamt" type="number" readonly
                class="flex-1 px-4 py-3 text-sm bg-white/5 border border-white/10 rounded-xl text-white/50 cursor-not-allowed" placeholder="Amount" />
            </div>
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Loan Term</label>
            <select id="mc-term" class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-[#ea580c]">
              <option value="10">10 years</option>
              <option value="15">15 years</option>
              <option value="20" selected>20 years</option>
              <option value="25">25 years</option>
              <option value="30">30 years</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Annual Interest Rate (%)</label>
            <input id="mc-rate" type="number" value="6.5" min="0" step="0.1"
              class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
          </div>
          <button id="mc-calculate" class="w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3.5 rounded-xl transition-colors">
            Calculate Monthly Payment
          </button>
        </div>
        <!-- Results -->
        <div id="mc-results" class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
          <div class="text-center pb-4 border-b border-white/10">
            <p class="text-xs text-white/50 mb-1">Estimated Monthly Payment</p>
            <p id="mc-monthly" class="text-4xl font-bold text-[#ea580c]">₱0</p>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-white/60">Loan Amount</span>
              <span id="mc-loan" class="font-semibold">₱0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-white/60">Total Payment</span>
              <span id="mc-total" class="font-semibold">₱0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-white/60">Total Interest</span>
              <span id="mc-interest" class="font-semibold text-yellow-400">₱0</span>
            </div>
          </div>
          <p class="text-xs text-white/30 pt-2 border-t border-white/10">
            * Estimates only. Actual rates may vary. Consult a licensed bank or broker for official quotes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Stay Updated</h2>
      <p class="text-gray-500 mb-6">Get the latest real estate news, market reports, and property tips delivered to your inbox.</p>
      <form class="flex gap-3 max-w-md mx-auto">
        <input type="email" placeholder="Your email address"
          class="flex-1 px-4 py-3 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
        />
        <button type="submit" class="bg-[#ea580c] hover:bg-[#6b0000] text-white font-semibold px-6 py-3 rounded-xl transition-colors whitespace-nowrap text-sm">
          Subscribe
        </button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.topic-pill').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = btn.dataset.filter.toLowerCase();
      document.querySelectorAll('.topic-pill').forEach(function(b) {
        b.className = b.className
          .replace('border-[#ea580c] text-[#ea580c] bg-[#ea580c]/10', '')
          .replace('border-gray-200 text-gray-500', '')
          .trim() + ' border-gray-200 text-gray-500';
      });
      btn.className = btn.className
        .replace('border-gray-200 text-gray-500', '')
        .trim() + ' border-[#ea580c] text-[#ea580c] bg-[#ea580c]/10';

      var cards = document.querySelectorAll('.article-card');
      var visible = 0;
      cards.forEach(function(card) {
        var cats = (card.dataset.categories || '').toLowerCase();
        var show = !filter || filter.split(' ').some(function(kw) { return cats.includes(kw); });
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      var noArticles = document.getElementById('no-articles');
      if (noArticles) noArticles.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<script>
  function fmt(n: number) {
    return '₱' + Math.round(n).toLocaleString('en-PH');
  }

  function calculate() {
    const price    = parseFloat((document.getElementById('mc-price') as HTMLInputElement).value) || 0;
    const downPct  = parseFloat((document.getElementById('mc-downpct') as HTMLInputElement).value) || 0;
    const termYrs  = parseInt((document.getElementById('mc-term') as HTMLSelectElement).value) || 20;
    const annRate  = parseFloat((document.getElementById('mc-rate') as HTMLInputElement).value) || 0;

    const downAmt  = price * (downPct / 100);
    const loan     = price - downAmt;
    const r        = annRate / 100 / 12;
    const n        = termYrs * 12;

    (document.getElementById('mc-downamt') as HTMLInputElement).value = Math.round(downAmt).toLocaleString('en-PH');

    if (loan <= 0 || annRate <= 0) {
      document.getElementById('mc-monthly')!.textContent = fmt(loan / n || 0);
      document.getElementById('mc-loan')!.textContent    = fmt(loan);
      document.getElementById('mc-total')!.textContent   = fmt(loan);
      document.getElementById('mc-interest')!.textContent = fmt(0);
      return;
    }

    const monthly = loan * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const total   = monthly * n;
    const interest = total - loan;

    document.getElementById('mc-monthly')!.textContent  = fmt(monthly);
    document.getElementById('mc-loan')!.textContent     = fmt(loan);
    document.getElementById('mc-total')!.textContent    = fmt(total);
    document.getElementById('mc-interest')!.textContent = fmt(interest);
  }

  document.getElementById('mc-calculate')?.addEventListener('click', calculate);
  ['mc-price','mc-downpct','mc-term','mc-rate'].forEach(id => {
    document.getElementById(id)?.addEventListener('keydown', (e: any) => e.key === 'Enter' && calculate());
  });

  calculate();
</script>
