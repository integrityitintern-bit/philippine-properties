---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WP_API } from '../config.js';

---

<Layout title="Resources & Real Estate Guides">
  <Navbar />

  <!-- Hero -->
  <section class="bg-[#ea580c] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Resources & Guides</h1>
      <p class="text-white/80 text-lg">Expert tips, market insights, and real estate guides for Filipino buyers and renters.</p>
    </div>
  </section>

  <!-- Articles -->
  <section class="py-16 max-w-6xl mx-auto px-4">
    <!-- Search input -->
    <input id="resource-search" type="text" placeholder="Search guides and articles..."
      class="w-full px-4 py-3 text-sm bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c] text-gray-900 placeholder-gray-400 mb-4" />

    <!-- Category filter pills (rendered by JS) -->
    <div id="category-pills" class="flex flex-wrap gap-2 mb-8"></div>

    <!-- Articles grid (rendered by JS) -->
    <div id="articles-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <!-- No-results state (shown by JS when filters return nothing) -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-gray-400 text-sm">No articles match your search — try different keywords</p>
    </div>

    <!-- No-posts state (shown by JS when WP returns no posts at all) -->
    <!-- WP SETUP: Go to WP Admin → Posts → Add New.
         Write your real estate guides (buying tips, market updates, etc.).
         Publish them and they will automatically appear here.
         You can also assign categories from Posts → Categories. -->
    <div id="no-posts" class="hidden text-center py-16">
      <div class="max-w-md mx-auto">
        <span class="text-5xl block mb-4">📰</span>
        <h3 class="font-bold text-gray-900 text-lg mb-2">No articles yet</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Head to <strong>WP Admin → Posts → Add New</strong> to write your first real estate guide.
          Published posts will automatically appear here. You can also organise them with
          <strong>Posts → Categories</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- Mortgage Calculator -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-10">
        <span class="inline-block bg-[#ea580c] text-white text-xs font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">Free Tool</span>
        <h2 class="text-2xl font-bold mb-2">Mortgage Calculator</h2>
        <p class="text-white/60 text-sm">Estimate your monthly payment in seconds</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <!-- Inputs -->
        <div class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Property Price (₱)</label>
            <input id="mc-price" type="number" value="5000000" min="0"
              class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Down Payment (%)</label>
            <div class="flex gap-2">
              <input id="mc-downpct" type="number" value="20" min="0" max="100"
                class="w-24 px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
              <input id="mc-downamt" type="number" readonly
                class="flex-1 px-4 py-3 text-sm bg-white/5 border border-white/10 rounded-xl text-white/50 cursor-not-allowed" placeholder="Amount" />
            </div>
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Loan Term</label>
            <select id="mc-term" class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-[#ea580c]">
              <option value="10">10 years</option>
              <option value="15">15 years</option>
              <option value="20" selected>20 years</option>
              <option value="25">25 years</option>
              <option value="30">30 years</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-1.5 block">Annual Interest Rate (%)</label>
            <input id="mc-rate" type="number" value="6.5" min="0" step="0.1"
              class="w-full px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-[#ea580c]" />
          </div>
          <button id="mc-calculate" class="w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3.5 rounded-xl transition-colors">
            Calculate Monthly Payment
          </button>
        </div>
        <!-- Results -->
        <div id="mc-results" class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
          <div class="text-center pb-4 border-b border-white/10">
            <p class="text-xs text-white/50 mb-1">Estimated Monthly Payment</p>
            <p id="mc-monthly" class="text-4xl font-bold text-[#ea580c]">₱0</p>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-white/60">Loan Amount</span>
              <span id="mc-loan" class="font-semibold">₱0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-white/60">Total Payment</span>
              <span id="mc-total" class="font-semibold">₱0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-white/60">Total Interest</span>
              <span id="mc-interest" class="font-semibold text-yellow-400">₱0</span>
            </div>
          </div>
          <p class="text-xs text-white/30 pt-2 border-t border-white/10">
            * Estimates only. Actual rates may vary. Consult a licensed bank or broker for official quotes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Stay Updated</h2>
      <p class="text-gray-500 mb-6">Get the latest real estate news, market reports, and property tips delivered to your inbox.</p>
      <form class="flex gap-3 max-w-md mx-auto">
        <input type="email" placeholder="Your email address"
          class="flex-1 px-4 py-3 text-sm bg-gray-50 text-gray-900 placeholder-gray-400 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#ea580c]"
        />
        <button type="submit" class="bg-[#ea580c] hover:bg-[#6b0000] text-white font-semibold px-6 py-3 rounded-xl transition-colors whitespace-nowrap text-sm">
          Subscribe
        </button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<!-- Articles: client-side render, filter, and search -->
<script define:vars={{ WP_API }}>
  var allPosts = [];
  var allCategories = [];
  var activeCatId = null;
  var searchQuery = '';

  // Fetch posts and categories live from WP API (client-side so new posts appear without rebuild)
  async function loadContent() {
    try {
      const [postsRes, catsRes] = await Promise.all([
        fetch(`${WP_API}/posts?_embed&per_page=20&status=publish`),
        fetch(`${WP_API}/categories?per_page=20&hide_empty=false`),
      ]);
      const postsData = await postsRes.json();
      const catsData = await catsRes.json();
      if (Array.isArray(postsData)) allPosts = postsData;
      if (Array.isArray(catsData)) allCategories = catsData.filter(c => c.slug !== 'uncategorized');
    } catch {}
    renderPills();
    renderArticles();
  }

  // ── Category pill bar ────────────────────────────────────────────────────
  var pillBar = document.getElementById('category-pills');

  function renderPills() {
    pillBar.innerHTML = '';

    var pills = [{ id: null, name: 'All' }].concat(
      allCategories.map(function(c) { return { id: c.id, name: c.name }; })
    );

    pills.forEach(function(cat) {
      var btn = document.createElement('button');
      btn.textContent = cat.name;
      var isActive = cat.id === activeCatId;
      btn.className = 'text-xs font-medium px-4 py-2 rounded-full cursor-pointer transition-colors ' +
        (isActive
          ? 'bg-[#ea580c] text-white border border-[#ea580c]'
          : 'border border-gray-200 text-gray-500 hover:border-[#ea580c] hover:text-[#ea580c]');
      btn.addEventListener('click', function() {
        activeCatId = cat.id;
        renderPills();
        renderArticles();
      });
      pillBar.appendChild(btn);
    });
  }

  // ── Card builder ─────────────────────────────────────────────────────────
  function cardHTML(post) {
    var featImg = (post._embedded && post._embedded['wp:featuredmedia'] && post._embedded['wp:featuredmedia'][0] && post._embedded['wp:featuredmedia'][0].source_url) || '';
    var title = (post.title && post.title.rendered) ? post.title.rendered : 'Untitled';
    var rawExcerpt = (post.excerpt && post.excerpt.rendered) ? post.excerpt.rendered.replace(/<[^>]*>/g, '') : '';
    var excerpt = rawExcerpt.length > 120 ? rawExcerpt.slice(0, 120) + '...' : rawExcerpt;
    var date = new Date(post.date).toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' });
    var link = post.link || '#';

    var wordCount = ((post.content && post.content.rendered) ? post.content.rendered : '').replace(/<[^>]*>/g, '').split(/\s+/).filter(Boolean).length;
    var readTime = Math.max(1, Math.ceil(wordCount / 200));

    var imgSection = featImg
      ? '<img src="' + featImg + '" alt="' + title.replace(/"/g, '&quot;') + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />'
      : '<div class="w-full h-full flex items-center justify-center text-4xl bg-gray-50">📰</div>';

    return (
      '<div class="h-44 bg-gray-100 overflow-hidden rounded-t-2xl">' + imgSection + '</div>' +
      '<div class="p-5 flex flex-col flex-1">' +
        '<p class="text-xs text-gray-400 mb-2">' + date + '</p>' +
        '<h3 class="font-bold text-gray-900 leading-snug mb-2 line-clamp-2">' + title + '</h3>' +
        '<p class="text-gray-500 text-xs leading-relaxed mb-4 flex-1">' + excerpt + '</p>' +
        '<div class="flex items-center justify-between">' +
          '<a href="' + link + '" target="_blank" rel="noopener" class="text-[#ea580c] font-semibold text-xs hover:underline">Read More →</a>' +
          '<span class="text-gray-400 text-xs">📖 ' + readTime + ' min read</span>' +
        '</div>' +
      '</div>'
    );
  }

  // ── Render articles ──────────────────────────────────────────────────────
  function renderArticles() {
    var grid = document.getElementById('articles-grid');
    var noResults = document.getElementById('no-results');
    var noPosts = document.getElementById('no-posts');

    // No WP posts at all — show setup guidance
    if (!allPosts || allPosts.length === 0) {
      grid.innerHTML = '';
      noResults.classList.add('hidden');
      noPosts.classList.remove('hidden');
      return;
    }

    noPosts.classList.add('hidden');

    var query = searchQuery.trim().toLowerCase();

    var filtered = allPosts.filter(function(post) {
      // Category filter
      if (activeCatId !== null) {
        var postCats = Array.isArray(post.categories) ? post.categories : [];
        if (!postCats.includes(activeCatId)) return false;
      }

      // Search filter
      if (query) {
        var titleText = ((post.title && post.title.rendered) ? post.title.rendered : '').replace(/<[^>]*>/g, '').toLowerCase();
        var excerptText = ((post.excerpt && post.excerpt.rendered) ? post.excerpt.rendered : '').replace(/<[^>]*>/g, '').toLowerCase();
        if (!titleText.includes(query) && !excerptText.includes(query)) return false;
      }

      return true;
    });

    if (filtered.length === 0) {
      grid.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');

    grid.innerHTML = filtered.map(function(post) {
      return '<article class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow group flex flex-col">' +
        cardHTML(post) +
        '</article>';
    }).join('');
  }

  // ── Search input ─────────────────────────────────────────────────────────
  var searchInput = document.getElementById('resource-search');
  searchInput.addEventListener('input', function() {
    searchQuery = searchInput.value;
    renderArticles();
  });

  // ── Init ─────────────────────────────────────────────────────────────────
  loadContent();
</script>

<!-- Mortgage calculator -->
<script>
  function fmt(n: number) {
    return '₱' + Math.round(n).toLocaleString('en-PH');
  }

  function calculate() {
    const price    = parseFloat((document.getElementById('mc-price') as HTMLInputElement).value) || 0;
    const downPct  = parseFloat((document.getElementById('mc-downpct') as HTMLInputElement).value) || 0;
    const termYrs  = parseInt((document.getElementById('mc-term') as HTMLSelectElement).value) || 20;
    const annRate  = parseFloat((document.getElementById('mc-rate') as HTMLInputElement).value) || 0;

    const downAmt  = price * (downPct / 100);
    const loan     = price - downAmt;
    const r        = annRate / 100 / 12;
    const n        = termYrs * 12;

    (document.getElementById('mc-downamt') as HTMLInputElement).value = Math.round(downAmt).toLocaleString('en-PH');

    if (loan <= 0 || annRate <= 0) {
      document.getElementById('mc-monthly')!.textContent = fmt(loan / n || 0);
      document.getElementById('mc-loan')!.textContent    = fmt(loan);
      document.getElementById('mc-total')!.textContent   = fmt(loan);
      document.getElementById('mc-interest')!.textContent = fmt(0);
      return;
    }

    const monthly  = loan * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const total    = monthly * n;
    const interest = total - loan;

    document.getElementById('mc-monthly')!.textContent  = fmt(monthly);
    document.getElementById('mc-loan')!.textContent     = fmt(loan);
    document.getElementById('mc-total')!.textContent    = fmt(total);
    document.getElementById('mc-interest')!.textContent = fmt(interest);
  }

  document.getElementById('mc-calculate')?.addEventListener('click', calculate);
  ['mc-price','mc-downpct','mc-term','mc-rate'].forEach(id => {
    document.getElementById(id)?.addEventListener('keydown', (e: any) => e.key === 'Enter' && calculate());
  });

  calculate();
</script>
