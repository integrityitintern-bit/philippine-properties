---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Agents', href: '/agents' },
  { label: 'Resources', href: '/resources' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Contact', href: '/contact' },
];
---

<nav class="fixed top-0 inset-x-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-200/60 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
      <span class="w-9 h-9 bg-orange-50 border border-orange-100 rounded-xl flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-[#ea580c]" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
        </svg>
      </span>
      <div>
        <span class="block text-gray-900 font-bold text-sm leading-tight tracking-tight whitespace-nowrap" style="font-family: 'Playfair Display', serif;">Philippine Real Estate</span>
        <span class="block text-[#ea580c] font-semibold text-xs leading-tight tracking-tight whitespace-nowrap" style="font-family: 'Playfair Display', serif;">Properties</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-7 text-sm font-medium text-gray-600 tracking-wide">
      <a href="/" class="nav-link hover:text-[#ea580c] transition-colors relative group">
        Home
        <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
      </a>

      <!-- Properties Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 hover:text-[#ea580c] transition-colors relative">
          Properties
          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
        </button>
        <div class="absolute top-full left-0 pt-3 hidden group-hover:block z-50">
          <div class="w-56 bg-white border border-gray-100 rounded-xl shadow-xl py-1">
            <a href="/pre-selling" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">🏗️ Pre-Selling Hub</a>
            <a href="/open-house" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">🗓️ Open House Calendar</a>
            <a href="/market-insights" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">📊 Market Insights</a>
            <hr class="my-1 border-gray-100"/>
            <a href="/search?listing_type=For+Sale" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">Buy Property</a>
            <a href="/list-property" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">Sell Property</a>
          </div>
        </div>
      </div>

      <a href="/agents" class="nav-link hover:text-[#ea580c] transition-colors relative group">
        Agents
        <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
      </a>

      <!-- Tools Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 hover:text-[#ea580c] transition-colors relative">
          Tools
          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
        </button>
        <div class="absolute top-full left-0 pt-3 hidden group-hover:block z-50">
          <div class="w-60 bg-white border border-gray-100 rounded-xl shadow-xl py-1">
            <a href="/mortgage-calculator" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">🏦 Mortgage Calculator</a>
            <a href="/loan-eligibility" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">✅ Loan Eligibility Checker</a>
            <a href="/resources" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">📚 Resources & Guides</a>
            <a href="/market-insights" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">📊 Market Insights</a>
          </div>
        </div>
      </div>

      <!-- About Us Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 hover:text-[#ea580c] transition-colors relative cursor-default">
          About Us
          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
        </button>
        <div class="absolute top-full left-0 pt-3 hidden group-hover:block z-50">
          <div class="w-52 bg-white border border-gray-100 rounded-xl shadow-xl py-1">
            <a href="/about" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">About Us</a>
            <a href="/agents" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">Meet Our Team</a>
            <a href="/about#achievements" class="block px-4 py-2.5 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50 transition-colors">Achievements</a>
          </div>
        </div>
      </div>

      {navLinks.filter(l => ['/faq', '/contact'].includes(l.href)).map(link => (
        <a href={link.href} class="nav-link hover:text-[#ea580c] transition-colors relative group">
          {link.label}
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#ea580c] group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-2">
      <!-- Currency toggle -->
      <button id="currency-toggle" title="Toggle currency"
        class="hidden sm:flex items-center gap-1 text-xs font-bold border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-500 px-2.5 py-1.5 rounded-lg transition-colors">
        <span id="currency-label">₱ PHP</span>
      </button>
      <!-- Dark mode toggle -->
      <button id="dark-toggle" title="Toggle dark mode"
        class="hidden sm:flex w-9 h-9 border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-500 rounded-lg items-center justify-center transition-colors">
        <svg id="dark-icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg id="dark-icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </button>
      <a href="/list-property" class="hidden sm:inline text-sm font-semibold bg-[#ea580c] hover:bg-[#c2410c] text-white px-5 py-2.5 rounded-lg transition-colors shadow-sm whitespace-nowrap">
        + List Property
      </a>
      <a href="/search" class="hidden sm:inline text-sm font-medium border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-600 px-4 py-2.5 rounded-lg transition-colors">
        Search
      </a>
      <a href="/saved" title="Saved Properties" class="hidden sm:flex w-10 h-10 border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-400 rounded-lg items-center justify-center transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </a>
      <div id="nav-auth-area" class="hidden sm:flex items-center"></div>
      <button id="mobile-menu-btn" class="md:hidden ml-1 text-gray-700 p-2">
        <svg id="menu-icon-bars" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-x" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden bg-white border-t border-gray-100 px-4 space-y-1 shadow-lg overflow-hidden"
    style="max-height:0;opacity:0;padding-top:0;padding-bottom:0;transition:max-height 0.32s ease,opacity 0.25s ease,padding 0.32s ease;">
    <a href="/" class="block text-gray-700 hover:text-[#ea580c] py-2.5 text-sm font-medium border-b border-gray-50 transition-colors">Home</a>
    <div class="border-b border-gray-50">
      <p class="text-gray-500 text-xs font-semibold uppercase tracking-widest pt-2.5 pb-1">Properties</p>
      <a href="/pre-selling" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">🏗️ Pre-Selling Hub</a>
      <a href="/open-house" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">🗓️ Open House Calendar</a>
      <a href="/market-insights" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">📊 Market Insights</a>
      <a href="/search?listing_type=For+Sale" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">Buy Property</a>
      <a href="/list-property" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 pb-2.5 text-sm transition-colors">Sell Property</a>
    </div>
    <a href="/agents" class="block text-gray-700 hover:text-[#ea580c] py-2.5 text-sm font-medium border-b border-gray-50 transition-colors">Agents</a>
    <div class="border-b border-gray-50">
      <p class="text-gray-500 text-xs font-semibold uppercase tracking-widest pt-2.5 pb-1">Tools</p>
      <a href="/mortgage-calculator" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">🏦 Mortgage Calculator</a>
      <a href="/loan-eligibility" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">✅ Loan Eligibility</a>
      <a href="/resources" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">📚 Resources & Guides</a>
      <a href="/market-insights" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 pb-2.5 text-sm transition-colors">📊 Market Insights</a>
    </div>
    <div class="border-b border-gray-50">
      <p class="text-gray-500 text-xs font-semibold uppercase tracking-widest pt-2.5 pb-1">About Us</p>
      <a href="/about" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">About Us</a>
      <a href="/agents" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 text-sm transition-colors">Meet Our Team</a>
      <a href="/about#achievements" class="block text-gray-700 hover:text-[#ea580c] py-2 pl-3 pb-2.5 text-sm transition-colors">Achievements</a>
    </div>
    {navLinks.filter(l => ['/faq', '/contact'].includes(l.href)).map(link => (
      <a href={link.href} class="block text-gray-700 hover:text-[#ea580c] py-2.5 text-sm font-medium border-b border-gray-50 transition-colors">{link.label}</a>
    ))}
    <a href="/list-property" class="block text-center bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3 rounded-lg text-sm mt-3 transition-colors">
      + List Property
    </a>
    <div id="mobile-auth-area" class="pt-2"></div>
  </div>
</nav>

<div class="h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconBars = document.getElementById('menu-icon-bars');
  const iconX = document.getElementById('menu-icon-x');
  let menuOpen = false;

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen && menu) {
      menu.style.maxHeight = menu.scrollHeight + 32 + 'px';
      menu.style.opacity = '1';
      menu.style.paddingTop = '1rem';
      menu.style.paddingBottom = '1rem';
      iconBars?.classList.add('hidden');
      iconX?.classList.remove('hidden');
    } else if (menu) {
      menu.style.maxHeight = '0';
      menu.style.opacity = '0';
      menu.style.paddingTop = '0';
      menu.style.paddingBottom = '0';
      iconX?.classList.add('hidden');
      iconBars?.classList.remove('hidden');
    }
  });
</script>

<script is:inline>
  (function() {
    // Saved count badge
    try {
      var saved = JSON.parse(localStorage.getItem('saved_properties') || '[]');
      if (saved.length > 0) {
        var link = document.querySelector('a[href="/saved"]');
        if (link) {
          link.style.position = 'relative';
          var badge = document.createElement('span');
          badge.style.cssText = 'position:absolute;top:-6px;right:-6px;width:16px;height:16px;background:#ea580c;color:white;font-size:9px;font-weight:700;border-radius:50%;display:flex;align-items:center;justify-content:center;';
          badge.textContent = saved.length > 9 ? '9+' : saved.length;
          link.appendChild(badge);
        }
      }
    } catch(e) {}
  })();
</script>

<script is:inline>
  // Dark mode toggle
  (function() {
    function applyDark(on) {
      if (on) {
        document.documentElement.classList.add('dark');
        localStorage.setItem('pp_dark', '1');
      } else {
        document.documentElement.classList.remove('dark');
        localStorage.removeItem('pp_dark');
      }
      var moon = document.getElementById('dark-icon-moon');
      var sun = document.getElementById('dark-icon-sun');
      if (moon) moon.classList.toggle('hidden', on);
      if (sun) sun.classList.toggle('hidden', !on);
    }
    function initDark() {
      var isDark = localStorage.getItem('pp_dark') === '1';
      applyDark(isDark);
      var btn = document.getElementById('dark-toggle');
      if (btn) btn.onclick = function() { applyDark(localStorage.getItem('pp_dark') !== '1'); };
    }
    initDark();
    document.addEventListener('astro:page-load', initDark);
  })();

  // Currency toggle
  (function() {
    var symbols = { PHP: '₱ PHP', USD: '$ USD' };
    function initCurrency() {
      var cur = localStorage.getItem('pp_currency') || 'PHP';
      var label = document.getElementById('currency-label');
      if (label) label.textContent = symbols[cur] || symbols['PHP'];
      var btn = document.getElementById('currency-toggle');
      if (btn) btn.onclick = function() {
        var next = (localStorage.getItem('pp_currency') || 'PHP') === 'PHP' ? 'USD' : 'PHP';
        localStorage.setItem('pp_currency', next);
        var lbl = document.getElementById('currency-label');
        if (lbl) lbl.textContent = symbols[next];
        window.dispatchEvent(new CustomEvent('pp:currency', { detail: next }));
      };
    }
    initCurrency();
    document.addEventListener('astro:page-load', initCurrency);
  })();
</script>

<script is:inline>
  function initNavAuth() {
    var user = window.ppAuth && window.ppAuth.getUser();
    var nav = document.getElementById('nav-auth-area');
    var mob = document.getElementById('mobile-auth-area');
    if (!nav) return;

    if (user) {
      var name = user.name || user.email.split('@')[0];
      var initial = name[0].toUpperCase();
      var savedPhoto = localStorage.getItem('pp_profile_photo');
      var avatarHtml = savedPhoto
        ? '<img src="' + savedPhoto + '" class="w-6 h-6 rounded-full object-cover shrink-0" />'
        : '<span class="w-6 h-6 bg-[#ea580c] rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0">' + initial + '</span>';
      nav.innerHTML =
        '<div class="relative">' +
        '<button id="nav-user-btn" class="flex items-center gap-2 text-sm font-medium border border-gray-200 hover:border-[#ea580c] text-gray-700 hover:text-[#ea580c] px-3 py-2 rounded-lg transition-colors">' +
        avatarHtml +
        '<span class="max-w-[96px] truncate">' + name + '</span>' +
        '<svg class="w-3 h-3 ml-0.5 opacity-50 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>' +
        '</button>' +
        '<div id="nav-user-menu" class="absolute right-0 top-full pt-1 hidden z-50">' +
        '<div class="w-52 bg-white border border-gray-100 rounded-xl shadow-xl py-1">' +
        '<a href="/dashboard" class="flex items-center gap-2.5 px-4 py-3 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50">📋 My Dashboard</a>' +
        '<a href="/account" class="flex items-center gap-2.5 px-4 py-3 text-sm text-gray-700 hover:text-[#ea580c] hover:bg-gray-50">⚙️ Account Settings</a>' +
        '<hr class="my-1 border-gray-100">' +
        '<button onclick="window.ppAuth.logout()" class="flex items-center gap-2.5 px-4 py-3 text-sm text-gray-500 hover:text-red-500 hover:bg-gray-50 w-full text-left">🚪 Logout</button>' +
        '</div></div></div>';

      var btn = document.getElementById('nav-user-btn');
      var menu = document.getElementById('nav-user-menu');
      if (btn && menu) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          menu.classList.toggle('hidden');
        });
      }

      if (mob) mob.innerHTML =
        '<a href="/dashboard" class="flex items-center gap-2 text-gray-700 hover:text-[#ea580c] py-3 text-sm font-medium border-b border-gray-100">📋 My Dashboard</a>' +
        '<a href="/account" class="flex items-center gap-2 text-gray-700 hover:text-[#ea580c] py-3 text-sm font-medium border-b border-gray-100">⚙️ Account Settings</a>' +
        '<button onclick="window.ppAuth.logout()" class="flex items-center gap-2 text-gray-500 hover:text-red-500 py-3 text-sm font-medium w-full text-left">🚪 Logout</button>';
    } else {
      nav.innerHTML =
        '<a href="/login" class="text-sm font-medium border border-gray-200 hover:border-[#ea580c] hover:text-[#ea580c] text-gray-600 px-4 py-2.5 rounded-lg transition-colors">Login</a>';
      if (mob) mob.innerHTML =
        '<a href="/login" class="block text-center bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold py-3 rounded-lg text-sm mt-2 transition-colors">Login / Register</a>';
    }
  }

  // Re-run on every Astro View Transition navigation
  document.addEventListener('astro:page-load', initNavAuth);

  // Close dropdown when clicking anywhere outside it
  document.addEventListener('click', function() {
    var m = document.getElementById('nav-user-menu');
    if (m) m.classList.add('hidden');
  });
</script>

