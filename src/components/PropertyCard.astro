---
const { property } = Astro.props;
const acf = property.acf || {};
const title = property.title?.rendered || 'Property';
const slug = property.slug;
const propertyId = property.id;
const image = property._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
const cdnImage = image ? `https://wsrv.nl/?url=${encodeURIComponent(image)}&w=600&q=82&output=webp` : '';
const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
const listingType = acf.listing_type || '';
const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
const badgeColor = listingType === 'For Rent'
  ? 'bg-blue-500/90'
  : listingType === 'Pre-Selling'
  ? 'bg-purple-500/90'
  : 'bg-[#ea580c]';
const isNew = (Date.now() - new Date(property.date).getTime()) < 7 * 24 * 60 * 60 * 1000;
const ohRaw = acf.open_house_date ? String(acf.open_house_date).replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3') : '';
const ohDate = ohRaw ? new Date(ohRaw) : null;
const today = new Date(); today.setHours(0,0,0,0);
const openHouseLabel = ohDate && ohDate >= today ? 'Open ' + ohDate.toLocaleDateString('en-PH', {month:'short', day:'numeric'}) : '';

// Photo count: featured image + ACF extra photo fields
const photoCount = [
  image,
  acf.photo_2, acf.photo_3, acf.photo_4, acf.photo_5,
  acf.photo_6, acf.photo_7, acf.photo_8, acf.photo_9, acf.photo_10,
].filter(Boolean).length;

// Amenity detection — handles ACF checkbox arrays, comma strings, or individual boolean fields
function hasAmenity(keywords: string[]) {
  const sources = [
    acf.amenities,
    acf.features,
    acf.property_features,
  ].filter(Boolean);
  const combined = sources.map((s: any) => Array.isArray(s) ? s.join(' ') : String(s)).join(' ').toLowerCase();
  return keywords.some(k => combined.includes(k));
}
const hasPool    = hasAmenity(['pool', 'swim']) || !!(acf.swimming_pool || acf.has_pool);
const hasGym     = hasAmenity(['gym', 'fitness']) || !!(acf.gym || acf.has_gym);
const hasParking = hasAmenity(['parking', 'garage', 'carport']) || !!(acf.parking || acf.garage || acf.has_parking);
const hasBalcony = hasAmenity(['balcony', 'terrace']) || !!(acf.balcony);

// Agent
const agentName   = acf.agent_name || '';
const agentPhoto  = typeof acf.agent_photo === 'string' ? acf.agent_photo : '';
const agentInitial = agentName ? agentName.trim()[0].toUpperCase() : '';
---

<a href={`/property/${slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:border-[#ea580c]/40 hover:shadow-lg transition-all duration-300 flex flex-col card-enter shadow-sm">

  <!-- Image -->
  <div class="relative h-48 overflow-hidden bg-gray-100">
    {cdnImage
      ? <img src={cdnImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      : <div class="w-full h-full flex items-center justify-center text-5xl opacity-20">🏠</div>
    }

    <!-- Status badges — top left -->
    <div class="absolute top-3 left-3 flex flex-col gap-1.5">
      {listingType && (
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full text-white backdrop-blur-sm ${badgeColor} w-fit`}>
          {listingType}
        </span>
      )}
      {(acf.property_status === 'Sold' || acf.property_status === 'Reserved') ? (
        <span class={`text-[10px] font-bold px-2.5 py-1 rounded-full text-white backdrop-blur-sm uppercase tracking-wider w-fit ${acf.property_status === 'Sold' ? 'bg-red-500' : 'bg-yellow-500'}`}>
          {acf.property_status}
        </span>
      ) : (
        <>
          {isNew && <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-green-500 text-white backdrop-blur-sm uppercase tracking-wider w-fit">New</span>}
          {openHouseLabel && <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-600 text-white backdrop-blur-sm uppercase tracking-wider w-fit">{openHouseLabel}</span>}
        </>
      )}
    </div>

    <!-- Action buttons — top right -->
    <div class="absolute top-3 right-3 flex flex-col gap-1.5">
      <button
        class="compare-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors"
        data-id={propertyId} data-slug={slug} data-title={title} data-price={price} data-image={cdnImage || image}
        aria-label="Compare" title="Add to compare"
      >
        <svg class="compare-icon w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </button>
      <button
        class="save-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors"
        data-id={propertyId} aria-label="Save property"
      >
        <svg class="save-icon w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>

    <!-- Photo count — bottom left -->
    {photoCount > 0 && (
      <div class="absolute bottom-2 left-2 flex items-center gap-1 bg-black/55 backdrop-blur-sm text-white text-[10px] font-semibold px-2 py-1 rounded-lg pointer-events-none">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {photoCount}
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="p-4 flex flex-col flex-1">
    <p class="text-[#f97316] font-bold text-lg leading-tight mb-1">{price}</p>
    <h3 class="text-gray-900 font-semibold text-sm leading-snug mb-1.5 line-clamp-2">{title}</h3>

    {city && (
      <p class="text-gray-400 text-xs mb-3 flex items-center gap-1">
        <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        {city}
      </p>
    )}

    <!-- Property details + amenity icons -->
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-gray-500 py-3 border-t border-b border-gray-100">
      {acf.bedrooms && (
        <span class="flex items-center gap-1">
          <!-- Bed icon -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 12V8.5A1.5 1.5 0 014.5 7H8m-5 5v4m18-4v4M8 7h8a1 1 0 011 1v4H7V8a1 1 0 011-1z"/>
          </svg>
          <span class="font-semibold text-gray-700">{acf.bedrooms}</span>
        </span>
      )}
      {acf.bathrooms && (
        <span class="flex items-center gap-1">
          <!-- Bath icon -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M4 12a2 2 0 01-2-2V8.5A1.5 1.5 0 013.5 7H6m-4 5v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
          </svg>
          <span class="font-semibold text-gray-700">{acf.bathrooms}</span>
        </span>
      )}
      {acf.floor_area && (
        <span class="flex items-center gap-1">
          <!-- Area icon -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
          </svg>
          <span class="font-semibold text-gray-700">{acf.floor_area}</span><span class="text-gray-400">m²</span>
        </span>
      )}
      {hasPool && (
        <span class="flex items-center gap-1" title="Swimming Pool">
          <!-- Pool / waves icon -->
          <svg class="w-3.5 h-3.5 text-blue-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 17c1.5-1 3-1 4.5 0s3 1 4.5 0 3-1 4.5 0 3 1 4.5 0"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 0a4 4 0 014 4H8a4 4 0 014-4z"/>
          </svg>
          <span class="text-blue-500 font-semibold">Pool</span>
        </span>
      )}
      {hasGym && (
        <span class="flex items-center gap-1" title="Gym / Fitness Center">
          <!-- Dumbbell icon -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 8v8M18 8v8M3 10v4M21 10v4M9 12h6"/>
          </svg>
          <span class="font-semibold">Gym</span>
        </span>
      )}
      {hasParking && (
        <span class="flex items-center gap-1" title="Parking / Garage">
          <!-- Car icon -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 17H3a2 2 0 01-2-2v-4l2.5-5h13l2.5 5v4a2 2 0 01-2 2h-2m-9 0a1.5 1.5 0 103 0m6 0a1.5 1.5 0 103 0"/>
          </svg>
          <span class="font-semibold">Parking</span>
        </span>
      )}
      {hasBalcony && (
        <span class="flex items-center gap-1" title="Balcony / Terrace">
          <!-- Balcony icon (simple railing) -->
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 10v8h18v-8M8 10V6m4 4V6m4 4V6"/>
          </svg>
          <span class="font-semibold">Balcony</span>
        </span>
      )}
      {!acf.bedrooms && !acf.bathrooms && !acf.floor_area && !hasPool && !hasGym && !hasParking && acf.property_type && (
        <span class="text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full capitalize">{acf.property_type}</span>
      )}
    </div>

    <!-- Agent footer -->
    {agentName ? (
      <div class="flex items-center gap-2.5 mt-3">
        {agentPhoto
          ? <img src={agentPhoto} alt={agentName} class="w-8 h-8 rounded-full object-cover border border-gray-200 shrink-0" loading="lazy" />
          : <div class="w-8 h-8 rounded-full bg-[#ea580c] flex items-center justify-center text-white text-xs font-bold shrink-0">{agentInitial}</div>
        }
        <div class="min-w-0">
          <p class="text-xs font-semibold text-gray-700 truncate">{agentName}</p>
          <p class="text-[10px] text-gray-400 uppercase tracking-wide">Verified Agent</p>
        </div>
        {acf.property_type && (
          <span class="ml-auto text-[10px] bg-gray-100 text-gray-400 px-2 py-0.5 rounded-full capitalize shrink-0">{acf.property_type}</span>
        )}
      </div>
    ) : (
      <div class="flex items-center gap-2 mt-3">
        <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-5.33 0-8 2.67-8 4v1h16v-1c0-1.33-2.67-4-8-4z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold text-gray-400 truncate">Philippine Real Estate Properties</p>
          <p class="text-[10px] text-gray-300 uppercase tracking-wide">Verified Agent</p>
        </div>
        {acf.property_type && (
          <span class="ml-auto text-[10px] bg-gray-100 text-gray-400 px-2 py-0.5 rounded-full capitalize shrink-0">{acf.property_type}</span>
        )}
      </div>
    )}
  </div>
</a>

<script>
  const saved = () => JSON.parse(localStorage.getItem('saved_properties') || '[]');

  document.querySelectorAll('.save-btn').forEach(btn => {
    const id = Number((btn as HTMLElement).dataset.id);
    const icon = btn.querySelector('.save-icon') as SVGElement;

    const setActive = (active: boolean) => {
      if (active) {
        icon.setAttribute('fill', '#ea580c');
        icon.setAttribute('stroke', '#ea580c');
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
      }
    };

    setActive(saved().includes(id));

    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      let s = saved();
      if (s.includes(id)) {
        s = s.filter((x: number) => x !== id);
        setActive(false);
      } else {
        s.push(id);
        setActive(true);
      }
      localStorage.setItem('saved_properties', JSON.stringify(s));
    });
  });

  const compareList = () => JSON.parse(localStorage.getItem('compare_list') || '[]');

  document.querySelectorAll('.compare-btn').forEach(btn => {
    const id = Number((btn as HTMLElement).dataset.id);
    const pSlug  = (btn as HTMLElement).dataset.slug  || '';
    const pTitle = (btn as HTMLElement).dataset.title || '';
    const pPrice = (btn as HTMLElement).dataset.price || '';
    const pImage = (btn as HTMLElement).dataset.image || '';
    const icon = btn.querySelector('.compare-icon') as SVGElement;

    const setCmpActive = (active: boolean) => {
      if (active) {
        icon.setAttribute('stroke', '#16a34a');
        (btn as HTMLElement).style.background = 'rgba(220,252,231,0.95)';
        (btn as HTMLElement).title = 'Remove from compare';
      } else {
        icon.setAttribute('stroke', 'currentColor');
        (btn as HTMLElement).style.background = '';
        (btn as HTMLElement).title = 'Add to compare';
      }
    };

    setCmpActive(compareList().some((x: any) => x.id === id));

    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      let list = compareList();
      const inList = list.some((x: any) => x.id === id);
      if (inList) {
        list = list.filter((x: any) => x.id !== id);
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(false);
      } else {
        if (list.length >= 3) {
          alert('You can compare up to 3 properties. Remove one first at /compare');
          return;
        }
        list.push({ id, slug: pSlug, title: pTitle, price: pPrice, image: pImage });
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(true);
        const toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:5rem;right:1.5rem;z-index:1000;background:#1e293b;color:white;font-size:13px;font-weight:600;padding:10px 16px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;';
        toast.innerHTML = '&#10003; Added to compare &nbsp;<a href="/compare" style="color:#fb923c;text-decoration:underline">View &#8594;</a>';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3500);
      }
    });
  });
</script>
