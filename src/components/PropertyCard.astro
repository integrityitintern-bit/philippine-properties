---
const { property } = Astro.props;
const acf = property.acf || {};
const title = property.title?.rendered || 'Property';
const slug = property.slug;
const propertyId = property.id;
const image = property._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
const price = acf.price ? '₱' + Number(acf.price).toLocaleString('en-PH') : 'Price on Request';
const listingType = acf.listing_type || '';
const city = [acf.location_city, acf.location_province].filter(Boolean).join(', ');
const badgeColor = listingType === 'For Rent'
  ? 'bg-blue-500/90'
  : listingType === 'Pre-Selling'
  ? 'bg-purple-500/90'
  : 'bg-[#ea580c]';
const isNew = (Date.now() - new Date(property.date).getTime()) < 7 * 24 * 60 * 60 * 1000;
const ohRaw = acf.open_house_date ? String(acf.open_house_date).replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3') : '';
const ohDate = ohRaw ? new Date(ohRaw) : null;
const today = new Date(); today.setHours(0,0,0,0);
const openHouseLabel = ohDate && ohDate >= today ? 'Open ' + ohDate.toLocaleDateString('en-PH', {month:'short', day:'numeric'}) : '';
const pricePerSqm = (acf.price && acf.floor_area) ? '₱' + Math.round(Number(acf.price) / Number(acf.floor_area)).toLocaleString('en-PH') + '/m²' : '';
---

<a href={`/property/${slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:border-[#ea580c]/40 hover:shadow-lg transition-all duration-300 flex flex-col card-enter shadow-sm">
  <div class="relative h-48 overflow-hidden bg-gray-100">
    {image
      ? <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      : <div class="w-full h-full flex items-center justify-center text-5xl opacity-20">🏠</div>
    }
    <!-- WP SETUP: In ACF → Field Groups → Property Details, add field:
         Label: Property Status | Name: property_status | Type: Select
         Choices: Available | Sold | Reserved -->
    <div class="absolute top-3 left-3 flex flex-col gap-1.5">
      {listingType && (
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full text-white backdrop-blur-sm ${badgeColor} w-fit`}>
          {listingType}
        </span>
      )}
      {(acf.property_status === 'Sold' || acf.property_status === 'Reserved') ? (
        <span class={`text-[10px] font-bold px-2.5 py-1 rounded-full text-white backdrop-blur-sm uppercase tracking-wider w-fit ${acf.property_status === 'Sold' ? 'bg-red-500' : 'bg-yellow-500'}`}>
          {acf.property_status}
        </span>
      ) : (
        <>
          {isNew && (
            <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-green-500 text-white backdrop-blur-sm uppercase tracking-wider w-fit">
              New
            </span>
          )}
          {openHouseLabel && (
            <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-600 text-white backdrop-blur-sm uppercase tracking-wider w-fit">
              {openHouseLabel}
            </span>
          )}
        </>
      )}
    </div>
    <div class="absolute top-3 right-3 flex flex-col gap-1.5">
      <button
        class="compare-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors"
        data-id={propertyId}
        data-slug={slug}
        data-title={title}
        data-price={price}
        data-image={image}
        aria-label="Compare property"
        title="Add to compare"
      >
        <svg class="compare-icon w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </button>
      <button
        class="save-btn w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow hover:bg-white transition-colors"
        data-id={propertyId}
        aria-label="Save property"
      >
        <svg class="save-icon w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="p-4 flex flex-col flex-1">
    <p class="text-[#f97316] font-bold text-lg leading-tight mb-1">{price}</p>
    <h3 class="text-gray-900 font-semibold text-sm leading-snug mb-2 line-clamp-2">{title}</h3>
    {city && (
      <p class="text-gray-400 text-xs mb-3 flex items-center gap-1">
        <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        {city}
      </p>
    )}
    <div class="flex items-center gap-3 text-gray-400 text-xs mt-auto pt-3 border-t border-gray-100">
      {acf.bedrooms && <span>🛏 {acf.bedrooms}</span>}
      {acf.bathrooms && <span>🚿 {acf.bathrooms}</span>}
      {acf.floor_area && <span>📐 {acf.floor_area}m²</span>}
      {pricePerSqm && <span class="text-gray-300">·</span>}
      {pricePerSqm && <span class="text-gray-400">{pricePerSqm}</span>}
      {acf.property_type && (
        <span class="ml-auto capitalize text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">{acf.property_type}</span>
      )}
    </div>
  </div>
</a>

<script>
  const saved = () => JSON.parse(localStorage.getItem('saved_properties') || '[]');

  document.querySelectorAll('.save-btn').forEach(btn => {
    const id = Number((btn as HTMLElement).dataset.id);
    const icon = btn.querySelector('.save-icon') as SVGElement;

    const setActive = (active: boolean) => {
      if (active) {
        icon.setAttribute('fill', '#ea580c');
        icon.setAttribute('stroke', '#ea580c');
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
      }
    };

    setActive(saved().includes(id));

    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      let s = saved();
      if (s.includes(id)) {
        s = s.filter((x: number) => x !== id);
        setActive(false);
      } else {
        s.push(id);
        setActive(true);
      }
      localStorage.setItem('saved_properties', JSON.stringify(s));
    });
  });

  // Compare buttons
  const compareList = () => JSON.parse(localStorage.getItem('compare_list') || '[]');

  document.querySelectorAll('.compare-btn').forEach(btn => {
    const id = Number((btn as HTMLElement).dataset.id);
    const pSlug = (btn as HTMLElement).dataset.slug || '';
    const pTitle = (btn as HTMLElement).dataset.title || '';
    const pPrice = (btn as HTMLElement).dataset.price || '';
    const pImage = (btn as HTMLElement).dataset.image || '';
    const icon = btn.querySelector('.compare-icon') as SVGElement;

    const setCmpActive = (active: boolean) => {
      if (active) {
        icon.setAttribute('stroke', '#16a34a');
        (btn as HTMLElement).style.background = 'rgba(220,252,231,0.95)';
        (btn as HTMLElement).title = 'Remove from compare';
      } else {
        icon.setAttribute('stroke', 'currentColor');
        (btn as HTMLElement).style.background = '';
        (btn as HTMLElement).title = 'Add to compare';
      }
    };

    setCmpActive(compareList().some((x: any) => x.id === id));

    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      let list = compareList();
      const inList = list.some((x: any) => x.id === id);
      if (inList) {
        list = list.filter((x: any) => x.id !== id);
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(false);
      } else {
        if (list.length >= 3) {
          alert('You can compare up to 3 properties. Remove one first at /compare');
          return;
        }
        list.push({ id, slug: pSlug, title: pTitle, price: pPrice, image: pImage });
        localStorage.setItem('compare_list', JSON.stringify(list));
        setCmpActive(true);
        const toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:5rem;right:1.5rem;z-index:1000;background:#1e293b;color:white;font-size:13px;font-weight:600;padding:10px 16px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;';
        toast.innerHTML = '&#10003; Added to compare &nbsp;<a href="/compare" style="color:#fb923c;text-decoration:underline">View &#8594;</a>';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3500);
      }
    });
  });
</script>
