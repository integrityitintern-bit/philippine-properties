---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const {
  title = 'Real Estate Portal',
  description = 'Find your dream property in the Philippines',
  ogImage = '/hero-bg.jpg',
  ogType = 'website',
  pageClass = '',
} = Astro.props;
const siteName = 'Integrity Real Estate Corp';
const fullTitle = title === 'Real Estate Portal' ? `${siteName} | Philippine Properties` : `${title} | ${siteName}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Integrity Realty" />
    <!-- Google Analytics: replace G-XXXXXXXXXX with your Measurement ID from analytics.google.com -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
      gtag('js',new Date());gtag('config','G-XXXXXXXXXX');
    </script> -->
    <!-- Microsoft Clarity: replace XXXXXXXXXX with your Project ID from clarity.microsoft.com -->
    <!--
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","XXXXXXXXXX");
    </script>
    -->
  </head>
  <body class={`min-h-screen${pageClass ? ' ' + pageClass : ''}`}>
    <!-- Loading progress bar -->
    <div id="nprogress" style="position:fixed;top:0;left:0;z-index:9999;height:3px;width:0;background:linear-gradient(90deg,#ea580c,#f97316);box-shadow:0 0 8px rgba(234,88,12,0.4);transition:width 0.4s ease,opacity 0.25s ease;pointer-events:none;opacity:0"></div>
    <script is:inline>
      (function(){
        var bar=document.getElementById('nprogress');
        function show(){bar.style.opacity='1';bar.style.width='30%';setTimeout(function(){bar.style.width='70%';},100);}
        function done(){bar.style.width='100%';setTimeout(function(){bar.style.opacity='0';setTimeout(function(){bar.style.width='0';},250);},200);}
        show();
        window.addEventListener('load',done);
        document.addEventListener('astro:page-load',done);
        document.addEventListener('astro:before-preparation',show);
        document.addEventListener('click',function(e){
          var a=e.target&&e.target.closest&&e.target.closest('a');
          if(a&&a.href&&a.origin===location.origin&&a.target!=='_blank'&&!a.href.startsWith('mailto:')&&!a.href.startsWith('tel:')&&a.getAttribute('href')!=='#'){show();}
        });
      })();
    </script>
    <script is:inline>
      window.ppAuth = {
        getUser: function() {
          try {
            var s = localStorage.getItem('pp_user');
            if (!s) return null;
            var u = JSON.parse(s);
            if (Date.now() >= u.expires_at) { localStorage.removeItem('pp_user'); return null; }
            return u;
          } catch(e) { return null; }
        },
        setUser: function(token, email, name) {
          var u = {
            token: token,
            email: email,
            name: name || email.split('@')[0],
            expires_at: Date.now() + 7 * 24 * 60 * 60 * 1000
          };
          localStorage.setItem('pp_user', JSON.stringify(u));
          return u;
        },
        logout: function() { localStorage.removeItem('pp_user'); window.location.href = '/'; }
      };
    </script>
    <slot />
    <!-- WhatsApp Float — update the number below (format: 63 + mobile number without 0) -->
    <a href="https://wa.me/639XXXXXXXXX?text=Hi%21+I%27m+interested+in+your+properties." target="_blank" rel="noopener" aria-label="Chat on WhatsApp"
      class="fixed bottom-20 md:bottom-6 left-4 md:left-6 w-14 h-14 bg-[#25D366] hover:bg-[#1da850] rounded-full shadow-xl shadow-green-900/30 flex items-center justify-center z-50 transition-all duration-300 hover:scale-110 print:hidden">
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
    <!-- Cookie Banner -->
    <div id="cookie-banner" class="fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur-sm border-t border-gray-200 shadow-lg px-4 py-4" style="display:none">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-600 text-sm text-center sm:text-left">
          We use cookies to improve your experience. By continuing, you agree to our
          <a href="/privacy" class="text-[#ea580c] hover:underline">Privacy Policy</a>.
        </p>
        <div class="flex gap-3 shrink-0">
          <button id="cookie-decline" class="text-sm text-gray-400 hover:text-gray-700 transition-colors px-4 py-2">Decline</button>
          <button id="cookie-accept" class="text-sm bg-[#ea580c] hover:bg-[#c2410c] text-white font-semibold px-5 py-2 rounded-lg transition-colors">Accept All</button>
        </div>
      </div>
    </div>
    <script is:inline>
      (function() {
        if (!localStorage.getItem('cookie_consent')) {
          var b = document.getElementById('cookie-banner');
          if (b) b.style.display = 'block';
        }
        function dismiss(val) {
          localStorage.setItem('cookie_consent', val);
          var b = document.getElementById('cookie-banner');
          if (b) b.style.display = 'none';
        }
        document.getElementById('cookie-accept')?.addEventListener('click', function() { dismiss('accepted'); });
        document.getElementById('cookie-decline')?.addEventListener('click', function() { dismiss('declined'); });
      })();
    </script>
    <!-- Back to top -->
    <button id="back-to-top" aria-label="Back to top"
      class="fixed bottom-20 md:bottom-6 right-4 md:right-6 w-11 h-11 bg-[#ea580c] hover:bg-[#c2410c] text-white rounded-full shadow-lg shadow-orange-900/40 flex items-center justify-center z-50 transition-all duration-300 print:hidden"
      style="opacity:0;transform:translateY(1rem);pointer-events:none">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
      </svg>
    </button>
    <script is:inline>
      (function() {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function() {
          if (window.scrollY > 300) {
            btn.style.opacity = '1';
            btn.style.transform = 'translateY(0)';
            btn.style.pointerEvents = 'auto';
          } else {
            btn.style.opacity = '0';
            btn.style.transform = 'translateY(1rem)';
            btn.style.pointerEvents = 'none';
          }
        }, { passive: true });
        btn.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
    <!-- Tawk.to Live Chat: replace XXXXXXXXXX/YYYYYYYY with IDs from tawk.to dashboard -->
    <!--
    <script is:inline type="text/javascript">
      var Tawk_API=Tawk_API||{},Tawk_LoadStart=new Date();
      (function(){var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
      s1.async=true;s1.src='https://embed.tawk.to/XXXXXXXXXX/YYYYYYYY';
      s1.charset='UTF-8';s1.setAttribute('crossorigin','*');
      s0.parentNode.insertBefore(s1,s0);})();
    </script>
    -->
    <!-- Mobile bottom spacer (matches tab bar height) -->
    <div class="h-16 md:hidden print:hidden"></div>
    <!-- Mobile bottom tab bar -->
    <nav class="fixed bottom-0 inset-x-0 z-30 bg-white border-t border-gray-200 md:hidden print:hidden flex items-stretch h-16 safe-area-inset-bottom">
      <a href="/" class="flex-1 flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-[#ea580c] transition-colors active:bg-gray-50" id="tabnav-home">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a1 1 0 01-1 1H4a1 1 0 01-1-1V9.75z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/></svg>
        <span class="text-[10px] font-medium">Home</span>
      </a>
      <a href="/search" class="flex-1 flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-[#ea580c] transition-colors active:bg-gray-50" id="tabnav-search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/></svg>
        <span class="text-[10px] font-medium">Search</span>
      </a>
      <a href="/saved" class="flex-1 flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-[#ea580c] transition-colors active:bg-gray-50" id="tabnav-saved">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        <span class="text-[10px] font-medium">Saved</span>
      </a>
      <a href="/compare" class="flex-1 flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-[#ea580c] transition-colors active:bg-gray-50" id="tabnav-compare">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        <span class="text-[10px] font-medium">Compare</span>
      </a>
      <a href="/list-property" class="flex-1 flex flex-col items-center justify-center gap-1 text-[#ea580c] transition-colors active:bg-orange-50" id="tabnav-list">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v8M8 12h8"/></svg>
        <span class="text-[10px] font-medium">List</span>
      </a>
    </nav>
    <script is:inline>
      (function() {
        var path = window.location.pathname;
        var map = { '/': 'tabnav-home', '/search': 'tabnav-search', '/saved': 'tabnav-saved', '/compare': 'tabnav-compare', '/list-property': 'tabnav-list' };
        var active = map[path] || (path.startsWith('/search') ? 'tabnav-search' : null);
        if (active) {
          var el = document.getElementById(active);
          if (el) { el.classList.remove('text-gray-400'); el.classList.add('text-[#ea580c]'); }
        }
      })();
    </script>
  </body>
</html>
